# Shiorra app — copy to .env and fill in real values

# Server
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Postgres — local example. On VPS, use the production connection string.
DATABASE_URL=postgresql://shiorra:shiorra@localhost:5432/shiorra?schema=public

# Session — generate a long random string for production
SESSION_SECRET=change-me-to-a-long-random-string

# Razorpay (test keys; replace with live keys before going to production)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Transactional email (order confirmations).
# Leave RESEND_API_KEY (and MAIL_HOST/MAIL_PASS) blank to disable — the app
# just logs "[mailer] skipped" and never sends. The order flow never breaks.
#
# Preferred: Resend's HTTP API (port 443). Use this on a VPS — many hosts block
# outbound SMTP ports, which makes SMTP fail silently in production.
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# MAIL_FROM must be on a domain VERIFIED in Resend (Dashboard → Domains → add
# DNS records). Free-provider addresses (@gmail.com, @outlook.com) CANNOT be
# used as the sender — you can't add DNS records there and Gmail's DMARC policy
# rejects them. Put such an address in MAIL_REPLY_TO instead, so customer
# replies land in that inbox while the sender stays on a verified domain.
RESEND_API_KEY=
MAIL_FROM=Shiōrra <orders@shiorra.com>
MAIL_REPLY_TO=hello@shiorra.com

# Optional SMTP fallback (any provider) — only used when RESEND_API_KEY is blank.
MAIL_HOST=
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=resend
MAIL_PASS=

# Uploads
UPLOAD_DIR=src/public/uploads
MAX_UPLOAD_MB=8

# First-time admin bootstrap (used by `npm run seed` if no admin exists)
ADMIN_EMAIL=admin@shiorra.com
ADMIN_PASSWORD=ChangeMeNow!2026
ADMIN_NAME=Shiorra Admin
