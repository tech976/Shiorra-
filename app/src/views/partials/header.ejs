<header class="site-header" id="siteHeader">
    <div class="container">
        <nav class="nav" id="primaryNav">
            <a href="/" class="nav__logo" aria-label="Shiōrra home">
                <img src="/img/logo/logo-green.png" alt="Shiōrra">
            </a>
            <ul class="nav__menu" id="navMenu">
                <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a></li>
                <li><a href="/shop" class="<%= currentPath.startsWith('/shop') || currentPath.startsWith('/product/') ? 'active' : '' %>">Shop Products</a></li>
                <li><a href="/reviews" class="<%= currentPath === '/reviews' ? 'active' : '' %>">Reviews</a></li>
                <li><a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a></li>
                <li><a href="/faq" class="<%= currentPath === '/faq' ? 'active' : '' %>">FAQ</a></li>
            </ul>
            <div class="nav__cta">
                <ul class="nav__icons">
                    <li><a href="<%= currentUser ? '/account' : '/login' %>" aria-label="Account">
                        <svg class="ico" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </a></li>
                    <li><a href="/cart" aria-label="Cart">
                        <svg class="ico" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
                        <% if (cartCount > 0) { %><span class="cart-dot"><%= cartCount %></span><% } %>
                    </a></li>
                </ul>
                <% if (currentUser) { %>
                    <% if (currentUser.role === 'ADMIN') { %>
                        <a href="/admin" class="btn btn--ghost">Admin</a>
                    <% } %>
                    <form action="/logout" method="post" class="nav__logout-form" style="margin:0;display:inline">
                        <button type="submit" class="btn">Log out</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="btn btn--ghost">Log in</a>
                    <a href="/register" class="btn">Sign up</a>
                <% } %>
                <button class="nav__toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </nav>
    </div>
</header>
