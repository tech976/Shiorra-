<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Advanced EnergyOne+ · Shiōrra Daily Energy & Focus Support</title>
<meta name="description" content="Shiōrra Advanced EnergyOne+ — Daily energy, focus & vitality support. Taurine, Ginseng Extract, B-Complex vitamins, essential minerals and amino acids. Caffeine-free, multi-nutrient formula. A trademark of K.C. Laboratories." />
<link rel="shortcut icon" type="image/png" href="/img/logo/logo-green.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    /* EnergyOne+ product accent — warm orange-amber (vitality) */
    --honey:#EA580C;
    --honey-2:#C2410C;
    --honey-deep:#7C2D12;
    --honey-soft:#FFEDD5;
    --charcoal:#282828;
    --charcoal-2:#3A3A3A;
    --ink:#282828;
    --ink-soft:#3A3A3A;
    --white:#FFFFFF;
    --surface:#F7F7F8;
    --surface-2:#FBFBFC;
    --line:#E5E5E7;
    --line-soft:#F0F0F2;
    --muted:#6B6B6B;
    --muted-2:#8A8A8A;
    --green:#1E9E5C;
    --shadow-sm:0 2px 6px rgba(40,40,40,.06);
    --shadow-md:0 8px 24px rgba(40,40,40,.08);
  }
  html{scroll-behavior:smooth;overflow-x:clip}
  body{
    font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
    color:var(--ink);
    background:#fff;
    line-height:1.55;
    font-size:15px;
    overflow-x:clip;
    padding-bottom:88px;
  }
  @media(max-width:680px){body{padding-bottom:80px}}
  img{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  button{font:inherit;cursor:pointer;border:0;background:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}

  /* ---------- Marquee ---------- */
  .marquee{background:var(--charcoal);color:#fff;padding:10px 0;overflow:hidden;border-bottom:1px solid var(--line)}
  .marquee-track{display:flex;gap:48px;width:max-content;animation:marquee 36s linear infinite;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
  .marquee-item{display:inline-flex;align-items:center;gap:8px}
  .marquee-item svg{width:14px;height:14px;color:var(--honey)}
  .marquee-item .accent{color:var(--honey)}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* ---------- Header is from css/style.css (.site-header / .nav__menu) ---------- */

  /* ---------- Trust microbar ---------- */
  .microbar{background:var(--surface);border-bottom:1px solid var(--line);padding:8px 0;font-size:12px;color:var(--ink-soft);font-weight:500}
  .microbar-inner{display:flex;justify-content:center;gap:32px;flex-wrap:wrap}
  .microbar-item{display:inline-flex;align-items:center;gap:6px}
  .microbar-item svg{width:14px;height:14px;color:var(--honey)}

  /* ---------- Hero ---------- */
  .product-hero{
    background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);
    padding:48px 0 64px;
    position:relative;
    overflow:hidden;
  }
  .product-hero::before{
    content:'';position:absolute;top:-100px;right:-100px;
    width:420px;height:420px;border-radius:50%;
    background:radial-gradient(circle,rgba(234,88,12,.18) 0%,transparent 70%);
    pointer-events:none;
  }
  .product-hero-grid{
    display:grid;grid-template-columns:1fr 1.05fr;gap:48px;align-items:start;
    position:relative;
  }
  @media(max-width:880px){.product-hero-grid{grid-template-columns:1fr;gap:28px}}

  .gallery{position:sticky;top:88px}
  @media(max-width:880px){.gallery{position:static}}
  .gallery-main{aspect-ratio:4/5;width:100%;background:#fff;border-radius:22px;border:1px solid var(--line);
    display:grid;place-items:center;overflow:hidden;position:relative;
  }
  .gallery-main img{width:100%;height:100%;object-fit:cover;object-position:center}
  .gallery-thumbs{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:10px}
  .gallery-thumb{aspect-ratio:4/5;background:#fff;border:1.5px solid var(--line);border-radius:12px;overflow:hidden;cursor:pointer;padding:0;transition:border-color .2s,transform .2s}
  .gallery-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s ease}
  .gallery-thumb:hover{border-color:var(--honey);transform:translateY(-1px)}
  .gallery-thumb.is-active{border-color:var(--honey);box-shadow:0 0 0 3px var(--honey-soft) inset}
  .gallery-placeholder{
    width:90%;height:90%;display:grid;place-items:center;flex-direction:column;
    background:repeating-linear-gradient(45deg,#fff7e5 0 16px,#fde4b8 16px 32px);
    border-radius:16px;color:var(--honey-deep);
    font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;letter-spacing:.08em;text-transform:uppercase;font-size:18px;text-align:center;padding:24px;
  }
  .gallery-placeholder span{display:block;font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.04em;text-transform:none;margin-top:8px;font-style:italic}
  .float-badge{
    position:absolute;background:#fff;border-radius:14px;padding:8px 14px;font-size:12px;font-weight:700;
    box-shadow:0 8px 24px rgba(40,40,40,.10);display:inline-flex;align-items:center;gap:8px;
  }
  .float-1{top:18px;left:18px}
  .float-2{bottom:18px;right:18px}
  .float-1-icon{width:24px;height:24px;border-radius:50%;background:var(--honey);color:#fff;display:grid;place-items:center;font-weight:800;font-size:12px}
  .pulse-dot{width:8px;height:8px;border-radius:50%;background:var(--honey);animation:pulse 1.6s infinite}
  @keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(234,88,12,.7)}50%{box-shadow:0 0 0 6px rgba(234,88,12,0)}}

  /* Product info column */
  .info{padding-top:8px}
  .pi-eyebrow-trust{display:inline-flex;align-items:center;gap:8px;background:var(--honey-soft);color:var(--honey-deep);font-size:11.5px;font-weight:800;padding:6px 12px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px}
  .pi-eyebrow-trust::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--honey)}
  .pi-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:40px;font-weight:700;line-height:1.08;letter-spacing:-0.022em;color:var(--ink);margin-bottom:10px}
  .pi-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.pi-title{font-size:32px}}
  .pi-sub{font-size:18px;color:var(--honey-deep);font-style:italic;font-weight:500;line-height:1.45;margin-bottom:22px;max-width:520px}
  .pi-tagrow{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px}
  .pi-tag{font-size:11px;font-weight:700;color:var(--ink-soft);background:#fff;border:1px solid var(--line);padding:5px 10px;border-radius:14px;letter-spacing:.06em;text-transform:uppercase}
  .pi-tag.ven{background:var(--green);color:#fff;border-color:var(--green)}
  .pi-rating{display:flex;align-items:center;gap:10px;margin-bottom:18px}
  .stars{display:inline-flex;gap:1px;color:var(--honey);font-size:17px;letter-spacing:1.5px}
  .pi-rating-n{font-weight:700;font-size:15px}
  .pi-rating-c{font-size:13px;color:var(--muted);text-decoration:underline}

  /* Price + CTA */
  .pi-price{display:flex;align-items:baseline;gap:12px;margin:6px 0 18px;flex-wrap:wrap}
  .pi-now{font-family:'Helvetica Neue',Arial,sans-serif;font-size:38px;font-weight:700;color:var(--ink);letter-spacing:-0.02em}
  .pi-mrp{font-size:18px;color:var(--muted);text-decoration:line-through}
  .pi-save{font-size:11px;font-weight:800;color:#fff;background:var(--honey);padding:4px 10px;border-radius:8px;letter-spacing:.06em;text-transform:uppercase}

  .pi-buy-row{display:flex;gap:10px;margin:18px 0}
  .pi-qty{display:inline-flex;align-items:center;border:1px solid var(--line);border-radius:12px;background:#fff;overflow:hidden}
  .pi-qty button{width:38px;height:46px;font-size:18px;color:var(--ink);font-weight:700}
  .pi-qty input{width:44px;height:46px;border:0;text-align:center;font-size:15px;font-weight:700;font-family:inherit;background:transparent}
  .pi-qty input::-webkit-inner-spin-button{display:none}
  .pi-add{flex:1;height:46px;display:inline-flex;align-items:center;justify-content:center;background:var(--charcoal);color:#fff;font-weight:700;font-size:14px;letter-spacing:.04em;border-radius:12px;text-transform:uppercase;transition:background .2s,transform .2s}
  .pi-add:hover{background:var(--charcoal-2);transform:translateY(-1px)}

  .pi-trust-line{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);margin-top:8px}
  .pi-trust-line svg{width:14px;height:14px;color:var(--honey)}

  .pi-points{margin-top:24px;display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
  .pi-points li{display:flex;align-items:center;gap:8px;font-size:13.5px;list-style:none;color:var(--ink-soft)}
  .pi-points li svg{width:16px;height:16px;color:var(--honey);flex-shrink:0}

  /* ---------- Generic section ---------- */
  section.s{padding:72px 0;font-size:17px}
  @media(max-width:680px){section.s{padding:56px 0}}
  .s-eyebrow{display:inline-block;background:var(--honey-soft);color:var(--honey-deep);font-size:12px;font-weight:700;padding:7px 14px;border-radius:20px;letter-spacing:.10em;text-transform:uppercase;margin-bottom:16px}
  .s-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:48px;font-weight:700;line-height:1.05;letter-spacing:-0.025em;margin-bottom:16px;max-width:760px;color:var(--charcoal)}
  .s-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.s-title{font-size:36px}}
  .s-sub{font-size:17px;color:var(--ink-soft);max-width:640px;line-height:1.6}
  .s-head{margin-bottom:40px}
  .s-head.center{text-align:center}
  .s-head.center .s-title,.s-head.center .s-sub{margin-left:auto;margin-right:auto}

  /* ---------- Why tired (problem) ---------- */
  .symptoms-bg{background:#fff}
  .symptoms-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
  @media(max-width:880px){.symptoms-grid{grid-template-columns:repeat(2,1fr)}}
  .symptom-card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:22px;transition:transform .25s,box-shadow .25s,border-color .25s}
  .symptom-card:hover{transform:translateY(-3px);box-shadow:0 14px 36px rgba(40,40,40,.10);border-color:var(--honey)}
  .symptom-card .ic{width:42px;height:42px;border-radius:12px;background:var(--honey-soft);color:var(--honey-deep);display:grid;place-items:center;margin-bottom:14px}
  .symptom-card .ic svg{width:22px;height:22px}
  .symptom-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:16px;font-weight:700;margin-bottom:6px;color:var(--ink)}
  .symptom-card p{font-size:14px;color:var(--muted);line-height:1.5}

  /* ---------- Power team (Taurine, Ginseng) ---------- */
  .power-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .power-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
  @media(max-width:880px){.power-grid{grid-template-columns:1fr}}
  .power-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;position:relative;overflow:hidden}
  .power-card::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(234,88,12,.10) 0%,transparent 70%);pointer-events:none}
  .power-card .pc-eye{display:inline-block;background:var(--honey-soft);color:var(--honey-deep);font-size:11px;font-weight:800;padding:5px 10px;border-radius:14px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:12px}
  .power-card h3{font-family:'Helvetica Neue',Arial,sans-serif;font-size:24px;margin-bottom:8px}
  .power-card .pc-lede{font-size:14.5px;color:var(--muted);margin-bottom:18px;line-height:1.55}
  .power-card ul{list-style:none;display:grid;gap:8px}
  .power-card li{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--ink-soft)}
  .power-card li svg{width:16px;height:16px;color:var(--honey)}
  .power-card .pc-tag{margin-top:16px;font-size:12px;color:var(--honey-deep);font-style:italic}

  /* ---------- B Vitamins ---------- */
  .bvit-bg{background:#fff}
  .bvit-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:10px;margin-top:18px}
  @media(max-width:980px){.bvit-grid{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:520px){.bvit-grid{grid-template-columns:repeat(2,1fr)}}
  .bvit-pill{background:var(--honey-soft);border:1px solid rgba(234,88,12,.20);border-radius:12px;padding:14px 10px;text-align:center}
  .bvit-pill .name{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:13px;color:var(--honey-deep);letter-spacing:.04em}
  .bvit-pill .sub{font-size:11px;color:var(--muted);margin-top:2px}
  .bvit-help{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:32px}
  @media(max-width:880px){.bvit-help{grid-template-columns:repeat(2,1fr)}}
  .bvit-help-card{background:var(--surface);border-radius:14px;padding:18px}
  .bvit-help-card .ic{width:34px;height:34px;border-radius:10px;background:var(--honey-soft);color:var(--honey-deep);display:grid;place-items:center;margin-bottom:8px}
  .bvit-help-card .ic svg{width:18px;height:18px}
  .bvit-help-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:14px;margin-bottom:4px;color:var(--ink)}
  .bvit-help-card p{font-size:13px;color:var(--muted)}

  /* ---------- Minerals + Amino Acids ---------- */
  .min-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .min-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
  @media(max-width:880px){.min-grid{grid-template-columns:repeat(2,1fr)}}
  .min-card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:20px}
  .min-card .ic{width:34px;height:34px;border-radius:10px;background:var(--honey-soft);color:var(--honey-deep);display:grid;place-items:center;font-family:'Helvetica Neue';font-weight:800;font-size:14px;margin-bottom:10px}
  .min-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:15px;margin-bottom:4px;color:var(--ink)}
  .min-card p{font-size:13.5px;color:var(--muted);line-height:1.5}

  .amino-bg{background:#fff}
  .amino-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:24px}
  @media(max-width:880px){.amino-grid{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:520px){.amino-grid{grid-template-columns:repeat(2,1fr)}}
  .amino-pill{background:#fff;border:1.5px solid var(--honey-soft);color:var(--honey-deep);font-family:'Helvetica Neue';font-weight:700;font-size:13px;padding:9px 8px;border-radius:10px;text-align:center;letter-spacing:.02em}
  .amino-list{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:18px}
  @media(max-width:680px){.amino-list{grid-template-columns:1fr}}
  .amino-list li{list-style:none;display:flex;gap:10px;font-size:14px;color:var(--ink-soft);align-items:center}
  .amino-list li svg{width:18px;height:18px;color:var(--honey);flex-shrink:0}

  /* ---------- Timeline (what you'll notice) ---------- */
  .timeline-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .timeline-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:16px}
  @media(max-width:880px){.timeline-grid{grid-template-columns:1fr}}
  .tl-card{background:#fff;border:1px solid var(--line);border-radius:18px;padding:24px;position:relative;transition:transform .25s,box-shadow .25s,border-color .25s}
  .tl-card:hover{transform:translateY(-3px);box-shadow:0 14px 36px rgba(40,40,40,.10);border-color:var(--honey)}
  .tl-step{position:absolute;top:18px;right:18px;background:var(--honey);color:#fff;font-family:'Helvetica Neue';font-weight:800;font-size:11px;padding:4px 10px;border-radius:14px;letter-spacing:.06em}
  .tl-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:20px;color:var(--ink);margin:18px 0 12px;max-width:80%}
  .tl-card ul{list-style:none;display:grid;gap:7px}
  .tl-card li{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--ink-soft)}
  .tl-card li svg{width:15px;height:15px;color:var(--honey)}
  .tl-stat{margin-top:32px;background:var(--honey);color:#fff;border-radius:14px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
  .tl-stat strong{font-family:'Helvetica Neue';font-weight:800;font-size:22px;letter-spacing:-0.02em}
  .tl-stat .ref{font-size:11px;opacity:.85;font-style:italic}

  /* ---------- Comparison table ---------- */
  .why-bg{background:#fff}
  .compare-table{margin-top:14px;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff}
  .compare-row{display:grid;grid-template-columns:1.2fr 1fr 1fr}
  .compare-row + .compare-row{border-top:1px solid var(--line-soft)}
  .compare-row.head{background:var(--surface);font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--ink)}
  .compare-row.head .cc{padding:14px 18px}
  .compare-row.head .cc:first-child{visibility:hidden}
  .compare-row.head .cc:nth-child(2){color:var(--honey-deep);background:var(--honey-soft)}
  .cc{padding:14px 18px;font-size:14px;line-height:1.45}
  .cc.lbl{font-weight:700;color:var(--ink)}
  .cc.them{color:var(--muted)}
  .cc.us{background:var(--honey-soft);color:var(--ink);font-weight:600}
  @media(max-width:680px){
    .compare-row{grid-template-columns:1fr 1fr}
    .compare-row.head .cc:first-child{display:none}
    .cc.lbl{grid-column:1/-1;background:var(--line-soft);font-size:13px}
  }

  /* ---------- Root cause table ---------- */
  .root-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .root-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:14px}
  @media(max-width:980px){.root-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:580px){.root-grid{grid-template-columns:1fr}}
  .root-card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:22px}
  .root-card .rc-eye{font-family:'Helvetica Neue';font-weight:800;font-size:11px;color:var(--honey-deep);letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}
  .root-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:16px;color:var(--ink);margin-bottom:8px}
  .root-card p{font-size:13.5px;color:var(--muted);line-height:1.5;margin-bottom:14px}
  .root-card .solve{display:flex;gap:8px;align-items:flex-start;background:var(--honey-soft);color:var(--honey-deep);padding:10px 12px;border-radius:10px;font-size:13px;font-weight:600;line-height:1.4}
  .root-card .solve svg{width:16px;height:16px;flex-shrink:0;margin-top:1px}

  /* ---------- Reminder + Final CTA ---------- */
  .reminder{background:var(--charcoal);color:#fff;padding:64px 0}
  .reminder .wrap{text-align:center}
  .reminder .eye{display:inline-block;background:rgba(255,255,255,.08);color:#fff;font-size:11px;font-weight:800;padding:6px 14px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px}
  .reminder h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:42px;font-weight:700;max-width:14ch;margin:0 auto 16px;letter-spacing:-0.02em}
  .reminder h2 em{font-style:italic;color:var(--honey);font-weight:500}
  .reminder p{font-size:16px;color:#bbb;max-width:560px;margin:0 auto 24px}
  .reminder .rem-row{display:inline-flex;flex-wrap:wrap;gap:8px;margin-top:8px;justify-content:center}
  .reminder .rem-chip{background:rgba(255,255,255,.07);color:#fff;font-size:12px;font-weight:600;padding:7px 14px;border-radius:20px}
  @media(max-width:680px){.reminder h2{font-size:32px}}

  .final{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:80px 0;text-align:center;position:relative}
  .final h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:44px;font-weight:700;max-width:18ch;margin:0 auto 14px}
  .final h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.final h2{font-size:32px}}
  .final p{font-size:16px;color:var(--muted);max-width:540px;margin:0 auto 24px}
