<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Advanced EnergyOne+ · Shiōrra Daily Energy & Focus Support</title>
<meta name="description" content="Shiōrra Advanced EnergyOne+ — Daily energy, focus & vitality support. Taurine, Ginseng Extract, B-Complex vitamins, essential minerals and amino acids. Caffeine-free, multi-nutrient formula. A trademark of K.C. Laboratories." />
<link rel="shortcut icon" type="image/png" href="/img/logo/logo-green.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    /* EnergyOne+ product accent — warm orange-amber (vitality) */
    --honey:#B73A92;
    --honey-2:#9B2F7B;
    --honey-deep:#7A2461;
    --honey-soft:#F4DCEC;
    --charcoal:#282828;
    --charcoal-2:#3A3A3A;
    --ink:#282828;
    --ink-soft:#3A3A3A;
    --white:#FFFFFF;
    --surface:#F7F7F8;
    --surface-2:#FBFBFC;
    --line:#E5E5E7;
    --line-soft:#F0F0F2;
    --muted:#6B6B6B;
    --muted-2:#8A8A8A;
    --green:#1E9E5C;
    --shadow-sm:0 2px 6px rgba(40,40,40,.06);
    --shadow-md:0 8px 24px rgba(40,40,40,.08);
  }
  html{scroll-behavior:smooth;overflow-x:clip}
  body{
    font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
    color:var(--ink);
    background:#fff;
    line-height:1.55;
    font-size:15px;
    overflow-x:clip;
    padding-bottom:88px;
  }
  @media(max-width:720px){body{padding-bottom:84px}}
  img{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  button{font:inherit;cursor:pointer;border:0;background:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}

  /* ---------- Marquee ---------- */
  .marquee{background:var(--charcoal);color:#fff;padding:10px 0;overflow:hidden;border-bottom:1px solid var(--line)}
  .marquee-track{display:flex;gap:48px;width:max-content;animation:marquee 36s linear infinite;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
  .marquee-item{display:inline-flex;align-items:center;gap:8px}
  .marquee-item svg{width:14px;height:14px;color:var(--honey)}
  .marquee-item .accent{color:var(--honey)}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* ---------- Header is from css/style.css (.site-header / .nav__menu) ---------- */

  /* ---------- Trust microbar ---------- */
  .microbar{background:var(--surface);border-bottom:1px solid var(--line);padding:8px 0;font-size:12px;color:var(--ink-soft);font-weight:500}
  .microbar-inner{display:flex;justify-content:center;gap:32px;flex-wrap:wrap}
  .microbar-item{display:inline-flex;align-items:center;gap:6px}
  .microbar-item svg{width:14px;height:14px;color:var(--honey)}

  /* ---------- Hero ---------- */
  .product-hero{
    background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);
    padding:48px 0 64px;
    position:relative;
    overflow:hidden;
  }
  .product-hero::before{
    content:'';position:absolute;top:-100px;right:-100px;
    width:420px;height:420px;border-radius:50%;
    background:radial-gradient(circle,rgba(234,88,12,.18) 0%,transparent 70%);
    pointer-events:none;
  }
  .product-hero-grid{
    display:grid;grid-template-columns:1fr 1.05fr;gap:48px;align-items:start;
    position:relative;
  }
  @media(max-width:880px){.product-hero-grid{grid-template-columns:1fr;gap:28px}}

  .gallery{position:sticky;top:88px}
  @media(max-width:880px){.gallery{position:static}}
  .gallery-main{aspect-ratio:4/5;width:100%;background:#fff;border-radius:22px;border:1px solid var(--line);
    display:grid;place-items:center;overflow:hidden;position:relative;
  }
  .gallery-main img{width:100%;height:100%;object-fit:cover;object-position:center}
  .gallery-thumbs{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:10px}
  .gallery-thumb{aspect-ratio:4/5;background:#fff;border:1.5px solid var(--line);border-radius:12px;overflow:hidden;cursor:pointer;padding:0;transition:border-color .2s,transform .2s}
  .gallery-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s ease}
  .gallery-thumb:hover{border-color:var(--honey);transform:translateY(-1px)}
  .gallery-thumb.is-active{border-color:var(--honey);box-shadow:0 0 0 3px var(--honey-soft) inset}
  .gallery-placeholder{
    width:90%;height:90%;display:grid;place-items:center;flex-direction:column;
    background:repeating-linear-gradient(45deg,#fff7e5 0 16px,#fde4b8 16px 32px);
    border-radius:16px;color:var(--honey-deep);
    font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;letter-spacing:.08em;text-transform:uppercase;font-size:18px;text-align:center;padding:24px;
  }
  .gallery-placeholder span{display:block;font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.04em;text-transform:none;margin-top:8px;font-style:italic}
  .float-badge{
    position:absolute;background:#fff;
    border-radius:16px;padding:10px 16px;font-size:12.5px;font-weight:700;
    box-shadow:0 8px 24px rgba(40,40,40,.10);
    display:inline-flex;align-items:center;gap:10px;
    z-index:3;
  }
  .float-1{top:20px;left:20px}
  .float-2{bottom:20px;right:20px}
  .float-1-icon{
    color:var(--honey);display:inline-grid;place-items:center;font-weight:800;font-size:18px;
  }
  .pulse-dot{width:8px;height:8px;border-radius:50%;background:var(--honey);animation:pulse 1.6s infinite}
  @keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(234,88,12,.7)}50%{box-shadow:0 0 0 6px rgba(234,88,12,0)}}

  /* Product info — "quiet pharmacy editorial" */
  .info{padding-top:8px}
  .pi-kicker{display:block;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--honey-deep);margin-bottom:10px}
  .pi-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:52px;font-weight:700;line-height:1.02;letter-spacing:-0.03em;color:var(--ink);margin-bottom:14px;text-wrap:balance}
  .pi-title em{font-style:normal;color:var(--honey);font-weight:700}
  @media(max-width:680px){.pi-title{font-size:38px}}
  .pi-sub{font-size:16px;color:var(--ink-soft);font-style:normal;font-weight:400;line-height:1.6;margin-bottom:20px;max-width:520px;text-align:left;hyphens:none;word-break:normal;overflow-wrap:normal}
  .pi-proof{display:flex;align-items:baseline;gap:7px;margin-bottom:10px;font-size:13px;line-height:1}
  .pi-proof__star{color:var(--honey);font-size:13px}
  .pi-proof__score{font-weight:600;color:var(--ink)}
  .pi-proof__count{font-weight:400;color:var(--muted);text-decoration:underline;text-underline-offset:3px}
  .pi-proof__count:hover{color:var(--ink)}
  .pi-claims{font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#8A8A8A;margin-bottom:28px;line-height:1.8}
  .pi-commerce{display:flex;align-items:center;justify-content:space-between;gap:16px}
  .pi-price-line{display:flex;flex-direction:column;gap:3px}
  .pi-price-now{font-family:'Helvetica Neue',Arial,sans-serif;font-size:22px;font-weight:700;letter-spacing:-0.01em;color:var(--ink);line-height:1}
  .pi-price-meta{font-size:13px;color:#8A8A8A;font-weight:400}
  .pi-price-meta s{text-decoration:line-through}
  .pi-qty{display:inline-flex;align-items:center;border:1px solid var(--line);border-radius:12px;background:#fff;overflow:hidden}
  .pi-qty button{width:38px;height:46px;font-size:18px;color:var(--ink);font-weight:700}
  .pi-qty input{width:44px;height:46px;border:0;text-align:center;font-size:15px;font-weight:700;font-family:inherit;background:transparent}
  .pi-qty input::-webkit-inner-spin-button{display:none}
  .pi-buy-row{display:flex;gap:10px;margin:0}
  .pi-add{flex:1;height:50px;display:inline-flex;align-items:center;justify-content:center;background:var(--charcoal);color:#fff;font-weight:700;font-size:14px;letter-spacing:.04em;border-radius:12px;text-transform:uppercase;transition:background .2s,transform .2s;border:0;cursor:pointer}
  .pi-add:hover{background:var(--charcoal-2);transform:translateY(-1px)}
  .pi-add-secondary{height:50px;display:inline-flex;align-items:center;justify-content:center;background:transparent;color:var(--ink);font-weight:700;font-size:14px;letter-spacing:.04em;border:1px solid var(--ink);border-radius:12px;cursor:pointer;text-transform:uppercase;transition:background .2s,color .2s}
  .pi-add-secondary:hover{background:var(--ink);color:#fff}
  .pi-footnote{margin-top:20px;padding-top:16px;border-top:1px solid var(--line-soft,#EFEFEF);font-size:12px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:#8A8A8A;line-height:1.7}
  /* Benefit bullets — soft circular check + clean type. List, not grid, so long
     copy can breathe without truncating. */
  .pi-points{margin-top:18px;display:flex;flex-direction:column;gap:10px;padding:0}
  .pi-points li{display:flex;align-items:center;gap:12px;font-size:14.5px;list-style:none;color:var(--ink);font-weight:500;line-height:1.35}
  .pi-points__check{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:var(--honey-soft);color:var(--honey-deep);flex-shrink:0}
  .pi-points__check svg{width:12px;height:12px}

  /* ---------- Generic section ---------- */
  section.s{padding:72px 0;font-size:17px;position:relative;overflow:hidden}
  @media(max-width:680px){section.s{padding:56px 0}}
  section.s > .wrap{position:relative;z-index:1}
  .s-eyebrow{display:inline-flex;align-items:center;background:var(--honey-soft);color:var(--honey-deep);font-size:12px;font-weight:800;padding:8px 16px;border-radius:22px;letter-spacing:.10em;text-transform:uppercase;margin-bottom:16px;position:relative}
  .s-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:48px;font-weight:700;line-height:1.05;letter-spacing:-0.025em;margin-bottom:16px;max-width:760px;color:var(--charcoal);position:relative;text-wrap:balance}
  .s-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.s-title{font-size:36px}}
  .s-sub{font-size:17px;color:var(--ink-soft);max-width:640px;line-height:1.6}
  .s-head{margin-bottom:40px;position:relative}
  .s-head.center{text-align:center}
  .s-head.center .s-title,.s-head.center .s-sub{margin-left:auto;margin-right:auto}

  /* ---------- Shared premium icon-chip system ---------- */
  .chip-xl{
    width:68px;height:68px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);
    display:grid;place-items:center;
    position:relative;
    transition:transform .35s cubic-bezier(.2,.8,.2,1);
  }
  .chip-xl svg{width:32px;height:32px;stroke-width:2.2;position:relative;z-index:1}
  .chip-md{
    width:52px;height:52px;border-radius:14px;
    background:#F7F7F8;
    color:var(--ink);
    display:grid;place-items:center;position:relative;
    transition:transform .3s cubic-bezier(.2,.8,.2,1);
  }
  .chip-md svg{width:24px;height:24px;stroke-width:2.2}
  @media(max-width:680px){
    .chip-xl{width:60px;height:60px;border-radius:16px}
    .chip-xl svg{width:28px;height:28px}
  }

  /* ---------- Why tired (problem) ---------- */
  .symptoms-bg{background:#fff}
  .symptoms-figure,.actives-figure,.bvitamins-figure{margin:0;border-radius:18px;overflow:hidden;background:#fff}
  .symptoms-figure picture,.actives-figure picture{display:block}
  .symptoms-figure img,.actives-figure img,.bvitamins-figure img{display:block;width:100%;height:auto}
  .symptoms-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media(max-width:880px){.symptoms-grid{grid-template-columns:repeat(2,1fr)}}
  .symptom-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;transition:transform .3s cubic-bezier(.2,.8,.2,1),box-shadow .3s,border-color .3s;position:relative;overflow:hidden}
  .symptom-card:hover{transform:translateY(-5px);box-shadow:0 22px 44px rgba(40,40,40,.10);border-color:var(--line)}
  .symptom-card:hover .ic{transform:scale(1.06) rotate(-2deg)}
  .symptom-card .ic{
    width:68px;height:68px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;margin-bottom:18px;
    position:relative;
    transition:transform .35s cubic-bezier(.2,.8,.2,1);
  }
  .symptom-card .ic svg{width:32px;height:32px;stroke-width:2.2}
  @media(max-width:680px){.symptom-card .ic{width:60px;height:60px}.symptom-card .ic svg{width:28px;height:28px}}
  .symptom-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;font-weight:700;margin-bottom:6px;color:var(--ink)}
  .symptom-card p{font-size:14px;color:var(--muted);line-height:1.55}

  /* ---------- Power team (Taurine, Ginseng) ---------- */
  .power-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .power-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;align-items:stretch}
  @media(max-width:880px){.power-grid{grid-template-columns:1fr}}
  .power-card{background:#fff;border:1px solid var(--line);border-radius:24px;padding:34px;position:relative;overflow:hidden;transition:transform .35s cubic-bezier(.2,.8,.2,1),box-shadow .35s,border-color .35s}
  .power-card:hover{transform:translateY(-4px);box-shadow:0 24px 50px rgba(40,40,40,.10);border-color:var(--line)}
  .power-card:hover .pc-icon{transform:scale(1.06) rotate(-3deg)}
  .pc-icon{
    width:72px;height:72px;border-radius:20px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;margin-bottom:18px;
    position:relative;
    transition:transform .4s cubic-bezier(.2,.8,.2,1);
  }
  .pc-icon svg{width:34px;height:34px;stroke-width:2.2}
  @media(max-width:680px){.pc-icon{width:64px;height:64px}.pc-icon svg{width:30px;height:30px}}
  .power-card .pc-eye{display:inline-block;background:var(--honey-soft);color:var(--honey-deep);font-size:11px;font-weight:800;padding:6px 12px;border-radius:14px;letter-spacing:.10em;text-transform:uppercase;margin-bottom:12px}
  .power-card h3{font-family:'Helvetica Neue',Arial,sans-serif;font-size:26px;margin-bottom:8px;letter-spacing:-0.01em}
  .power-card .pc-lede{font-size:14.5px;color:var(--muted);margin-bottom:18px;line-height:1.55}
  .power-card ul{list-style:none;display:grid;gap:10px}
  .power-card li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--ink-soft)}
  .power-card li svg{width:18px;height:18px;color:var(--honey);flex-shrink:0}
  .power-card .pc-tag{margin-top:18px;font-size:12px;color:var(--honey-deep);font-style:italic;padding-top:14px;border-top:1px dashed var(--line)}

  /* ---------- B Vitamins ---------- */
  .bvit-bg{background:#fff}
  .bvit-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:12px;margin-top:18px}
  @media(max-width:980px){.bvit-grid{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:520px){.bvit-grid{grid-template-columns:repeat(2,1fr)}}
  .bvit-pill{
    background:var(--honey-soft);
    border:1px solid var(--line-soft);
    border-radius:16px;padding:20px 12px;text-align:center;position:relative;
    transition:transform .3s cubic-bezier(.2,.8,.2,1),box-shadow .3s;
    overflow:hidden;
  }
  .bvit-pill:hover{transform:translateY(-3px);box-shadow:0 10px 22px rgba(40,40,40,.08)}
  .bvit-pill .name{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:18px;color:var(--honey-deep);letter-spacing:.02em;position:relative}
  .bvit-pill .sub{font-size:11px;color:var(--muted);margin-top:4px;font-weight:600;letter-spacing:.03em;position:relative}
  .bvit-help{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:36px;align-items:stretch}
  @media(max-width:880px){.bvit-help{grid-template-columns:repeat(2,1fr)}}
  .bvit-help-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:24px;transition:transform .3s,box-shadow .3s,border-color .3s;position:relative;overflow:hidden}
  .bvit-help-card:hover{transform:translateY(-3px);box-shadow:0 18px 36px rgba(40,40,40,.08);border-color:var(--line)}
  .bvit-help-card:hover .bv-icon,.bvit-help-card:hover .ic{transform:scale(1.06) rotate(-3deg)}
  .bv-icon,.bvit-help-card .ic{
    width:60px;height:60px;border-radius:16px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;margin-bottom:14px;
    transition:transform .35s cubic-bezier(.2,.8,.2,1);
  }
  .bv-icon svg,.bvit-help-card .ic svg{width:28px;height:28px;stroke-width:2.2}
  .bvit-help-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:15px;margin-bottom:6px;color:var(--ink);font-weight:700}
  .bvit-help-card p{font-size:13px;color:var(--muted);line-height:1.5}

  /* ---------- Minerals + Amino Acids ---------- */
  .min-bg{background:#fff}
  .minerals-figure{margin:0;border-radius:18px;overflow:hidden;background:#fff}
  .minerals-figure img{display:block;width:100%;height:auto}
  .min-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media(max-width:880px){.min-grid{grid-template-columns:repeat(2,1fr)}}
  .min-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;transition:transform .3s cubic-bezier(.2,.8,.2,1),box-shadow .3s,border-color .3s;position:relative;overflow:hidden}
  .min-card:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(40,40,40,.10);border-color:var(--line)}
  .min-card:hover .mn-icon,.min-card:hover .ic{transform:scale(1.06) rotate(-3deg)}
  .mn-icon,.min-card .ic{
    width:62px;height:62px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;
    font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:20px;
    letter-spacing:.01em;margin-bottom:14px;
    transition:transform .35s cubic-bezier(.2,.8,.2,1);
  }
  .min-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:16px;margin-bottom:6px;color:var(--ink);font-weight:700}
  .min-card p{font-size:13.5px;color:var(--muted);line-height:1.55}

  .amino-bg{background:#fff}
  .amino-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:24px}
  @media(max-width:880px){.amino-grid{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:520px){.amino-grid{grid-template-columns:repeat(2,1fr)}}
  .amino-pill{
    background:var(--honey-soft);
    border:1px solid var(--line-soft);color:var(--honey-deep);
    font-family:'Helvetica Neue',Arial,sans-serif;font-weight:700;font-size:13px;
    padding:12px 8px;border-radius:12px;text-align:center;letter-spacing:.02em;
    transition:transform .25s,box-shadow .25s;
    position:relative;
  }
  .amino-pill:hover{transform:translateY(-2px);box-shadow:0 10px 20px rgba(40,40,40,.08)}
  .amino-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:22px}
  @media(max-width:680px){.amino-list{grid-template-columns:1fr}}
  .amino-list li{list-style:none;display:flex;gap:12px;font-size:14.5px;color:var(--ink-soft);align-items:center;padding:10px 14px;background:#fff;border-radius:12px;border:1px solid var(--line-soft)}
  .amino-list li svg{width:20px;height:20px;color:var(--honey);flex-shrink:0;stroke-width:2.4}

  /* ---------- Timeline (what you'll notice) ---------- */
  .timeline-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .timeline-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:16px;align-items:stretch}
  @media(max-width:880px){.timeline-grid{grid-template-columns:1fr}}
  .tl-card{background:#fff;border:1px solid var(--line);border-radius:22px;padding:30px;position:relative;transition:transform .3s cubic-bezier(.2,.8,.2,1),box-shadow .3s,border-color .3s;overflow:hidden}
  .tl-card:hover{transform:translateY(-5px);box-shadow:0 22px 44px rgba(40,40,40,.10);border-color:var(--line)}
  .tl-card:hover .tl-icon{transform:scale(1.06) rotate(-3deg)}
  .tl-icon{
    width:64px;height:64px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;
    transition:transform .35s cubic-bezier(.2,.8,.2,1);
    position:relative;z-index:1;
  }
  .tl-icon svg{width:30px;height:30px;stroke-width:2.2}
  .tl-step{position:absolute;top:20px;right:20px;background:var(--honey-soft);color:var(--honey-deep);font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:11px;padding:6px 12px;border-radius:14px;letter-spacing:.08em;text-transform:uppercase;z-index:2}
  .tl-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:20px;color:var(--ink);margin:20px 0 14px;max-width:80%;font-weight:700;letter-spacing:-0.01em;position:relative;z-index:1}
  .tl-card ul{list-style:none;display:grid;gap:9px;position:relative;z-index:1}
  .tl-card li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--ink-soft)}
  .tl-card li svg{width:18px;height:18px;color:var(--honey);flex-shrink:0;stroke-width:2.4}
  .tl-stat{margin-top:36px;background:#fff;color:var(--ink);border:1px solid var(--line);border-radius:18px;padding:24px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;position:relative;overflow:hidden;box-shadow:0 8px 24px rgba(40,40,40,.08)}
  .tl-stat strong{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:22px;letter-spacing:-0.02em;position:relative;color:var(--honey-deep)}
  .tl-stat .ref{font-size:11px;color:var(--muted);font-style:italic;position:relative}

  /* ---------- Comparison table ---------- */
  .why-bg{background:#fff}
  .compare-table{margin-top:14px;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff}
  .compare-row{display:grid;grid-template-columns:1.2fr 1fr 1fr}
  .compare-row + .compare-row{border-top:1px solid var(--line-soft)}
  .compare-row.head{background:var(--surface);font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--ink)}
  .compare-row.head .cc{padding:14px 18px}
  .compare-row.head .cc:first-child{visibility:hidden}
  .compare-row.head .cc:nth-child(2){color:var(--honey-deep);background:var(--honey-soft)}
  .cc{padding:14px 18px;font-size:14px;line-height:1.45}
  .cc.lbl{font-weight:700;color:var(--ink)}
  .cc.them{color:var(--muted)}
  .cc.us{background:var(--honey-soft);color:var(--ink);font-weight:600}
  @media(max-width:680px){
    .compare-row{grid-template-columns:1fr 1fr}
    .compare-row.head .cc:first-child{display:none}
    .cc.lbl{grid-column:1/-1;background:var(--line-soft);font-size:13px}
  }

  /* ---------- Root cause table ---------- */
  .root-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .root-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:14px;align-items:stretch}
  @media(max-width:980px){.root-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:580px){.root-grid{grid-template-columns:1fr}}
  .root-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;transition:transform .3s cubic-bezier(.2,.8,.2,1),box-shadow .3s,border-color .3s;position:relative;overflow:hidden}
  .root-card:hover{transform:translateY(-4px);box-shadow:0 20px 44px rgba(40,40,40,.10);border-color:var(--line)}
  .root-card .rc-eye{display:inline-flex;align-items:center;gap:6px;font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:11px;color:var(--honey-deep);letter-spacing:.10em;text-transform:uppercase;margin-bottom:12px;padding:5px 10px;background:var(--honey-soft);border-radius:12px}
  .root-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;color:var(--ink);margin-bottom:8px;font-weight:700;line-height:1.3}
  .root-card p{font-size:13.5px;color:var(--muted);line-height:1.55;margin-bottom:16px}
  .root-card .solve{display:flex;gap:10px;align-items:flex-start;background:var(--honey-soft);color:var(--honey-deep);padding:12px 14px;border-radius:12px;font-size:13px;font-weight:600;line-height:1.45}
  .root-card .solve svg{width:18px;height:18px;flex-shrink:0;margin-top:1px;stroke-width:2.4}

  /* ---------- Reminder + Final CTA ---------- */
  .reminder{background:var(--charcoal);color:#fff;padding:64px 0}
  .reminder .wrap{text-align:center}
  .reminder .eye{display:inline-block;background:rgba(255,255,255,.08);color:#fff;font-size:11px;font-weight:800;padding:6px 14px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px}
  .reminder h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:42px;font-weight:700;line-height:1.15;color:#fff;max-width:24ch;margin:0 auto 16px;letter-spacing:-0.02em}
  .reminder h2 em{font-style:italic;color:var(--honey);font-weight:500}
  .reminder p{font-size:16px;color:#bbb;max-width:560px;margin:0 auto 24px}
  .reminder .rem-row{display:inline-flex;flex-wrap:wrap;gap:8px;margin-top:8px;justify-content:center}
  .reminder .rem-chip{background:rgba(255,255,255,.07);color:#fff;font-size:12px;font-weight:600;padding:7px 14px;border-radius:20px}
  @media(max-width:680px){.reminder h2{font-size:32px}}

  .final{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:80px 0;text-align:center;position:relative}
  .final h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:44px;font-weight:700;line-height:1.15;max-width:22ch;margin:0 auto 14px}
  .final h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.final h2{font-size:32px}}
  .final p{font-size:16px;color:var(--muted);max-width:540px;margin:0 auto 24px}
  .final-cta{display:inline-flex;align-items:center;gap:10px;background:var(--charcoal);color:#fff;padding:16px 32px;border-radius:14px;font-weight:700;font-size:14px;letter-spacing:.04em;text-transform:uppercase;transition:transform .2s,background .2s}
  .final-cta:hover{transform:translateY(-2px);background:var(--charcoal-2)}

  /* Sticky buy bar — Myntra/Nykaa dual-button standard */
  .sticky-cta{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--line);box-shadow:0 -8px 24px rgba(40,40,40,.08);padding:10px 12px calc(10px + env(safe-area-inset-bottom));z-index:40}
  .sticky-bar{display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:560px;margin:0 auto}
  .sticky-bar__btn{height:48px;display:inline-flex;align-items:center;justify-content:center;border-radius:10px;font-weight:700;font-size:13.5px;letter-spacing:.04em;text-transform:uppercase;font-family:inherit;cursor:pointer;white-space:nowrap;transition:background .2s,color .2s}
  .sticky-bar__cart{background:#fff;color:var(--ink);border:1.5px solid var(--ink)}
  .sticky-bar__cart:active{background:var(--ink);color:#fff}
  .sticky-bar__buy{background:var(--charcoal);color:#fff;border:1.5px solid var(--charcoal)}
  .sticky-bar__buy:active{background:#000}

  /* ============================================================
     MOBILE UX PASS — surgical augmentations only.
     Targets <=720px viewports (Indian mobile 360–414px primary).
     ============================================================ */
  @media (max-width: 720px){
    .wrap{padding:0 clamp(16px,4.5vw,24px)}

    .marquee{padding:8px 0}
    .marquee-track{gap:32px;font-size:11.5px}

    /* Section illustrations go edge-to-edge (zoomed) on phones */
    .symptoms-figure,.actives-figure,.bvitamins-figure,.minerals-figure{border-radius:0;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw)}

    .product-hero{padding:clamp(28px,7vw,44px) 0 clamp(36px,9vw,56px)}
    .product-hero::before{width:280px;height:280px;top:-80px;right:-80px}
    .product-hero-grid{gap:24px}
    .pi-title{font-size:clamp(28px,7.5vw,38px);line-height:1.08}
    .pi-sub{font-size:15px;line-height:1.55;margin-bottom:18px;text-align:left;hyphens:none;word-break:normal;overflow-wrap:normal;color:var(--ink-soft)}
    .pi-kicker{font-size:10px;letter-spacing:.18em;margin-bottom:8px}
    .pi-claims{font-size:11px;letter-spacing:.12em;margin-bottom:24px}
    .pi-price-now{font-size:20px}
    .pi-price-meta{font-size:12.5px}
    .pi-footnote{margin-top:18px;padding-top:14px;font-size:11px}
    .pi-commerce{gap:12px}
    .pi-points{margin-top:16px;gap:11px}
    .pi-points li{font-size:14.5px;min-height:24px}
    .pi-points__check{width:22px;height:22px}

    .pi-buy-form .pi-buy-row{display:none !important}

    .gallery-thumbs{gap:6px;margin-top:8px}
    .gallery-thumb{min-height:44px;border-radius:10px;border-width:1.25px}

    .pi-qty{border-radius:11px}
    .pi-qty button{width:44px;height:48px}
    .pi-qty input{width:42px;height:48px;font-size:15px}

    section.s{padding:clamp(40px,10vw,72px) 0}
    .s-title{font-size:clamp(26px,7vw,38px);line-height:1.1}
    .s-sub{font-size:15px;line-height:1.55}
    .s-head{margin-bottom:28px}

    .power-card{padding:24px}
    .power-card h3{font-size:22px}
    .symptom-card{padding:22px 20px}
    .symptom-card h4{font-size:16px}
    .min-card{padding:22px 20px}
    .root-card{padding:22px 20px}
    .tl-card{padding:24px 22px}
    .tl-card h4{font-size:20px;max-width:100%;margin:18px 0 12px}
    .tl-step{top:14px;right:14px;font-size:10.5px}
    .tl-stat{padding:20px 22px;flex-direction:column;align-items:flex-start;text-align:left}
    .tl-stat strong{font-size:20px;line-height:1.25}

    .cc{padding:12px 14px;font-size:13.5px}

    .bvit-help-card{padding:20px 18px}
    .bvit-help-card .bv-icon,.bvit-help-card .ic{width:56px;height:56px;border-radius:14px}
    .bvit-help-card .bv-icon svg,.bvit-help-card .ic svg{width:26px;height:26px}

    .amino-pill{font-size:12.5px;padding:11px 8px;min-height:44px;display:flex;align-items:center;justify-content:center}
    .amino-list li{padding:12px 14px;font-size:14px}

    .reminder{padding:48px 0}
    .reminder p{font-size:15px}
    .final{padding:56px 0}
    .final p{font-size:15px}
    .final-cta{padding:14px 24px;font-size:13.5px;min-height:50px}

    .site-header .nav__menu a,.site-header .nav__toggle{min-height:44px}
  }

  @media (max-width: 380px){
    .pi-title{font-size:30px}
    .pi-price-now{font-size:19px}
    .gallery-thumb{border-radius:8px}
  }

  @media (max-width: 580px){
    .symptoms-grid{grid-template-columns:1fr;gap:12px}
    .bvit-help{grid-template-columns:1fr;gap:12px}
    .min-grid{grid-template-columns:repeat(2,1fr);gap:12px}
  }
</style>
</head>
