<section class="page-hero">
    <div class="container">
        <span class="eyebrow">Account</span>
        <h1><%= address ? 'Edit address' : 'Add address' %></h1>
    </div>
</section>
<section class="section">
    <div class="container">
        <div class="account">
            <%- include('../partials/account-nav', { active: 'addresses' }) %>

            <div class="account__main">
                <form
                    action="<%= address ? '/account/addresses/' + address.id : '/account/addresses' %>"
                    method="post"
                    class="form-grid"
                >
                    <label>Full name<input name="fullName" required value="<%= values.fullName || '' %>"></label>
                    <label>Phone<input name="phone" required value="<%= values.phone || '' %>"></label>
                    <label class="form-grid__full">Address line 1<input name="line1" required value="<%= values.line1 || '' %>"></label>
                    <label class="form-grid__full">Address line 2 (optional)<input name="line2" value="<%= values.line2 || '' %>"></label>
                    <label>City<input name="city" required value="<%= values.city || '' %>"></label>
                    <label>State<input name="state" required value="<%= values.state || '' %>"></label>
                    <label>Postcode<input name="postcode" required value="<%= values.postcode || '' %>"></label>
                    <label>Country<input name="country" required value="<%= values.country || 'India' %>"></label>
                    <div class="form-grid__full" style="display:flex;gap:10px;flex-wrap:wrap;">
                        <button class="btn"><%= address ? 'Save changes' : 'Add address' %></button>
                        <a href="/account/addresses" class="btn btn--ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
