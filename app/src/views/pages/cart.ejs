</section>

<script>
  (function () {
    // Auto-submit qty stepper +/- buttons (already in markup as submit buttons with value),
    // but also auto-submit on input change after typing.
    document.querySelectorAll('[data-qty-form]').forEach(function (form) {
      var input = form.querySelector('[data-qty-input]');
      if (!input) return;
      var t;
      input.addEventListener('change', function () {
        clearTimeout(t);
        t = setTimeout(function () { form.submit(); }, 200);
      });
    });

    // Mobile summary toggle
    document.querySelectorAll('[data-summary-toggle]').forEach(function (btn) {
      var id = btn.getAttribute('aria-controls');
      var body = id ? document.getElementById(id) : null;
      if (!body) return;
      // ensure visible on desktop
      var apply = function () {
        if (window.matchMedia('(max-width: 960px)').matches) {
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          body.hidden = !expanded;
        } else {
          body.hidden = false;
        }
      };
      btn.addEventListener('click', function () {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        apply();
      });
      window.addEventListener('resize', apply);
      apply();
    });
  })();
</script>
