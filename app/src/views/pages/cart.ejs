                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2 3 4v4c0 3.4 2.2 5.7 5 6 2.8-.3 5-2.6 5-6V4l-5-2Z"/><path d="m6 8 1.5 1.5L10 7"/></svg>
