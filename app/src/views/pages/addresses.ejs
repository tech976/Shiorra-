<style>
    /* ============================================================
       Shiorra — Account: Addresses
       Inherits the shared account aesthetic.
       ============================================================ */
    :root {
        --acct-ink: #282828;
        --acct-ink-2: #4A4A4A;
        --acct-muted: #6B6B6B;
        --acct-muted-2: #8A8A8A;
        --acct-line: #ECECEC;
        --acct-line-2: #F2F2F2;
        --acct-bg: #FFFFFF;
        --acct-bg-soft: #FAFAFA;
        --acct-accent: #23867F;
        --acct-accent-2: #1B6E68;
        --acct-accent-soft: rgba(35, 134, 127, 0.08);
        --acct-shadow-sm: 0 1px 2px rgba(40, 40, 40, 0.04);
        --acct-shadow: 0 1px 2px rgba(40, 40, 40, 0.04), 0 12px 32px rgba(40, 40, 40, 0.06);
        --acct-radius: 22px;
        --acct-radius-sm: 14px;
        --acct-radius-xs: 12px;
    }

    .acct-hero {
        background: var(--acct-bg-soft);
        border-bottom: 1px solid var(--acct-line);
        padding: clamp(56px, 9vw, 88px) 0 clamp(40px, 6vw, 64px);
    }
    .acct-hero .container { max-width: 1180px; }
    .acct-hero__eyebrow {
        display: inline-flex; align-items: center; gap: 8px;
        font-size: 11px; font-weight: 600;
        letter-spacing: 0.16em; text-transform: uppercase;
        color: var(--acct-muted); margin-bottom: 18px;
    }
    .acct-hero__eyebrow::before { content: ""; width: 22px; height: 1px; background: var(--acct-ink); }
    .acct-hero h1 {
        font-family: var(--ff-body, "Inter", sans-serif);
        font-size: clamp(32px, 4.4vw, 44px);
        font-weight: 600; letter-spacing: -0.02em; line-height: 1.08;
        color: var(--acct-ink); margin: 0 0 14px;
    }
    .acct-hero p { font-size: 16px; line-height: 1.6; color: var(--acct-muted); max-width: 60ch; margin: 0; }

    .acct-shell { padding: clamp(36px, 5vw, 64px) 0 clamp(72px, 10vw, 120px); background: var(--acct-bg); }
    .acct-shell .container { max-width: 1180px; }
    .acct-grid {
        display: grid;
        grid-template-columns: 268px minmax(0, 1fr);
        gap: clamp(24px, 3vw, 40px);
        align-items: start;
    }
    @media (max-width: 920px) { .acct-grid { grid-template-columns: 1fr; gap: 20px; } }

    /* Sidebar nav */
    .acct-nav { position: sticky; top: 96px; }
    @media (max-width: 920px) { .acct-nav { position: static; } }
    .acct-nav__card {
        background: var(--acct-bg);
        border: 1px solid var(--acct-line);
        border-radius: 16px;
        padding: 20px 16px;
        box-shadow: var(--acct-shadow-sm);
    }
    .acct-nav__head { padding: 6px 10px 18px; border-bottom: 1px solid var(--acct-line-2); margin-bottom: 12px; }
    .acct-nav__eyebrow {
        display: block; font-size: 11px; font-weight: 600;
        letter-spacing: 0.16em; text-transform: uppercase;
        color: var(--acct-muted-2); margin-bottom: 8px;
    }
    .acct-nav__name { margin: 0; font-size: 15px; font-weight: 600; color: var(--acct-ink); line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .acct-nav__email { margin: 3px 0 0; font-size: 12.5px; color: var(--acct-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .acct-nav__list { display: flex; flex-direction: column; gap: 2px; padding: 4px 0; }
    .acct-nav__item {
        position: relative; display: flex; align-items: center; gap: 12px;
        padding: 11px 14px; border-radius: var(--acct-radius-xs);
        font-size: 14.5px; font-weight: 500; color: var(--acct-ink-2);
        text-decoration: none; transition: background 160ms ease, color 160ms ease;
    }
    .acct-nav__item:hover { background: var(--acct-bg-soft); color: var(--acct-ink); }
    .acct-nav__item.is-active { background: var(--acct-bg-soft); color: var(--acct-ink); font-weight: 600; }
    .acct-nav__item.is-active::before {
        content: ""; position: absolute; left: 4px; top: 10px; bottom: 10px;
        width: 3px; border-radius: 3px; background: var(--acct-accent);
    }
    .acct-nav__item--alt { color: var(--acct-accent); }
    .acct-nav__icon { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; color: currentColor; flex-shrink: 0; }
    .acct-nav__logout { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--acct-line-2); }
    .acct-nav__signout {
        width: 100%; display: flex; align-items: center; gap: 12px;
        padding: 11px 14px; border: 0; background: transparent;
        font-family: inherit; font-size: 14.5px; font-weight: 500;
        color: var(--acct-muted); text-align: left; cursor: pointer;
        border-radius: var(--acct-radius-xs);
        transition: background 160ms ease, color 160ms ease;
    }
    .acct-nav__signout:hover { background: var(--acct-bg-soft); color: var(--acct-ink); }

    /* Main */
    .acct-main { min-width: 0; display: flex; flex-direction: column; gap: clamp(20px, 2.4vw, 28px); }
    .acct-panel {
        background: var(--acct-bg); border: 1px solid var(--acct-line);
        border-radius: 16px;
        padding: clamp(24px, 2.6vw, 32px);
        box-shadow: var(--acct-shadow-sm);
    }
    .acct-panel__head {
        display: flex; justify-content: space-between; align-items: baseline;
        gap: 16px; margin-bottom: 22px; flex-wrap: wrap;
    }
    .acct-panel__title { margin: 0; font-size: 19px; font-weight: 600; letter-spacing: -0.01em; color: var(--acct-ink); }
    .acct-panel__sub { margin: 6px 0 0; font-size: 14px; color: var(--acct-muted); line-height: 1.55; }

    /* Buttons */
    .acct-btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        padding: 13px 26px;
        font-family: inherit; font-size: 14.5px; font-weight: 600; letter-spacing: 0.005em;
        border: 1px solid var(--acct-ink); background: var(--acct-ink); color: #fff;
        border-radius: 999px; cursor: pointer; text-decoration: none;
        transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease, border-color 180ms ease, color 180ms ease;
    }
    .acct-btn:hover { transform: translateY(-1px); box-shadow: 0 10px 22px rgba(40,40,40,0.16); background: #000; border-color: #000; color: #fff; }
    .acct-btn--ghost { background: transparent; color: var(--acct-ink); border-color: var(--acct-line); }
    .acct-btn--ghost:hover { background: var(--acct-bg-soft); color: var(--acct-ink); border-color: #D8D8D8; box-shadow: none; }
    .acct-btn--sm { padding: 9px 16px; font-size: 13px; }
    .acct-btn--danger { background: transparent; color: #9A1450; border-color: rgba(194,27,98,0.25); }
    .acct-btn--danger:hover { background: rgba(194,27,98,0.06); color: #9A1450; border-color: rgba(194,27,98,0.45); box-shadow: none; }

    /* Empty state */
    .acct-empty {
        display: flex; flex-direction: column; align-items: center;
        text-align: center; gap: 14px;
        padding: 56px 24px;
        background: var(--acct-bg-soft);
        border: 1px dashed var(--acct-line);
        border-radius: var(--acct-radius-sm);
    }
    .acct-empty__art { width: 80px; height: 80px; color: var(--acct-accent); opacity: 0.85; }
    .acct-empty__title { margin: 4px 0 0; font-size: 17px; font-weight: 600; color: var(--acct-ink); }
    .acct-empty__copy { margin: 0; max-width: 38ch; font-size: 14px; color: var(--acct-muted); line-height: 1.55; }
    .acct-empty .acct-btn { margin-top: 6px; }

    .acct-inline-form { display: inline; margin: 0; padding: 0; }

    /* Address grid */
    .acct-addrgrid {
        display: grid; gap: 18px;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
    .acct-addr {
        position: relative;
        display: flex; flex-direction: column;
        background: var(--acct-bg);
        border: 1px solid var(--acct-line);
        border-radius: 16px;
        padding: 24px;
        box-shadow: var(--acct-shadow-sm);
        transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
    }
    .acct-addr:hover { transform: translateY(-3px); box-shadow: var(--acct-shadow); border-color: #E0E0E0; }
    .acct-addr--default { border-color: rgba(35,134,127,0.32); }
    .acct-addr__top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 14px; }
    .acct-addr__label {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--acct-muted);
    }
    .acct-addr__label svg { color: var(--acct-accent); }
    .acct-addr__default {
        font-size: 10.5px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
        padding: 4px 10px; border-radius: 999px;
        background: var(--acct-accent-soft); color: var(--acct-accent-2);
    }
    .acct-addr__name { margin: 0 0 8px; font-size: 15.5px; font-weight: 600; color: var(--acct-ink); letter-spacing: -0.005em; }
    .acct-addr__body { margin: 0; font-size: 14px; line-height: 1.6; color: var(--acct-ink-2); }
    .acct-addr__body span { display: block; }
    .acct-addr__phone { margin: 12px 0 0; font-size: 13.5px; color: var(--acct-muted); }
    .acct-addr__actions {
        display: flex; gap: 8px; flex-wrap: wrap; align-items: center;
        margin-top: auto; padding-top: 18px;
        border-top: 1px solid var(--acct-line-2);
    }
    .acct-addr__actions > * { margin: 0; }
    .acct-addr__spacer { margin-top: 18px; }

    /* Add new card */
    .acct-addr--new {
        display: flex; align-items: center; justify-content: center;
        text-align: center;
        background: transparent;
        border: 1.5px dashed var(--acct-line);
        color: var(--acct-muted);
        text-decoration: none;
        min-height: 220px;
        box-shadow: none;
    }
    .acct-addr--new:hover {
        border-color: var(--acct-accent);
        color: var(--acct-accent);
        background: var(--acct-accent-soft);
        transform: translateY(-3px); box-shadow: var(--acct-shadow-sm);
    }
    .acct-addr--new__inner { display: flex; flex-direction: column; align-items: center; gap: 10px; }
    .acct-addr--new__plus {
        width: 44px; height: 44px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--acct-bg); border: 1px solid var(--acct-line);
        color: var(--acct-accent);
        transition: border-color 200ms ease, background 200ms ease;
    }
    .acct-addr--new:hover .acct-addr--new__plus { border-color: var(--acct-accent); }
    .acct-addr--new__lbl { font-size: 14.5px; font-weight: 600; letter-spacing: -0.005em; }
    .acct-addr--new__sub { font-size: 12.5px; color: var(--acct-muted-2); }

    /* ───────── Mobile tightening ───────── */
    @media (max-width: 720px) {
        .acct-hero { padding: 40px 0 28px; }
        .acct-hero__eyebrow { margin-bottom: 12px; }
        .acct-hero h1 { font-size: 28px; margin-bottom: 10px; }
        .acct-hero p { font-size: 14.5px; }

        .acct-shell { padding: 24px 0 56px; }

        .acct-nav__card { padding: 16px 12px; border-radius: 16px; }
        .acct-nav__head { padding: 4px 8px 12px; margin-bottom: 8px; }
        .acct-nav__item, .acct-nav__signout {
            padding: 13px 12px;
            min-height: 44px;
            font-size: 15px;
        }

        .acct-panel { padding: 22px 20px; border-radius: 16px; }
        .acct-panel__head { margin-bottom: 16px; }
        .acct-panel__title { font-size: 17px; }
        .acct-panel__sub { font-size: 13.5px; }

        /* Address grid: tighter gap */
        .acct-addrgrid { gap: 14px; }
        .acct-addr { padding: 22px 20px; border-radius: 16px; }
        .acct-addr__top { margin-bottom: 12px; }
        .acct-addr__actions {
            gap: 8px;
            padding-top: 14px;
            margin-top: 14px;
        }

        /* Buttons: ≥44px tap target everywhere */
        .acct-btn { min-height: 44px; padding: 12px 20px; font-size: 14.5px; }
        .acct-btn--sm { min-height: 40px; padding: 10px 16px; font-size: 13px; }

        /* Each action button takes its share of the row for easy thumb reach */
        .acct-addr__actions .acct-btn,
        .acct-addr__actions .acct-inline-form { flex: 1 1 auto; }
        .acct-addr__actions .acct-inline-form .acct-btn { width: 100%; }

        .acct-addr--new { min-height: 160px; }
    }

    /* Full-width address cards on narrow phones */
    @media (max-width: 480px) {
        .acct-addrgrid { grid-template-columns: 1fr; }
    }
</style>

<section class="acct-hero">
    <div class="container">
        <span class="acct-hero__eyebrow">Account · Addresses</span>
        <h1>Saved addresses</h1>
        <p>Manage where your orders ship to. Save multiple addresses for faster checkout.</p>
    </div>
</section>

<section class="acct-shell">
    <div class="container">
        <div class="acct-grid">
            <%- include('../partials/account-nav', { active: 'addresses' }) %>

            <div class="acct-main">
                <div class="acct-panel">
                    <div class="acct-panel__head">
                        <div>
                            <h2 class="acct-panel__title">Your addresses</h2>
                            <p class="acct-panel__sub"><%= addresses.length %> saved · we'll suggest your default at checkout.</p>
                        </div>
                        <% if (addresses.length) { %>
                            <a href="/account/addresses/new" class="acct-btn acct-btn--sm">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                                Add address
                            </a>
                        <% } %>
                    </div>

                    <% if (!addresses.length) { %>
                        <div class="acct-empty">
                            <svg class="acct-empty__art" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M40 68s-22-18-22-36a22 22 0 0 1 44 0c0 18-22 36-22 36Z"/>
                                <circle cx="40" cy="32" r="7"/>
                            </svg>
                            <h3 class="acct-empty__title">No saved addresses yet</h3>
                            <p class="acct-empty__copy">Add an address to speed up future checkouts. You can save multiple for home, work or gifts.</p>
                            <a href="/account/addresses/new" class="acct-btn">Add your first address</a>
                        </div>
                    <% } else { %>
                        <div class="acct-addrgrid">
                            <% addresses.forEach(function(a) { %>
                                <div class="acct-addr <%= a.isDefault ? 'acct-addr--default' : '' %>">
                                    <div class="acct-addr__top">
                                        <span class="acct-addr__label">
                                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-6.2-7-11a7 7 0 0 1 14 0c0 4.8-7 11-7 11Z"/><circle cx="12" cy="10" r="2.4"/></svg>
                                            Shipping
                                        </span>
                                        <% if (a.isDefault) { %><span class="acct-addr__default">Default</span><% } %>
                                    </div>
                                    <p class="acct-addr__name"><%= a.fullName %></p>
                                    <p class="acct-addr__body">
                                        <span><%= a.line1 %></span>
                                        <% if (a.line2) { %><span><%= a.line2 %></span><% } %>
                                        <span><%= a.city %>, <%= a.state %> <%= a.postcode %></span>
                                        <span><%= a.country %></span>
                                    </p>
                                    <p class="acct-addr__phone"><%= a.phone %></p>
                                    <div class="acct-addr__actions">
                                        <a href="/account/addresses/<%= a.id %>/edit" class="acct-btn acct-btn--ghost acct-btn--sm">Edit</a>
                                        <% if (!a.isDefault) { %>
                                            <form action="/account/addresses/<%= a.id %>/default" method="post" class="acct-inline-form">
                                                <button type="submit" class="acct-btn acct-btn--ghost acct-btn--sm">Make default</button>
                                            </form>
                                        <% } %>
                                        <form action="/account/addresses/<%= a.id %>?_method=DELETE" method="post" class="acct-inline-form" onsubmit="return confirm('Remove this address?');">
                                            <button type="submit" class="acct-btn acct-btn--danger acct-btn--sm">Remove</button>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>

                            <a href="/account/addresses/new" class="acct-addr acct-addr--new">
                                <div class="acct-addr--new__inner">
                                    <span class="acct-addr--new__plus" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                                    </span>
                                    <span class="acct-addr--new__lbl">Add new address</span>
                                    <span class="acct-addr--new__sub">For home, work or a gift</span>
                                </div>
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>
