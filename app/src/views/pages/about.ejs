<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --honey:#3DBDB6;
    --honey-2:#2FA39C;
    --honey-deep:#23867F;
    --honey-soft:#E0F5F3;
    --charcoal:#282828;
    --charcoal-2:#3A3A3A;
    --ink:#282828;
    --ink-soft:#3A3A3A;
    --white:#FFFFFF;
    --surface:#F7F7F8;
    --line:#E5E5E7;
    --line-soft:#F0F0F2;
    --muted:#6B6B6B;
    --green:#1E9E5C;
  }
  html{scroll-behavior:smooth;overflow-x:clip}
  body{font-family:'Inter','Helvetica Neue',Arial,sans-serif;color:var(--ink);background:#fff;line-height:1.55;font-size:15px;overflow-x:clip}
  img{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  button{font:inherit;cursor:pointer;border:0;background:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}

  .marquee{background:var(--charcoal);color:#fff;padding:10px 0;overflow:hidden;border-bottom:1px solid var(--line)}
  .marquee-track{display:flex;gap:48px;width:max-content;animation:marquee 36s linear infinite;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
  .marquee-item{display:inline-flex;align-items:center;gap:8px}
  .marquee-item svg{width:14px;height:14px;color:var(--honey)}
  .marquee-item .accent{color:var(--honey)}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  .microbar{background:var(--surface);border-bottom:1px solid var(--line);padding:8px 0;font-size:12px;color:var(--ink-soft);font-weight:500}
  .microbar-inner{display:flex;justify-content:center;gap:32px;flex-wrap:wrap}
  .microbar-item{display:inline-flex;align-items:center;gap:6px}
  .microbar-item svg{width:14px;height:14px;color:var(--honey)}

  .ed-hero{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:96px 0 80px;position:relative;overflow:hidden;text-align:center}
  .ed-hero::before{content:'';position:absolute;top:-120px;right:-100px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(61,189,182,.20) 0%,transparent 70%);pointer-events:none}
  .ed-hero::after{content:'';position:absolute;bottom:-80px;left:-80px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(61,189,182,.15) 0%,transparent 70%);pointer-events:none}
  .ed-hero .wrap{position:relative}
  .ed-hero .eyebrow{display:inline-block;background:var(--honey-soft);color:var(--honey-deep);font-size:12px;font-weight:800;padding:7px 14px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px}
  .ed-hero h1{font-family:'Helvetica Neue',Arial,sans-serif;font-size:clamp(32px,6vw,64px);font-weight:700;line-height:1.05;letter-spacing:-0.03em;max-width:14ch;margin:0 auto 22px;color:var(--charcoal);text-wrap:balance}
  .ed-hero h1 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.ed-hero h1{font-size:42px}}
  .ed-hero p{font-size:18px;color:var(--muted);max-width:60ch;margin:0 auto 28px;line-height:1.6}
  .ed-hero-meta{display:inline-flex;flex-wrap:wrap;gap:18px;justify-content:center;font-size:12px;color:var(--ink-soft);font-weight:600;letter-spacing:.08em;text-transform:uppercase}
  .ed-hero-meta .dot{color:var(--honey)}

  section.s{padding:80px 0;font-size:17px}
  @media(max-width:680px){section.s{padding:56px 0}}
  .s-eyebrow{display:inline-block;background:var(--honey-soft);color:var(--honey-deep);font-size:12px;font-weight:700;padding:7px 14px;border-radius:20px;letter-spacing:.10em;text-transform:uppercase;margin-bottom:16px}
  .s-title{font-family:'Helvetica Neue',Arial,sans-serif;font-size:48px;font-weight:700;line-height:1.05;letter-spacing:-0.025em;margin-bottom:16px;max-width:760px;color:var(--charcoal);text-wrap:balance}
  .s-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.s-title{font-size:36px}}
  .s-sub{font-size:17px;color:var(--ink-soft);max-width:640px;line-height:1.6}
  .s-head{margin-bottom:40px}
  .s-head.center{text-align:center}
  .s-head.center .s-title,.s-head.center .s-sub{margin-left:auto;margin-right:auto}

  /* Pillars */
  .pillars-bg{background:#fff}
  .pillars-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media(max-width:880px){.pillars-grid{grid-template-columns:repeat(2,1fr)}}
  .pillar-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:24px;transition:transform .25s,box-shadow .25s,border-color .25s}
  .pillar-card:hover{transform:translateY(-3px);box-shadow:0 14px 36px rgba(40,40,40,.10);border-color:var(--honey)}
  .pillar-num{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:11px;color:var(--honey-deep);letter-spacing:.16em;margin-bottom:14px}
  .pillar-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:20px;margin-bottom:8px;color:var(--ink)}
  .pillar-card p{font-size:14.5px;color:var(--ink-soft);line-height:1.55}

  /* Products row */
  .prod-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .prod-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;align-items:stretch}
  @media(max-width:880px){.prod-grid{grid-template-columns:1fr}}
  .prod-card{background:#fff;border:1px solid var(--line);border-radius:20px;overflow:hidden;transition:transform .25s,box-shadow .25s;display:block}
  .prod-card:hover{transform:translateY(-3px);box-shadow:0 14px 36px rgba(40,40,40,.10)}
  .prod-card__media{aspect-ratio:4/5;overflow:hidden}
  /* Card media backdrops kept neutral — accents live only in fonts */
  .prod-card--iron .prod-card__media,
  .prod-card--ginger .prod-card__media,
  .prod-card--energy .prod-card__media{background:#fff}
  .prod-card__media img{width:100%;height:100%;object-fit:cover}
  .prod-card__body{padding:24px}
  .prod-card__eye{font-size:11px;font-weight:800;letter-spacing:.10em;text-transform:uppercase;margin-bottom:6px}
  .prod-card--iron .prod-card__eye{color:#BE123C}
  .prod-card--ginger .prod-card__eye{color:#144B30}
  .prod-card--energy .prod-card__eye{color:#B73A92}
  .prod-card h3{font-family:'Helvetica Neue',Arial,sans-serif;font-size:22px;margin-bottom:8px;color:var(--ink)}
  .prod-card h3 em{font-style:italic;font-weight:500}
  .prod-card--iron h3 em{color:#E11D48}
  .prod-card--ginger h3 em{color:#2E8B57}
  .prod-card--energy h3 em{color:#B73A92}
  .prod-card p{font-size:14.5px;color:var(--ink-soft);line-height:1.55;margin-bottom:18px}
  .prod-card__cta{display:inline-flex;align-items:center;gap:8px;color:var(--charcoal);font-weight:700;font-size:13px;letter-spacing:.04em;text-transform:uppercase}
  .prod-card__cta svg{width:14px;height:14px;transition:transform .25s}
  .prod-card:hover .prod-card__cta svg{transform:translateX(4px)}

  /* Standards */
  .std-bg{background:#fff}
  .std-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;align-items:stretch;max-width:840px;margin:0 auto}
  @media(max-width:640px){.std-grid{grid-template-columns:1fr}}
  .std-card{display:flex;align-items:center;gap:16px;background:var(--surface);border:1px solid var(--line-soft);border-radius:16px;padding:18px 22px;text-align:left;transition:transform .25s,box-shadow .25s,border-color .25s}
  .std-card:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(40,40,40,.09);border-color:var(--honey)}
  .std-card .ic{flex:0 0 44px;width:44px;height:44px;border-radius:12px;background:var(--honey-soft);color:var(--honey-deep);display:grid;place-items:center}
  .std-card .ic svg{width:23px;height:23px;stroke-width:2}
  .std-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:15.5px;color:var(--ink);margin:0;letter-spacing:-0.005em}

  /* Story */
  .story-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .story-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
  @media(max-width:880px){.story-grid{grid-template-columns:1fr;gap:28px}}
  .story-copy h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:42px;font-weight:700;line-height:1.05;letter-spacing:-0.02em;margin-bottom:18px;color:var(--charcoal);text-wrap:balance}
  .story-copy h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.story-copy h2{font-size:32px}}
  .story-copy p{font-size:16px;color:var(--ink-soft);line-height:1.7;margin-bottom:14px}
  .story-quote{background:#fff;border:1px solid var(--line);border-left:4px solid var(--honey);padding:28px;border-radius:14px;box-shadow:0 8px 24px rgba(40,40,40,.06)}
  .story-quote .kanji{font-family:'Noto Serif',serif;font-size:clamp(44px,9vw,80px);line-height:1;color:var(--honey-deep);margin-bottom:14px}
  .story-quote .word{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:14px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink);margin-bottom:8px}
  .story-quote p{font-size:15.5px;color:var(--muted);line-height:1.6;font-style:italic}

  /* Manifesto */
  .manifesto{background:var(--charcoal);color:#fff;padding:80px 0;text-align:center}
  .manifesto h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:48px;font-weight:700;max-width:18ch;margin:0 auto 16px;line-height:1.05;letter-spacing:-0.02em;text-wrap:balance}
  .manifesto h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.manifesto h2{font-size:36px}}
  .manifesto p{font-size:17px;color:#bbb;max-width:60ch;margin:0 auto}

  /* Final */
  .final{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:96px 0;text-align:center}
  .final h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:48px;font-weight:700;max-width:20ch;margin:0 auto 14px;line-height:1.05;letter-spacing:-0.025em;color:var(--charcoal);text-wrap:balance}
  .final h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.final h2{font-size:34px}}
  .final p{font-size:16px;color:var(--muted);max-width:540px;margin:0 auto 28px}
  .final-cta{display:inline-flex;align-items:center;gap:10px;background:var(--charcoal);color:#fff;padding:16px 32px;border-radius:14px;font-weight:700;font-size:14px;letter-spacing:.04em;text-transform:uppercase;transition:transform .2s,background .2s}
  .final-cta:hover{transform:translateY(-2px);background:var(--charcoal-2)}

  /* Footer */
  .ed-footer{background:var(--charcoal);color:#ddd;padding:56px 0 24px}
  .ed-footer__cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:32px;margin-bottom:32px}
  @media(max-width:880px){.ed-footer__cols{grid-template-columns:1fr 1fr}}
  .ed-footer__brand img{height:32px;margin-bottom:12px}
  .ed-footer__brand p{color:#999;font-size:.88rem;max-width:32ch}
  .ed-footer__col h5{color:#fff;font-size:.74rem;margin-bottom:12px;letter-spacing:.08em;text-transform:uppercase}
  .ed-footer__col ul{list-style:none}
  .ed-footer__col li{margin-bottom:8px}
  .ed-footer__col a{color:#aaa;font-size:.88rem}
  .ed-footer__col a:hover{color:var(--honey)}
  .ed-footer__bar{display:flex;justify-content:space-between;padding-top:24px;border-top:1px solid rgba(255,255,255,.08);color:#777;font-size:.82rem;flex-wrap:wrap;gap:8px}
</style>
</head>
