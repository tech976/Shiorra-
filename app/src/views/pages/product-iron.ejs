  if (!main || !thumbs.length) return;
  thumbs.forEach((t) => {
    t.addEventListener('click', () => {
      const url = t.getAttribute('data-full');
      if (!url) return;
      thumbs.forEach((x) => x.classList.remove('is-active'));
      t.classList.add('is-active');
      main.src = url;
    });
  });
})();
(function () {
  document.querySelectorAll('.pi-qty').forEach((q) => {
    const input = q.querySelector('input');
    const min = parseInt(input.min, 10) || 1;
    const max = parseInt(input.max, 10) || 9;
    q.querySelectorAll('button[data-q]').forEach((b) => {
      b.addEventListener('click', () => {
        const v = parseInt(input.value, 10) || min;
        input.value = b.dataset.q === '+' ? Math.min(max, v + 1) : Math.max(min, v - 1);
      });
    });
  });
})();
</script>
</body>
</html>
