<!-- EDITORIAL MASTHEAD — reviews-page DNA -->
<div class="pi-masthead">
  <div class="wrap">
    <div class="pi-masthead__inner reveal">
      <span class="pi-masthead__edition">Iron+ · Volume One</span>
      <span class="pi-masthead__pub">Shiōrra Reader Edition</span>
    </div>
  </div>
</div>

<style>
  /* Editorial masthead — borrows the reviews.ejs rv-hero__masthead language */
  .pi-masthead{background:#fff;border-bottom:1px solid var(--line);padding:18px 0}
  .pi-masthead__inner{display:flex;justify-content:space-between;align-items:center;gap:24px;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--c-text-3,#8A8A8A)}
  .pi-masthead__edition{color:var(--ink)}
  .pi-masthead__pub{color:var(--honey-deep)}
  @media (max-width:560px){
    .pi-masthead{padding:14px 0}
    .pi-masthead__inner{font-size:10px;letter-spacing:.18em}
  }
</style>

<!-- HERO -->
<section class="product-hero" id="buy">
  <div class="wrap">
    <div class="product-hero-grid">
      <div class="gallery">
        <div class="gallery-main">
          <img id="galleryMain" src="/img/products/iron-1.jpg" alt="Shiōrra Advanced Iron+ — 30 vegecaps for pregnancy and lactation">
        </div>
        <div class="gallery-thumbs" id="galleryThumbs">
          <button type="button" class="gallery-thumb is-active" data-full="/img/products/iron-1.jpg" aria-label="Pack shot"><img src="/img/products/iron-1.jpg" alt=""></button>
          <button type="button" class="gallery-thumb" data-full="/img/products/iron-2.jpg" aria-label="Product display"><img src="/img/products/iron-2.jpg" alt=""></button>
          <button type="button" class="gallery-thumb" data-full="/img/products/iron-3.jpg" aria-label="Product display"><img src="/img/products/iron-3.jpg" alt=""></button>
          <button type="button" class="gallery-thumb" data-full="/img/products/iron-4.jpg" aria-label="Product display"><img src="/img/products/iron-4.jpg" alt=""></button>
          <button type="button" class="gallery-thumb" data-full="/img/products/iron-5.jpg" aria-label="Product details"><img src="/img/products/iron-5.jpg" alt=""></button>
        </div>
      </div>
      <div class="info">
        <span class="pi-kicker">Daily Prenatal Iron · 30 Vegecaps</span>
        <h1 class="pi-title">Advanced Iron<em>+</em></h1>
        <p class="pi-sub">Chelated Ferrous Bisglycinate 27 mg with active Folate, B12 &amp; Zinc — gentle on the stomach, no metallic aftertaste.</p>
        <div class="pi-proof">
          <span class="pi-proof__star" aria-hidden="true">★</span>
          <span class="pi-proof__score">4.9</span>
          <a href="/reviews" class="pi-proof__count">1,240+ reviews</a>
        </div>
        <p class="pi-claims">Doctor recommended · FSSAI &amp; GMP · 100% vegetarian</p>
        <form action="/cart/buy-now" method="post" id="addToCartForm" class="pi-buy-form">
          <input type="hidden" name="productId" value="<%= product.id %>">
          <div class="pi-commerce">
            <div class="pi-price-line">
              <span class="pi-price-now">₹749</span>
              <span class="pi-price-meta">MRP <s>₹899</s> · 17% off</span>
            </div>
            <div class="pi-qty">
              <button type="button" data-q="-" aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" value="1" min="1" max="9" form="addToCartForm" aria-label="Quantity">
              <button type="button" data-q="+" aria-label="Increase quantity">+</button>
            </div>
          </div>
          <% var _soldOut = (typeof product.stock === 'number' && product.stock <= 0);
             var _lowStock = (!_soldOut && typeof product.stock === 'number' && product.stock <= 10); %>
          <% if (_lowStock) { %><p class="pi-stocknote" style="margin:6px 0 0;font-size:13px;font-weight:600;color:#C2410C">Only <%= product.stock %> left in stock</p><% } %>
