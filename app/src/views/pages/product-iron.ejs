            <ul class="nav__menu" id="navMenu">
                <li><a href="/">Home</a></li>
                <li><a href="/shop" class="active">Shop Products</a></li>                <li><a href="/reviews">Reviews</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/faq">FAQ</a></li>
            </ul>
