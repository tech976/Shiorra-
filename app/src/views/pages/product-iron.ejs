              <button type="button" class="pi-add" disabled aria-disabled="true" style="opacity:.5;cursor:not-allowed">Sold out</button>
            </div>
            <p class="pi-stocknote" style="margin:10px 0 0;font-size:13px;color:#6A6F75">Currently out of stock. Please check back soon.</p>
          <% } else { %>
            <div class="pi-buy-row">
              <button type="submit" formaction="/cart/add" class="pi-add-secondary">Add to cart</button>
