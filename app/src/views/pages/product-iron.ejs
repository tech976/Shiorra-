<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Advanced Iron+ · Shiōrra · Smarter Iron for a Healthier Pregnancy</title>
<meta name="description" content="Shiōrra Advanced Iron+ — Ferrous Bisglycinate 27 mg + active Folate, B12, B6, Zinc, Copper & Selenium. Designed for pregnant & lactating women. Gentle on stomach, no metallic aftertaste. A trademark of K.C. Laboratories." />
<link rel="shortcut icon" type="image/png" href="/img/logo/logo-green.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    /* Iron+ product accent — pink (pregnancy / vitality) */
    --honey:#E11D48;
    --honey-2:#BE123C;
    --honey-deep:#9F1239;
    --honey-soft:#FFE4EC;
    --charcoal:#282828;
    --charcoal-2:#3A3A3A;
    --ink:#282828;
    --ink-soft:#3A3A3A;
    --white:#FFFFFF;
    --surface:#F7F7F8;
    --surface-2:#FBFBFC;
    --line:#E5E5E7;
    --line-soft:#F0F0F2;
    --muted:#6B6B6B;
    --muted-2:#8A8A8A;
    --green:#1E9E5C;
    --shadow-sm:0 2px 6px rgba(40,40,40,.06);
    --shadow-md:0 8px 24px rgba(40,40,40,.08);
  }
  html{scroll-behavior:smooth;overflow-x:clip}
  body{
    font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
    color:var(--ink);
    background:#fff;
    line-height:1.55;
    font-size:15px;
    overflow-x:clip;
    padding-bottom:88px;
  }
  @media(max-width:680px){body{padding-bottom:80px}}
  img{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  button{font:inherit;cursor:pointer;border:0;background:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}

  /* ---------- Marquee ---------- */
  .marquee{background:var(--charcoal);color:#fff;padding:10px 0;overflow:hidden;border-bottom:1px solid var(--line)}
  .marquee-track{display:flex;gap:48px;width:max-content;animation:marquee 36s linear infinite;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
  .marquee-item{display:inline-flex;align-items:center;gap:8px}
  .marquee-item svg{width:14px;height:14px;color:var(--honey)}
  .marquee-item .accent{color:var(--honey)}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* ---------- Trust microbar ---------- */
  .microbar{background:var(--surface);border-bottom:1px solid var(--line);padding:8px 0;font-size:12px;color:var(--ink-soft);font-weight:500}
  .microbar-inner{display:flex;justify-content:center;gap:32px;flex-wrap:wrap}
  .microbar-item{display:inline-flex;align-items:center;gap:6px}
  .microbar-item svg{width:14px;height:14px;color:var(--honey)}

  /* ---------- Hero ---------- */
  .product-hero{
    background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);
    padding:48px 0 64px;
    position:relative;
    overflow:hidden;
  }
  .product-hero::before{
    content:'';position:absolute;top:-100px;right:-100px;
    width:420px;height:420px;border-radius:50%;
    background:radial-gradient(circle,rgba(255,61,142,.18) 0%,transparent 70%);
    pointer-events:none;
  }
  .product-hero-grid{
    display:grid;grid-template-columns:1fr 1.05fr;gap:48px;align-items:start;
    position:relative;
  }
  @media(max-width:880px){.product-hero-grid{grid-template-columns:1fr;gap:28px}}

  .gallery{position:sticky;top:88px}
  @media(max-width:880px){.gallery{position:static}}
  .gallery-main{aspect-ratio:4/5;width:100%;background:#fff;border-radius:22px;border:1px solid var(--line);
    display:grid;place-items:center;overflow:hidden;position:relative;
  }
  .gallery-main img{width:100%;height:100%;object-fit:cover;object-position:center}
  .gallery-thumbs{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:10px}
  .gallery-thumb{aspect-ratio:4/5;background:#fff;border:1.5px solid var(--line);border-radius:12px;overflow:hidden;cursor:pointer;padding:0;transition:border-color .2s,transform .2s}
  .gallery-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s ease}
  .gallery-thumb:hover{border-color:var(--honey);transform:translateY(-1px)}
  .gallery-thumb.is-active{border-color:var(--honey);box-shadow:0 0 0 3px var(--honey-soft) inset}
  .float-badge{
    position:absolute;background:#fff;
    border-radius:16px;padding:10px 16px;font-size:12.5px;font-weight:700;
    box-shadow:0 8px 24px rgba(40,40,40,.10),0 2px 6px rgba(40,40,40,.06);
    border:1px solid var(--line);
    display:inline-flex;align-items:center;gap:10px;
  }
  .float-1{top:18px;left:18px}
  .float-2{bottom:18px;right:18px}
  .float-1-icon{
    color:var(--honey);font-size:14px;line-height:1;
  }
  .pulse-dot{width:6px;height:6px;border-radius:50%;background:var(--honey)}

  /* Product info */
  .info{padding-top:8px}
  .pi-eyebrow-trust{display:inline-flex;align-items:center;gap:8px;background:var(--honey-soft);color:var(--honey-deep);font-size:11.5px;font-weight:800;padding:6px 12px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:14px}
  .pi-eyebrow-trust::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--honey)}
  .pi-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:40px;font-weight:700;line-height:1.08;letter-spacing:-0.022em;color:var(--ink);margin-bottom:10px;text-wrap:balance}
  .pi-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.pi-title{font-size:32px}}
  .pi-sub{font-size:18px;color:var(--honey-deep);font-style:italic;font-weight:500;line-height:1.45;margin-bottom:22px;max-width:520px}
  .pi-tagrow{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px}
  .pi-tag{font-size:11px;font-weight:700;color:var(--ink-soft);background:#fff;border:1px solid var(--line);padding:5px 10px;border-radius:14px;letter-spacing:.06em;text-transform:uppercase}
  .pi-tag.ven{background:var(--green);color:#fff;border-color:var(--green)}
  .pi-rating{display:flex;align-items:center;gap:10px;margin-bottom:18px}
  .stars{display:inline-flex;gap:1px;color:var(--honey);font-size:17px;letter-spacing:1.5px}
  .pi-rating-n{font-weight:700;font-size:15px}
  .pi-rating-c{font-size:13px;color:var(--muted);text-decoration:underline}
  .pi-price{display:flex;align-items:baseline;gap:12px;margin:6px 0 18px;flex-wrap:wrap}
  .pi-now{font-family:'Helvetica Neue',Arial,sans-serif;font-size:38px;font-weight:700;color:var(--ink);letter-spacing:-0.02em}
  .pi-mrp{font-size:18px;color:var(--muted);text-decoration:line-through}
  .pi-save{font-size:11px;font-weight:800;color:#fff;background:var(--honey);padding:4px 10px;border-radius:8px;letter-spacing:.06em;text-transform:uppercase}
  .pi-buy-row{display:flex;gap:10px;margin:18px 0}
  .pi-qty{display:inline-flex;align-items:center;border:1px solid var(--line);border-radius:12px;background:#fff;overflow:hidden}
  .pi-qty button{width:38px;height:46px;font-size:18px;color:var(--ink);font-weight:700}
  .pi-qty input{width:44px;height:46px;border:0;text-align:center;font-size:15px;font-weight:700;font-family:inherit;background:transparent}
  .pi-qty input::-webkit-inner-spin-button{display:none}
  .pi-add{flex:1;height:50px;display:inline-flex;align-items:center;justify-content:center;background:var(--charcoal);color:#fff;font-weight:700;font-size:14px;letter-spacing:.04em;border-radius:12px;text-transform:uppercase;transition:background .2s,transform .2s;border:0;cursor:pointer}
  .pi-add:hover{background:var(--charcoal-2);transform:translateY(-1px)}
  .pi-add-secondary{height:38px;display:inline-flex;align-items:center;justify-content:center;background:transparent;color:var(--ink-soft);font-weight:600;font-size:12.5px;letter-spacing:.04em;border:0;cursor:pointer;text-transform:uppercase;text-decoration:underline;text-underline-offset:3px;transition:color .2s}
  .pi-add-secondary:hover{color:var(--charcoal)}
  .pi-trust-line{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);margin-top:8px}
  .pi-trust-line svg{width:14px;height:14px;color:var(--honey)}
  .pi-points{margin-top:24px;display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
  .pi-points li{display:flex;align-items:center;gap:8px;font-size:13.5px;list-style:none;color:var(--ink-soft)}
  .pi-points li svg{width:16px;height:16px;color:var(--honey);flex-shrink:0}

  /* ---------- Section ---------- */
  section.s{padding:72px 0;font-size:17px;position:relative}
  @media(max-width:680px){section.s{padding:56px 0}}
  .s-eyebrow{
    display:inline-flex;align-items:center;
    background:var(--honey-soft);
    color:var(--honey-deep);font-size:12px;font-weight:800;
    padding:8px 16px;border-radius:22px;letter-spacing:.10em;text-transform:uppercase;margin-bottom:16px;
  }
  .s-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:48px;font-weight:700;line-height:1.05;letter-spacing:-0.025em;margin-bottom:16px;max-width:760px;color:var(--charcoal);position:relative;text-wrap:balance}
  .s-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.s-title{font-size:36px}}
  .s-sub{font-size:17px;color:var(--ink-soft);max-width:640px;line-height:1.6}
  .s-head{margin-bottom:40px;position:relative}
  .s-head.center{text-align:center}
  .s-head.center .s-title,.s-head.center .s-sub{margin-left:auto;margin-right:auto}

  /* ---------- Premium icon chip (shared) ---------- */
  .ic-chip{
    width:64px;height:64px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);
    display:grid;place-items:center;
    transition:transform .35s cubic-bezier(.2,.7,.2,1);
  }
  .ic-chip svg{width:30px;height:30px;stroke-width:2.2}

  /* ---------- Symptom cards ---------- */
  .symptoms-bg{background:#fff}
  .symptoms-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media(max-width:880px){.symptoms-grid{grid-template-columns:repeat(2,1fr)}}
  .symptom-card{
    background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;
    transition:transform .3s cubic-bezier(.2,.7,.2,1),box-shadow .3s,border-color .3s;
  }
  .symptom-card:hover{transform:translateY(-4px);box-shadow:0 16px 36px -16px rgba(40,40,40,.12),0 2px 8px rgba(40,40,40,.06);border-color:var(--line)}
  .symptom-card:hover .ic{transform:scale(1.04)}
  .symptom-card .ic{
    width:64px;height:64px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;margin-bottom:18px;
    transition:transform .35s cubic-bezier(.2,.7,.2,1);
  }
  .symptom-card .ic svg{width:30px;height:30px;stroke-width:2.2}
  .symptom-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;font-weight:700;margin-bottom:6px;color:var(--ink)}
  .symptom-card p{font-size:14px;color:var(--muted);line-height:1.5}

  /* ---------- Power team ---------- */
  .power-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .power-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;align-items:stretch}
  @media(max-width:880px){.power-grid{grid-template-columns:1fr}}
  .power-card{
    background:#fff;border:1px solid var(--line);border-radius:24px;padding:34px;
    transition:transform .35s cubic-bezier(.2,.7,.2,1),box-shadow .35s,border-color .35s;
  }
  .power-card:hover{transform:translateY(-4px);box-shadow:0 20px 44px -20px rgba(40,40,40,.12),0 2px 8px rgba(40,40,40,.06);border-color:var(--line)}
  .power-card .pc-eye{
    display:inline-flex;align-items:center;
    background:var(--honey-soft);
    color:var(--honey-deep);font-size:11px;font-weight:800;padding:6px 12px;border-radius:16px;
    letter-spacing:.10em;text-transform:uppercase;margin-bottom:14px;
  }
  .power-card h3{font-family:'Helvetica Neue',Arial,sans-serif;font-size:26px;margin-bottom:8px;letter-spacing:-0.015em}
  .power-card .pc-lede{font-size:14.5px;color:var(--muted);margin-bottom:18px;line-height:1.55}
  .power-card ul{list-style:none;display:grid;gap:10px}
  .power-card li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--ink-soft)}
  .power-card li svg{
    width:22px;height:22px;color:var(--honey);
    flex-shrink:0;
  }
  .power-card .pc-tag{margin-top:18px;font-size:12.5px;color:var(--muted);font-style:italic;padding-top:14px;border-top:1px solid var(--line-soft)}

  /* ---------- B Vitamins ---------- */
  .bvit-bg{background:#fff}
  .bvit-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-top:18px}
  @media(max-width:980px){.bvit-grid{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:520px){.bvit-grid{grid-template-columns:repeat(2,1fr)}}
  .bvit-pill{
    background:var(--honey-soft);
    border-radius:18px;padding:20px 12px;text-align:center;
    transition:transform .3s,box-shadow .3s;
  }
  .bvit-pill:hover{transform:translateY(-3px);box-shadow:0 12px 28px -14px rgba(40,40,40,.12)}
  .bvit-pill .name{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:18px;color:var(--honey-deep);letter-spacing:.02em}
  .bvit-pill .sub{font-size:11.5px;color:var(--honey-deep);opacity:.75;margin-top:4px;font-weight:600}
  .bvit-help{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:36px;align-items:stretch}
  @media(max-width:880px){.bvit-help{grid-template-columns:repeat(2,1fr)}}
  .bvit-help-card{
    background:#fff;border:1px solid var(--line);
    border-radius:20px;padding:24px;
    transition:transform .3s,box-shadow .3s,border-color .3s;
  }
  .bvit-help-card:hover{transform:translateY(-3px);border-color:var(--line);box-shadow:0 16px 32px -16px rgba(40,40,40,.12)}
  .bvit-help-card:hover .ic{transform:scale(1.04)}
  .bvit-help-card .ic{
    width:64px;height:64px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;margin-bottom:14px;
    transition:transform .35s cubic-bezier(.2,.7,.2,1);
  }
  .bvit-help-card .ic svg{width:30px;height:30px;stroke-width:2.2}
  .bvit-help-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:15px;margin-bottom:6px;color:var(--ink);font-weight:700}
  .bvit-help-card p{font-size:13px;color:var(--muted);line-height:1.55}

  /* ---------- Minerals ---------- */
  .min-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .min-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media(max-width:880px){.min-grid{grid-template-columns:repeat(2,1fr)}}
  .min-card{
    background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;
    transition:transform .3s,box-shadow .3s,border-color .3s;
  }
  .min-card:hover{transform:translateY(-4px);box-shadow:0 16px 36px -16px rgba(40,40,40,.12),0 2px 8px rgba(40,40,40,.06);border-color:var(--line)}
  .min-card:hover .ic{transform:scale(1.04)}
  .min-card .ic{
    width:64px;height:64px;border-radius:18px;
    background:#F7F7F8;
    color:var(--ink);display:grid;place-items:center;
    font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:22px;letter-spacing:-.01em;
    margin-bottom:14px;
    transition:transform .35s cubic-bezier(.2,.7,.2,1);
  }
  .min-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;margin-bottom:6px;color:var(--ink);font-weight:700}
  .min-card p{font-size:13.5px;color:var(--muted);line-height:1.5}

  /* ---------- 9 actives formula ---------- */
  .formula-bg{background:#fff}
  .formula-list{
    margin-top:14px;border:1px solid var(--line);border-radius:22px;overflow:hidden;background:#fff;
  }
  .formula-row{display:grid;grid-template-columns:1.5fr 1fr 2fr;align-items:center;padding:18px 22px;border-top:1px solid var(--line-soft);transition:background .25s}
  .formula-row:not(:first-child):hover{background:rgba(0,0,0,0.02)}
  .formula-row:first-child{border-top:0;background:var(--surface);font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.10em;color:var(--ink)}
  .fc-name{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:700;color:var(--ink);font-size:14.5px}
  .fc-name small{display:block;font-size:11.5px;color:var(--muted);font-weight:500;margin-top:2px}
  .fc-amt{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:700;color:var(--honey-deep);font-size:14px}
  .fc-role{font-size:13.5px;color:var(--muted);line-height:1.5}
  @media(max-width:680px){.formula-row{grid-template-columns:1fr}.fc-amt{font-size:13px}.formula-row:first-child{display:none}}

  /* ---------- Timeline ---------- */
  .timeline-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .timeline-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:16px;align-items:stretch}
  @media(max-width:880px){.timeline-grid{grid-template-columns:1fr}}
  .tl-card{
    background:#fff;border:1px solid var(--line);border-radius:22px;padding:30px;position:relative;
    transition:transform .35s cubic-bezier(.2,.7,.2,1),box-shadow .35s,border-color .35s;
  }
  .tl-card:hover{transform:translateY(-5px);box-shadow:0 20px 44px -20px rgba(40,40,40,.12),0 2px 8px rgba(40,40,40,.06);border-color:var(--line)}
  .tl-step{
    position:absolute;top:20px;right:20px;
    background:var(--honey-soft);
    color:var(--honey-deep);font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:11px;
    padding:6px 12px;border-radius:14px;letter-spacing:.08em;text-transform:uppercase;
  }
  .tl-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:22px;color:var(--ink);margin:22px 0 14px;max-width:80%;letter-spacing:-0.015em}
  .tl-card ul{list-style:none;display:grid;gap:10px}
  .tl-card li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--ink-soft)}
  .tl-card li svg{
    width:22px;height:22px;color:var(--honey);
    flex-shrink:0;
  }
  .tl-stat{
    margin-top:36px;
    background:var(--charcoal);
    color:#fff;border-radius:20px;padding:26px 32px;
    display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
  }
  .tl-stat strong{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:24px;letter-spacing:-0.02em}
  .tl-stat .ref{font-size:11.5px;opacity:.85;font-style:italic}

  /* ---------- Compare ---------- */
  .why-bg{background:#fff}
  .compare-table{margin-top:14px;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff}
  .compare-row{display:grid;grid-template-columns:1.2fr 1fr 1fr}
  .compare-row + .compare-row{border-top:1px solid var(--line-soft)}
  .compare-row.head{background:var(--surface);font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--ink)}
  .compare-row.head .cc{padding:14px 18px}
  .compare-row.head .cc:first-child{visibility:hidden}
  .compare-row.head .cc:nth-child(2){color:var(--honey-deep);background:var(--honey-soft)}
  .cc{padding:14px 18px;font-size:14px;line-height:1.45}
  .cc.lbl{font-weight:700;color:var(--ink)}
  .cc.them{color:var(--muted)}
  .cc.us{background:var(--honey-soft);color:var(--ink);font-weight:600}
  @media(max-width:680px){
    .compare-row{grid-template-columns:1fr 1fr}
    .compare-row.head .cc:first-child{display:none}
    .cc.lbl{grid-column:1/-1;background:var(--line-soft);font-size:13px}
  }

  /* ---------- Root cards ---------- */
  .root-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .root-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:14px;align-items:stretch}
  @media(max-width:980px){.root-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:580px){.root-grid{grid-template-columns:1fr}}
  .root-card{
    background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;
    transition:transform .35s cubic-bezier(.2,.7,.2,1),box-shadow .35s,border-color .35s;
  }
  .root-card:hover{transform:translateY(-4px);box-shadow:0 18px 40px -18px rgba(40,40,40,.12),0 2px 8px rgba(40,40,40,.06);border-color:var(--line)}
  .root-card .rc-eye{
    display:inline-flex;align-items:center;
    font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:11px;
    color:var(--honey-deep);letter-spacing:.10em;text-transform:uppercase;margin-bottom:12px;
    padding:5px 10px;background:var(--honey-soft);
    border-radius:14px;
  }
  .root-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;color:var(--ink);margin-bottom:8px;font-weight:700;letter-spacing:-0.01em}
  .root-card p{font-size:13.5px;color:var(--muted);line-height:1.55;margin-bottom:16px}
  .root-card .solve{
    display:flex;gap:10px;align-items:center;
    background:var(--honey-soft);
    color:var(--honey-deep);padding:12px 14px;border-radius:14px;
    font-size:13px;font-weight:700;line-height:1.4;
  }
  .root-card .solve svg{
    width:20px;height:20px;flex-shrink:0;color:var(--honey);stroke-width:2.4;
  }

  /* ---------- Reminder + final CTA ---------- */
  .reminder{background:var(--charcoal);color:#fff;padding:64px 0}
  .reminder .wrap{text-align:center}
  .reminder .eye{display:inline-block;background:rgba(255,255,255,.08);color:#fff;font-size:11px;font-weight:800;padding:6px 14px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px}
  .reminder h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:42px;font-weight:700;line-height:1.15;color:#fff;max-width:22ch;margin:0 auto 16px;letter-spacing:-0.02em}
  .reminder h2 em{font-style:italic;color:var(--honey);font-weight:500}
  .reminder p{font-size:16px;color:#bbb;max-width:560px;margin:0 auto 24px}
  .reminder .rem-row{display:inline-flex;flex-wrap:wrap;gap:8px;margin-top:8px;justify-content:center}
  .reminder .rem-chip{background:rgba(255,255,255,.07);color:#fff;font-size:12px;font-weight:600;padding:7px 14px;border-radius:20px}
  @media(max-width:680px){.reminder h2{font-size:32px}}

  .final{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:80px 0;text-align:center;position:relative}
  .final h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:44px;font-weight:700;line-height:1.15;max-width:22ch;margin:0 auto 14px}
  .final h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.final h2{font-size:32px}}
  .final p{font-size:16px;color:var(--muted);max-width:540px;margin:0 auto 24px}
  .final-cta{display:inline-flex;align-items:center;gap:10px;background:var(--charcoal);color:#fff;padding:16px 32px;border-radius:14px;font-weight:700;font-size:14px;letter-spacing:.04em;text-transform:uppercase;transition:transform .2s,background .2s}
  .final-cta:hover{transform:translateY(-2px);background:var(--charcoal-2)}

  /* ---------- Sticky offer ---------- */
  .sticky-cta{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--line);box-shadow:0 -8px 24px rgba(40,40,40,.06);padding:10px 0;z-index:40}
  .sticky-cta-inner{display:flex;align-items:center;gap:14px;justify-content:space-between}
  .sticky-text{display:flex;flex-direction:column;line-height:1.2}
  .sticky-eye{font-size:10px;font-weight:800;color:var(--honey-deep);letter-spacing:.10em;text-transform:uppercase;margin-bottom:2px}
  .sticky-h{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:700;font-size:14px;color:var(--ink)}
  .sticky-h em{color:var(--honey);font-style:normal;font-weight:800}
  .sticky-price{display:flex;align-items:baseline;gap:6px;flex-shrink:0}
  .sticky-now{font-family:'Helvetica Neue';font-weight:700;font-size:18px;color:var(--ink)}
  .sticky-mrp{font-size:12px;color:var(--muted);text-decoration:line-through}
  .sticky-btn{background:var(--charcoal);color:#fff;padding:12px 18px;border-radius:10px;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.04em;flex-shrink:0}
  .sticky-btn:hover{background:var(--charcoal-2)}
  @media(max-width:680px){.sticky-text{display:none}}

  /* ============================================================
     MOBILE UX PASS — surgical augmentations only.
     Targets <=720px viewports (Indian mobile 360–414px primary).
     ============================================================ */
  @media (max-width: 720px){
    /* Horizontal page padding scales smoothly */
    .wrap{padding:0 clamp(16px,4.5vw,24px)}

    /* Marquee — keep readable */
    .marquee{padding:8px 0}
    .marquee-track{gap:32px;font-size:11.5px}

    /* Microbar — let copy wrap, tighten gap */
    .microbar{padding:8px 0;font-size:11px}
    .microbar-inner{gap:14px 18px;justify-content:flex-start;overflow-x:auto;
      -webkit-overflow-scrolling:touch;white-space:nowrap;flex-wrap:nowrap;
      padding-bottom:2px}
    .microbar-item{flex:0 0 auto}

    /* Hero — tighten padding, scale title with clamp */
    .product-hero{padding:clamp(28px,7vw,44px) 0 clamp(36px,9vw,56px)}
    .product-hero::before{width:280px;height:280px;top:-80px;right:-80px}
    .product-hero-grid{gap:24px}
    .pi-title{font-size:clamp(28px,7.5vw,38px);line-height:1.08}
    .pi-sub{font-size:15.5px;line-height:1.5;margin-bottom:18px}
    .pi-points{grid-template-columns:1fr;gap:10px}
    .pi-points li{font-size:14px;min-height:24px}
    .pi-tag{font-size:10.5px;padding:5px 9px}
    .pi-now{font-size:32px}
    .pi-mrp{font-size:16px}

    /* Float-badges — keep visible but smaller so they don't crop the product */
    .float-badge{padding:7px 11px;font-size:11px;border-radius:12px;gap:6px}
    .float-1{top:10px;left:10px}
    .float-2{bottom:10px;right:10px}

    /* Gallery thumbs — keep horizontal at 360px, ~64-72px tall */
    .gallery-thumbs{gap:6px;margin-top:8px}
    .gallery-thumb{min-height:44px;border-radius:10px;border-width:1.25px}

    /* Buy row — keep touch targets ≥44px and CTA full-width */
    .pi-buy-row{gap:8px;margin:16px 0}
    .pi-qty{border-radius:11px}
    .pi-qty button{width:44px;height:48px}
    .pi-qty input{width:42px;height:48px;font-size:15px}
    .pi-add{height:58px;font-size:16px;font-weight:800;letter-spacing:.06em;border-radius:14px;min-height:58px;padding:0 16px;white-space:nowrap}
    .pi-add-secondary{height:40px;font-size:13px}

    /* Section padding scales */
    section.s{padding:clamp(40px,10vw,72px) 0}
    .s-title{font-size:clamp(26px,7vw,38px);line-height:1.1}
    .s-sub{font-size:15px;line-height:1.55}
    .s-head{margin-bottom:28px}

    /* Symptom + min cards — single column on small phones for readability */
    .power-card{padding:24px}
    .symptom-card{padding:22px 20px}
    .symptom-card h4{font-size:16px}
    .min-card{padding:22px 20px}
    .root-card{padding:22px 20px}
    .tl-card{padding:24px 22px}
    .tl-card h4{font-size:20px;max-width:100%;margin:18px 0 12px}
    .tl-step{top:14px;right:14px;font-size:10.5px}
    .tl-stat{padding:20px 22px;flex-direction:column;align-items:flex-start;text-align:left}
    .tl-stat strong{font-size:20px;line-height:1.25}

    /* Compare table — bigger touch label rows */
    .cc{padding:12px 14px;font-size:13.5px}

    /* B vitamins help cards — keep icon chip large enough to read */
    .bvit-help-card{padding:20px 18px}
    .bvit-help-card .ic{width:56px;height:56px;border-radius:14px}
    .bvit-help-card .ic svg{width:26px;height:26px}

    /* Reminder + final */
    .reminder{padding:48px 0}
    .reminder p{font-size:15px}
    .final{padding:56px 0}
    .final p{font-size:15px}
    .final-cta{padding:14px 24px;font-size:13.5px;min-height:50px}

    /* Sticky CTA — tight price + button, no overflow */
    .sticky-cta{padding:8px 0}
    .sticky-cta-inner{gap:10px}
    .sticky-now{font-size:16px}
    .sticky-mrp{font-size:11px}
    .sticky-btn{padding:12px 16px;font-size:12.5px;border-radius:10px;min-height:44px}

    /* Tappable nav & links inherited from layout — reinforce here */
    .site-header .nav__menu a,.site-header .nav__toggle{min-height:44px}
  }

  /* Extra-narrow phones (~360px) — only tighten where necessary */
  @media (max-width: 380px){
    .float-badge{font-size:10.5px;padding:6px 9px}
    .float-1{top:8px;left:8px}
    .float-2{bottom:8px;right:8px}
    .pi-now{font-size:28px}
    .pi-mrp{font-size:14px}
    .pi-save{font-size:10px;padding:3px 8px}
    .gallery-thumb{border-radius:8px}
  }

  /* Single-column at 580px for symptom + B vitamins (8 cards is a lot) */
  @media (max-width: 580px){
    .symptoms-grid{grid-template-columns:1fr;gap:12px}
    .bvit-help{grid-template-columns:1fr;gap:12px}
    .min-grid{grid-template-columns:repeat(2,1fr);gap:12px}
  }
</style>
</head>
