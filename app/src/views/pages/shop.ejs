<style>
  /* shop.ejs — mobile-first surgical augmentations.
     Base layout lives in /css/style.css; this only tunes <=720px viewports. */
  .page-hero h1{font-size:clamp(34px,8vw,64px);line-height:1.05;letter-spacing:-0.02em}
  .page-hero .eyebrow{font-size:clamp(11px,2.6vw,13px)}
  .page-hero{padding:clamp(40px,9vw,96px) 0 clamp(24px,6vw,48px)}

  /* Product grid stacks to 1-col on phones, 2-col on small tablets */
  @media (max-width: 1024px){
    .product-grid{grid-template-columns:repeat(2,1fr)!important;gap:clamp(16px,3vw,28px)!important}
  }
  @media (max-width: 720px){
    .product-grid{grid-template-columns:1fr!important;gap:clamp(18px,5vw,24px)!important}
    .section{padding:clamp(40px,10vw,80px) 0!important}
    .container{padding-left:clamp(16px,5vw,24px);padding-right:clamp(16px,5vw,24px)}
  }
  /* Touch-target safety for every card-level link/button reused on this page */
  @media (max-width: 720px){
    .product-card__cta,
    .product-card a.btn,
    .product-card__media{min-height:44px}
    .product-card__cta{padding:14px 18px;min-height:48px}
    .product-card__name{font-size:clamp(17px,4.4vw,21px)}
  }

  /* Stock states */
  .product-card__badge--soldout{background:#15171A!important;color:#fff!important}
  .product-card--soldout .product-card__media img{opacity:.55;filter:grayscale(.2)}
  .product-card__stock{margin:6px 0 0;font-size:12.5px;font-weight:600;color:#C2410C;letter-spacing:.01em}
</style>

<section class="page-hero">
    <div class="container">
        <span class="eyebrow">Shop</span>
        <h1>The full range.</h1>
    </div>
</section>

<section class="section" style="padding-bottom:0;">
    <div class="container">
        <% if (products && products.length) { %>
            <%- include('../partials/help-me-choose', { products: products }) %>
        <% } %>
    </div>
</section>

<section class="section">
    <div class="container">
        <% if (products.length === 0) { %>
            <p>No products yet.</p>
        <% } else { %>
            <div class="product-grid">
                <% products.forEach(function(product) { %>
                    <%- include('../partials/product-card', { product: product }) %>
                <% }); %>
            </div>
        <% } %>
    </div>
</section>
