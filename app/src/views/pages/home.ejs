    <script src="/js/main.js"></script>
    <script>
        // Hero banner carousel — auto-advance every 5s, pause on hover, dots + arrows + keyboard
        (() => {
            const root = document.getElementById('heroBanners');
            if (!root) return;
            const slides = Array.from(root.querySelectorAll('.hero-banners__slide'));
            const dots   = Array.from(root.querySelectorAll('.hero-banners__dot'));
            const prevBtn = document.getElementById('bannerPrev');
            const nextBtn = document.getElementById('bannerNext');
            const INTERVAL = 2000;
            let idx = 0, paused = false, timer = null, progressTimer = null, progressStart = 0;

            const setActive = (n) => {
                idx = (n + slides.length) % slides.length;
                slides.forEach((s, i) => {
                    const on = i === idx;
                    s.classList.toggle('is-active', on);
                    s.setAttribute('aria-hidden', String(!on));
                });
                dots.forEach((d, i) => {
                    const on = i === idx;
                    d.classList.toggle('is-active', on);
                    d.setAttribute('aria-selected', String(on));
                });
                resetProgress();
            };

            const next = () => setActive(idx + 1);
            const prev = () => setActive(idx - 1);

            const resetProgress = () => {
                root.style.setProperty('--p', '0%');
                progressStart = performance.now();
            };
            const tickProgress = () => {
                if (!paused) {
                    const elapsed = performance.now() - progressStart;
                    const pct = Math.min(100, (elapsed / INTERVAL) * 100);
                    root.style.setProperty('--p', pct + '%');
                }
                progressTimer = requestAnimationFrame(tickProgress);
            };

            const start = () => {
                stop();
                timer = setInterval(() => { if (!paused) next(); }, INTERVAL);
            };
            const stop = () => { if (timer) { clearInterval(timer); timer = null; } };

            // Manual controls
            nextBtn?.addEventListener('click', () => { setActive(idx + 1); start(); });
            prevBtn?.addEventListener('click', () => { setActive(idx - 1); start(); });
            dots.forEach((d) => d.addEventListener('click', () => {
                setActive(parseInt(d.dataset.go, 10) || 0);
                start();
            }));

            // Pause while hovering / focusing
            root.addEventListener('mouseenter', () => { paused = true; });
            root.addEventListener('mouseleave', () => { paused = false; progressStart = performance.now(); });
            root.addEventListener('focusin',   () => { paused = true; });
            root.addEventListener('focusout',  () => { paused = false; progressStart = performance.now(); });

            // Keyboard
            root.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowLeft')  { prev(); start(); }
                if (e.key === 'ArrowRight') { next(); start(); }
            });
            root.tabIndex = 0;

            // Pause when page tab hidden
            document.addEventListener('visibilitychange', () => {
                paused = document.hidden;
                if (!paused) progressStart = performance.now();
            });

            resetProgress();
            tickProgress();
            start();
        })();

        // Scroll progress bar
        (() => {
            const bar = document.getElementById('scrollProgress');
            if (!bar) return;
            const update = () => {
                const max = document.documentElement.scrollHeight - window.innerHeight;
                const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
                bar.style.width = pct + '%';
            };
            window.addEventListener('scroll', update, { passive: true });
            window.addEventListener('resize', update);
            update();
        })();

        // Word-by-word headline reveal
        (() => {
            const heads = document.querySelectorAll('[data-split]');
            if (!heads.length) return;
            const splitNode = (node) => {
                const out = document.createDocumentFragment();
                node.childNodes.forEach(child => {
                    if (child.nodeType === Node.TEXT_NODE) {
                        const parts = child.textContent.split(/(\s+)/);
                        parts.forEach(part => {
                            if (!part) return;
                            if (/^\s+$/.test(part)) {
                                out.appendChild(document.createTextNode(' '));
                            } else {
                                const w = document.createElement('span');
                                w.className = 'word';
                                w.textContent = part;
                                out.appendChild(w);
                            }
                        });
                    } else if (child.nodeType === Node.ELEMENT_NODE) {
                        if (child.tagName === 'BR') {
                            out.appendChild(child.cloneNode(true));
                        } else {
                            const w = document.createElement('span');
                            w.className = 'word';
                            w.appendChild(child.cloneNode(true));
                            out.appendChild(w);
                            out.appendChild(document.createTextNode(' '));
                        }
                    }
                });
                node.innerHTML = '';
                node.appendChild(out);
            };
            heads.forEach(h => {
                splitNode(h);
                h.querySelectorAll('.word').forEach((w, i) => {
                    w.style.transitionDelay = (i * 0.06) + 's';
                });
            });
            const io = new IntersectionObserver(entries => {
                entries.forEach(en => {
                    if (en.isIntersecting) {
                        en.target.classList.add('is-visible');
                        io.unobserve(en.target);
                    }
                });
            }, { threshold: 0.25 });
            heads.forEach(h => io.observe(h));
        })();
    </script>

    <script>
        (() => {
            const btn = document.getElementById("backToTop");
            if (!btn) return;
            const onScroll = () => btn.classList.toggle("is-visible", window.scrollY > 600);
            window.addEventListener("scroll", onScroll, { passive: true });
            btn.addEventListener("click", () => {
                if (window.lenis) window.lenis.scrollTo(0, { duration: 1.2 });
                else window.scrollTo({ top: 0, behavior: "smooth" });
            });
            onScroll();
        })();
    </script></body>
