<style>
  /* ============== CHECKOUT (shares design language with cart.ejs) ============== */
  :root {
    --sh-ink: #1c2a2a;
    --sh-ink-soft: #4a5a59;
    --sh-mute: #7a8a89;
    --sh-line: #e6ece9;
    --sh-line-strong: #d5ddd9;
    --sh-bg: #fbfaf7;
    --sh-card: #ffffff;
    --sh-sage: #23867F;
    --sh-sage-soft: #e6f1ef;
    --sh-success: #1f7a4f;
    --sh-danger: #b04545;
    --sh-radius: 16px;
    --sh-radius-sm: 12px;
    --sh-shadow-sm: 0 1px 2px rgba(28,42,42,.04);
    --sh-shadow-md: 0 6px 24px rgba(28,42,42,.06);
    --sh-shadow-lg: 0 16px 48px rgba(28,42,42,.08);
  }

  .sh-flow-hero { padding: 40px 0 8px; }
  .sh-flow-hero .eyebrow { color: var(--sh-mute); }
  .sh-flow-hero h1 { font-size: clamp(28px, 3.4vw, 40px); letter-spacing: -.01em; margin: 6px 0 0; }
  .sh-flow-hero .sh-steps {
    display: flex; gap: 18px; align-items: center; margin-top: 18px;
    color: var(--sh-mute); font-size: 13px; letter-spacing: .04em; text-transform: uppercase;
  }
  .sh-flow-hero .sh-steps span.is-active { color: var(--sh-ink); font-weight: 600; }
  .sh-flow-hero .sh-steps em { width: 24px; height: 1px; background: var(--sh-line-strong); display: inline-block; font-style: normal; }

  .co-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(340px, 1fr);
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 960px) { .co-grid { grid-template-columns: 1fr; gap: 24px; } }

  /* Form column */
  .co-form { display: grid; gap: 32px; }

  .co-section {
    background: var(--sh-card);
    border: 1px solid var(--sh-line);
    border-radius: var(--sh-radius);
    box-shadow: var(--sh-shadow-sm);
    padding: 32px;
  }
  @media (max-width: 640px) { .co-section { padding: 24px 20px; } }

  .co-section__head {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 22px;
  }
  .co-step {
    width: 32px; height: 32px; flex-shrink: 0;
    border-radius: 999px; background: var(--sh-ink); color: #fff;
    display: grid; place-items: center;
    font-size: 14px; font-weight: 600;
    letter-spacing: -.01em;
  }
  .co-section__title { margin: 0; font-size: 18px; letter-spacing: -.005em; color: var(--sh-ink); }
  .co-section__title small { display: block; color: var(--sh-mute); font-size: 12.5px; font-weight: 400; margin-top: 2px; letter-spacing: 0; }

  /* form grid */
  .co-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 16px 18px; }
  .co-fields .co-full { grid-column: 1 / -1; }
  @media (max-width: 560px) { .co-fields { grid-template-columns: 1fr; } }

  .co-field { display: flex; flex-direction: column; gap: 8px; }
  .co-field label,
  .co-field .co-label {
    font-size: 11.5px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--sh-ink-soft); font-weight: 600;
  }
  .co-field input,
  .co-field select,
  .co-field textarea {
    appearance: none;
    width: 100%;
    height: 50px;
    padding: 14px 16px;
    box-sizing: border-box;
    border: 1px solid var(--sh-line-strong);
    border-radius: 12px;
    background: #fff;
    font-size: 15px; color: var(--sh-ink);
    transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
  }
  .co-field input::placeholder { color: #a3aeac; }
  .co-field input:hover,
  .co-field select:hover { border-color: #bcc7c3; }
  .co-field input:focus,
  .co-field select:focus,
  .co-field textarea:focus {
    outline: none;
    border-color: var(--sh-sage);
    box-shadow: 0 0 0 4px rgba(35,134,127,.14);
  }

  /* payment radio cards */
  .co-pay { display: grid; gap: 12px; }
  .co-pay__option {
    position: relative;
    display: grid; grid-template-columns: 24px 1fr auto; gap: 14px;
    align-items: center;
    padding: 18px 20px;
    border: 1px solid var(--sh-line-strong);
    border-radius: 14px;
    background: #fff;
    cursor: pointer;
    transition: border-color .15s ease, background .15s ease, box-shadow .15s ease;
  }
  .co-pay__option:hover { border-color: #bcc7c3; }
  .co-pay__option input[type="radio"] {
    appearance: none;
    width: 20px; height: 20px;
    border: 1.5px solid var(--sh-line-strong);
    border-radius: 999px;
    cursor: pointer; margin: 0;
    display: grid; place-items: center;
    transition: border-color .15s ease;
  }
  .co-pay__option input[type="radio"]::after {
    content: ""; width: 10px; height: 10px;
    border-radius: 999px; background: var(--sh-sage);
    transform: scale(0); transition: transform .15s ease;
  }
  .co-pay__option input[type="radio"]:checked { border-color: var(--sh-sage); }
  .co-pay__option input[type="radio"]:checked::after { transform: scale(1); }
  .co-pay__option:has(input[type="radio"]:checked) {
    border-color: var(--sh-sage);
    background: var(--sh-sage-soft);
    box-shadow: 0 0 0 4px rgba(35,134,127,.08);
  }
  .co-pay__body { display: grid; gap: 4px; min-width: 0; }
  .co-pay__title { font-size: 15px; font-weight: 600; color: var(--sh-ink); }
  .co-pay__sub { font-size: 13px; color: var(--sh-ink-soft); }
  .co-pay__badges {
    display: inline-flex; gap: 6px; align-items: center;
    color: var(--sh-mute); font-size: 11px; letter-spacing: .08em; text-transform: uppercase;
  }
  .co-pay__badges svg { width: 18px; height: 18px; color: var(--sh-mute); }

  .co-pay__notice {
    padding: 14px 16px;
    background: #fff7e6; border: 1px solid #f3e0b3;
    border-radius: 12px; color: #6b5418; font-size: 13.5px;
  }
  .co-pay__notice code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; background: #fff; padding: 1px 6px; border-radius: 6px; border: 1px solid #ecdfb8; }

  /* place order button & note */
  .co-place {
    appearance: none; display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%;
    background: var(--sh-ink); color: #fff;
    border: 0; border-radius: 14px;
    padding: 20px 22px;
    font-size: 17px; font-weight: 600; letter-spacing: .01em;
    cursor: pointer;
    transition: transform .15s ease, box-shadow .15s ease, opacity .15s ease;
  }
  .co-place:hover:not(:disabled) { transform: translateY(-1px); box-shadow: var(--sh-shadow-md); }
  .co-place:disabled { opacity: .55; cursor: not-allowed; }
  .co-place svg { width: 18px; height: 18px; }

  .co-note {
    margin: 14px 0 0;
    text-align: center; font-size: 13px; color: var(--sh-danger); min-height: 18px;
  }
  .co-microcopy {
    margin: 12px 0 0; text-align: center;
    font-size: 12.5px; color: var(--sh-mute);
  }
  .co-microcopy a { color: var(--sh-ink-soft); text-decoration: underline; }

  /* trust strip */
  .co-trust {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    margin-top: 28px;
  }
  @media (max-width: 640px) { .co-trust { grid-template-columns: 1fr; } }
  .co-trust__item {
    display: flex; align-items: flex-start; gap: 12px;
    background: #fff; border: 1px solid var(--sh-line);
    border-radius: 12px; padding: 14px 16px;
  }
  .co-trust__icon {
    width: 32px; height: 32px; flex-shrink: 0;
    border-radius: 8px; background: var(--sh-sage-soft); color: var(--sh-sage);
    display: grid; place-items: center;
  }
  .co-trust__icon svg { width: 16px; height: 16px; }
  .co-trust__t { font-size: 13.5px; color: var(--sh-ink); font-weight: 600; }
  .co-trust__s { font-size: 12px; color: var(--sh-mute); margin-top: 2px; line-height: 1.4; }

  /* ============== SUMMARY CARD (mirrors cart.ejs) ============== */
  .summary-card {
    background: var(--sh-card);
    border: 1px solid var(--sh-line);
    border-radius: var(--sh-radius);
    box-shadow: var(--sh-shadow-md);
    padding: 28px;
    position: sticky;
    top: 96px;
  }
  .summary-card__title {
    margin: 0 0 18px;
    font-size: 17px; letter-spacing: -.005em;
    display: flex; align-items: center; justify-content: space-between;
  }
  .summary-card__title a {
    font-size: 13px; color: var(--sh-sage); text-decoration: none; font-weight: 500;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .summary-card__title a:hover { text-decoration: underline; }
  .summary-card__title a svg { width: 12px; height: 12px; }

  .coupon-chip {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--sh-sage-soft); color: var(--sh-sage);
    border: 1px solid rgba(35,134,127,.25);
    padding: 8px 12px; border-radius: 999px;
    font-size: 13px; font-weight: 600; letter-spacing: .02em;
    margin-bottom: 18px;
  }

  .summary-divider { height: 1px; background: var(--sh-line); margin: 0 0 18px; }

  .summary-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 10px 0;
    font-size: 14px; color: var(--sh-ink-soft);
  }
  .summary-row strong { color: var(--sh-ink); font-weight: 500; }
  .summary-row--discount { color: var(--sh-success); }
  .summary-row--discount strong { color: var(--sh-success); font-weight: 600; }
  .summary-row--total {
    padding-top: 18px; margin-top: 8px;
    border-top: 1px solid var(--sh-line);
    font-size: 16px; color: var(--sh-ink);
  }
  .summary-row--total strong { font-size: 24px; font-weight: 700; letter-spacing: -.015em; }
  .summary-row .muted { color: var(--sh-mute); font-size: 12px; }

  /* mini items */
  .mini-items { list-style: none; margin: 0 0 18px; padding: 0; display: grid; gap: 14px; max-height: 240px; overflow-y: auto; padding-right: 4px; }
  .mini-items::-webkit-scrollbar { width: 4px; }
  .mini-items::-webkit-scrollbar-thumb { background: var(--sh-line-strong); border-radius: 4px; }
  .mini-items li { display: grid; grid-template-columns: 52px 1fr auto; gap: 12px; align-items: center; }
  .mini-thumb {
    width: 52px; height: 52px; border-radius: 10px;
    background: #fff; border: 1px solid var(--sh-line);
    position: relative; overflow: hidden;
  }
  .mini-thumb img { width: 100%; height: 100%; object-fit: contain; padding: 4px; }
  .mini-thumb .mini-thumb__ph { width: 100%; height: 100%; display: grid; place-items: center; color: var(--sh-mute); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; }
  .mini-thumb .qty-badge {
    position: absolute; top: -6px; right: -6px;
    background: var(--sh-ink); color: #fff;
    font-size: 11px; font-weight: 700; line-height: 1;
    border-radius: 999px; min-width: 20px; height: 20px;
    display: inline-grid; place-items: center; padding: 0 6px;
    border: 2px solid #fff;
  }
  .mini-name { font-size: 13.5px; color: var(--sh-ink); line-height: 1.35; }
  .mini-meta { color: var(--sh-mute); font-size: 12px; margin-top: 2px; }
  .mini-price { font-size: 13.5px; font-weight: 600; color: var(--sh-ink); white-space: nowrap; }

  /* mobile summary collapse */
  .summary-collapse-toggle { display: none; }
  @media (max-width: 960px) {
    .summary-card { position: static; }
    .summary-collapse-toggle {
      display: flex; align-items: center; justify-content: space-between;
      width: 100%; padding: 14px 18px;
      background: var(--sh-sage-soft); border: 1px solid rgba(35,134,127,.2);
      border-radius: 12px; margin-bottom: 16px;
      font-size: 14px; color: var(--sh-ink); font-weight: 500;
      cursor: pointer;
    }
    .summary-collapse-toggle .chev { transition: transform .2s ease; }
    .summary-collapse-toggle[aria-expanded="true"] .chev { transform: rotate(180deg); }
    .summary-collapse-body[hidden] { display: none; }
  }

  /* ============== MOBILE UX TUNING ============== */
  @media (max-width: 960px) {
    /* Order: form first, summary after — aside is the 2nd grid child,
       which naturally stacks below on single-col. Lock it explicitly. */
    .co-grid > form { order: 1; }
    .co-grid > aside { order: 2; }

    /* Summary toggle ≥44px tap target */
    .summary-collapse-toggle {
      min-height: 52px;
      padding: 14px 18px;
      font-size: 15px;
    }
  }

  @media (max-width: 640px) {
    .sh-flow-hero { padding: 36px 0 4px; }
    .sh-flow-hero .sh-steps { gap: 10px; font-size: 11.5px; margin-top: 14px; flex-wrap: wrap; }
    .sh-flow-hero .sh-steps em { width: 16px; }

    .co-form { gap: 22px; }
    .co-section { padding: 24px 20px; border-radius: 16px; }

    /* Section numbered circles: 40px → 32px (already 32) — keep readable title */
    .co-step { width: 32px; height: 32px; font-size: 14px; }
    .co-section__head { gap: 12px; margin-bottom: 18px; }
    .co-section__title { font-size: 16.5px; }
    .co-section__title small { font-size: 12px; }

    /* Form inputs — 16px font-size to prevent iOS zoom, ≥48px tall,
       ≥14px vertical padding implicit via 48px height */
    .co-fields { gap: 16px 16px; }
    .co-field { gap: 8px; }
    .co-field label,
    .co-field .co-label { font-size: 11.5px; }
    .co-field input,
    .co-field select,
    .co-field textarea {
      height: 50px;
      padding: 14px 16px;
      font-size: 16px;
      border-radius: 12px;
    }

    /* Payment radio cards — ≥56px tall, comfortable padding */
    .co-pay { gap: 10px; }
    .co-pay__option {
      min-height: 64px;
      padding: 16px 16px;
      gap: 12px;
      border-radius: 14px;
      grid-template-columns: 22px 1fr auto;
    }
    .co-pay__option input[type="radio"] {
      width: 22px; height: 22px;
    }
    .co-pay__title { font-size: 15px; }
    .co-pay__sub { font-size: 12.5px; line-height: 1.4; }
    .co-pay__badges svg { width: 22px; height: 22px; }
    .co-pay__notice { font-size: 13px; padding: 14px; }

    /* Place order — full-width, ≥48px (we go ~58), 18px font */
    .co-place {
      padding: 18px 20px;
      font-size: 18px;
      min-height: 56px;
      border-radius: 14px;
    }
    .co-note { font-size: 13px; }
    .co-microcopy { font-size: 12.5px; line-height: 1.5; }
    .co-microcopy a { padding: 4px 0; display: inline-block; }

    /* Trust strip — stack vertically; icons stay ≥24px */
    .co-trust { grid-template-columns: 1fr; gap: 10px; margin-top: 22px; }
    .co-trust__item { padding: 12px 14px; border-radius: 12px; }
    .co-trust__icon { width: 36px; height: 36px; border-radius: 10px; }
    .co-trust__icon svg { width: 18px; height: 18px; }
    .co-trust__t { font-size: 14px; }
    .co-trust__s { font-size: 12.5px; }

    /* Summary card */
    .summary-card { padding: 24px 20px; border-radius: 16px; }
    .summary-card__title { font-size: 16px; margin-bottom: 16px; }

    /* Mini items: typography readable, name ≥14px, meta ≥13px */
    .mini-items { gap: 16px; max-height: 320px; margin-bottom: 16px; }
    .mini-items li { grid-template-columns: 56px 1fr auto; gap: 12px; }
    .mini-thumb { width: 56px; height: 56px; border-radius: 12px; }
    .mini-name { font-size: 14px; }
    .mini-meta { font-size: 13px; }
    .mini-price { font-size: 14px; }

    .summary-row { font-size: 14.5px; padding: 11px 0; }
    .summary-row--total strong { font-size: 22px; }

    .coupon-chip { font-size: 12.5px; padding: 8px 12px; }
  }

  /* Saved-address pre-fill banner — quick reassurance the form is auto-filled */
  .co-saved-addr-banner {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px;
    border-radius: 10px;
    background: #F4F9F8;
    border: 1px solid #DDECEB;
    color: var(--sh-ink);
    font-size: 13.5px;
    margin-bottom: 16px;
  }
  .co-saved-addr-banner svg { flex-shrink: 0; color: #23867F; }

  /* Larger phones — small spacing tweak */
  @media (max-width: 480px) {
    .co-section { padding: 22px 18px; }

    /* Sticky bottom "Place order" bar on mobile — always visible, never
       requires scrolling to find. Friction-killer. */
    .co-mobile-place {
      position: fixed; left: 0; right: 0; bottom: 0;
      background: #fff;
      border-top: 1px solid var(--sh-line);
      padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
      display: flex; align-items: center; gap: 12px;
      box-shadow: 0 -6px 20px rgba(0,0,0,0.06);
      z-index: 50;
    }
    .co-mobile-place__price { display: flex; flex-direction: column; line-height: 1.2; }
    .co-mobile-place__price small { font-size: 11px; color: var(--sh-mute); text-transform: uppercase; letter-spacing: 0.06em; }
    .co-mobile-place__price strong { font-size: 18px; color: var(--sh-ink); font-weight: 700; }
    .co-mobile-place__btn {
      flex: 1; height: 52px;
      background: var(--sh-ink); color: #fff;
      border: 0; border-radius: 12px;
      font-weight: 700; font-size: 15px;
      letter-spacing: .05em; text-transform: uppercase;
      cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    }
    /* push form content above the sticky bar (this <style> only loads on
       /checkout, so scoping isn't needed). */
    body { padding-bottom: 96px; }
  }
  @media (min-width: 641px) {
    .co-mobile-place { display: none; }
  }
</style>

<section class="page-hero sh-flow-hero">
  <div class="container">
    <span class="eyebrow">Step 2 of 2</span>
    <h1>Checkout</h1>
    <div class="sh-steps" aria-label="Checkout progress">
      <span><a href="/cart" style="color:inherit; text-decoration:none;">Cart</a></span>
      <em></em>
      <span class="is-active">Checkout</span>
      <em></em>
      <span>Confirmation</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="co-grid">

      <!-- LEFT: form -->
      <form id="checkoutForm" class="co-form" action="/checkout/cod" method="post" novalidate>

        <!-- 1. Contact -->
        <div class="co-section">
          <div class="co-section__head">
            <div class="co-step">1</div>
            <div>
              <h2 class="co-section__title">Contact</h2>
              <small>We'll send your order updates here</small>
            </div>
          </div>

          <div class="co-fields">
            <div class="co-field co-full">
              <label for="co-email">Email address</label>
              <input id="co-email" type="email" name="email" autocomplete="email" placeholder="you@example.com" value="<%= (currentUser && currentUser.email) ? currentUser.email : '' %>">
            </div>
          </div>
        </div>

        <!-- 2. Shipping address -->
        <div class="co-section">
          <div class="co-section__head">
            <div class="co-step">2</div>
            <div>
              <h2 class="co-section__title">Shipping address</h2>
              <small>Where should we deliver your order?</small>
            </div>
          </div>

          <% const defAddr = (addresses && addresses.length) ? addresses[0] : null; %>
          <% if (defAddr) { %>
            <div class="co-saved-addr-banner">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 6.5c0 4-5.5 7.5-5.5 7.5S2.5 10.5 2.5 6.5a5.5 5.5 0 1 1 11 0Z"/><circle cx="8" cy="6.5" r="2"/></svg>
              <span>Using your saved address — edit any field to ship somewhere new.</span>
            </div>
          <% } %>
          <div class="co-fields">
            <div class="co-field">
              <label for="co-name">Full name</label>
              <input id="co-name" name="address[fullName]" autocomplete="name" required value="<%= defAddr ? defAddr.fullName : ((currentUser && currentUser.name) ? currentUser.name : '') %>">
            </div>
            <div class="co-field">
              <label for="co-phone">Phone</label>
              <input id="co-phone" name="address[phone]" autocomplete="tel" required value="<%= defAddr ? defAddr.phone || '' : ((currentUser && currentUser.phone) ? currentUser.phone : '') %>">
            </div>
            <div class="co-field co-full">
              <label for="co-line1">Address line 1</label>
              <input id="co-line1" name="address[line1]" autocomplete="address-line1" placeholder="House / flat, street" required value="<%= defAddr ? defAddr.line1 : '' %>">
            </div>
            <div class="co-field co-full">
              <label for="co-line2">Apartment, suite, landmark <span style="text-transform:none; letter-spacing:0; color:var(--sh-mute); font-weight:400;">(optional)</span></label>
              <input id="co-line2" name="address[line2]" autocomplete="address-line2" placeholder="Apt, suite, landmark" value="<%= defAddr ? defAddr.line2 || '' : '' %>">
            </div>
            <div class="co-field">
              <label for="co-city">City</label>
              <input id="co-city" name="address[city]" autocomplete="address-level2" required value="<%= defAddr ? defAddr.city : '' %>">
            </div>
            <div class="co-field">
              <label for="co-state">State</label>
              <input id="co-state" name="address[state]" autocomplete="address-level1" required value="<%= defAddr ? defAddr.state : '' %>">
            </div>
            <div class="co-field">
              <label for="co-postcode">Postal code</label>
              <input id="co-postcode" name="address[postcode]" autocomplete="postal-code" inputmode="numeric" required value="<%= defAddr ? defAddr.postcode : '' %>">
            </div>
            <div class="co-field">
              <label for="co-country">Country</label>
              <input id="co-country" name="address[country]" autocomplete="country-name" value="<%= defAddr ? defAddr.country : 'India' %>" required>
            </div>
          </div>
        </div>

        <!-- 3. Payment -->
        <div class="co-section">
          <div class="co-section__head">
            <div class="co-step">3</div>
            <div>
              <h2 class="co-section__title">Payment method</h2>
              <small>All transactions are secure and encrypted</small>
            </div>
          </div>

          <div class="co-pay">
            <% if (razorpayEnabled) { %>
              <label class="co-pay__option">
                <input type="radio" name="payMethod" value="razorpay" checked>
                <div class="co-pay__body">
                  <span class="co-pay__title">Pay online · Razorpay</span>
                  <span class="co-pay__sub">UPI · Cards · Wallets · Netbanking · EMI</span>
                </div>
                <span class="co-pay__badges" aria-hidden="true">
                  <svg viewBox="0 0 24 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1" y="1" width="22" height="14" rx="2"/><path d="M1 6h22"/></svg>
                </span>
              </label>
            <% } else { %>
              <div class="co-pay__notice">
                Online payment via Razorpay is not configured. Set <code>RAZORPAY_KEY_ID</code> + <code>RAZORPAY_KEY_SECRET</code> in <code>app/.env</code> and restart to enable it. Cash on Delivery is available right now.
              </div>
            <% } %>

            <label class="co-pay__option">
              <input type="radio" name="payMethod" value="cod" <%= !razorpayEnabled ? 'checked' : '' %>>
              <div class="co-pay__body">
                <span class="co-pay__title">Cash on Delivery</span>
                <span class="co-pay__sub">Pay in cash when the courier arrives at your door.</span>
              </div>
              <span class="co-pay__badges" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="13" rx="2"/><circle cx="12" cy="12.5" r="2.5"/></svg>
              </span>
            </label>
          </div>
        </div>

        <!-- 4. Review & place order -->
        <div class="co-section">
          <div class="co-section__head">
            <div class="co-step">4</div>
            <div>
              <h2 class="co-section__title">Review &amp; place order</h2>
              <small>You'll be charged <strong style="color:var(--sh-ink);"><%= formatINR(totals.totalInPaise) %></strong> · review your summary on the right</small>
            </div>
          </div>

          <button type="submit" id="payBtn" class="co-place">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="10" height="7" rx="1.5"/><path d="M5 7V5a3 3 0 0 1 6 0v2"/></svg>
            Place order · <%= formatINR(totals.totalInPaise) %>
          </button>
          <p class="co-note" id="checkoutMsg" role="status"></p>
          <p class="co-microcopy">By placing the order you agree to our <a href="/terms">Terms</a> and <a href="/privacy">Privacy Policy</a>.</p>

          <!-- trust strip -->
          <div class="co-trust">
            <div class="co-trust__item">
              <span class="co-trust__icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2 3 4v4c0 3.4 2.2 5.7 5 6 2.8-.3 5-2.6 5-6V4l-5-2Z"/><path d="m6 8 1.5 1.5L10 7"/></svg></span>
              <div><div class="co-trust__t">Secure SSL</div><div class="co-trust__s">256-bit encrypted checkout</div></div>
            </div>
            <div class="co-trust__item">
              <span class="co-trust__icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8a5 5 0 0 1 9-3"/><path d="M12 3v3h-3"/><path d="M13 8a5 5 0 0 1-9 3"/><path d="M4 13v-3h3"/></svg></span>
              <div><div class="co-trust__t">14-day returns</div><div class="co-trust__s">No questions asked</div></div>
            </div>
            <div class="co-trust__item">
              <span class="co-trust__icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h9l2 3v3h-2"/><circle cx="6" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><path d="M3 5v7h1"/></svg></span>
              <div><div class="co-trust__t">Fast delivery</div><div class="co-trust__s">Ships within 24 hours</div></div>
            </div>
          </div>
        </div>
      </form>

      <!-- MOBILE-ONLY sticky bottom Place Order bar (always visible — no need
           to scroll to the section-4 button OR expand the summary). The button
           submits the main checkout form via form="checkoutForm". -->
      <div class="co-mobile-place" aria-hidden="false">
        <div class="co-mobile-place__price">
          <small>Total</small>
          <strong><%= formatINR(totals.totalInPaise) %></strong>
        </div>
        <button type="submit" form="checkoutForm" class="co-mobile-place__btn">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="10" height="7" rx="1.5"/><path d="M5 7V5a3 3 0 0 1 6 0v2"/></svg>
          Place order
        </button>
      </div>

      <!-- RIGHT: order summary -->
      <aside aria-label="Order summary">
        <button class="summary-collapse-toggle" type="button" aria-expanded="false" aria-controls="co-summary-body" data-summary-toggle>
          <span>Order summary · <strong><%= formatINR(totals.totalInPaise) %></strong></span>
          <svg class="chev" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m4 6 4 4 4-4"/></svg>
        </button>

        <div class="summary-card summary-collapse-body" id="co-summary-body" hidden>
          <h3 class="summary-card__title">
            <span>Order summary</span>
            <a href="/cart">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 3 4 10v3h3l7-7-3-3Z"/></svg>
              Edit
            </a>
          </h3>

          <% if (coupon) { %>
            <div class="coupon-chip">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1a1.5 1.5 0 0 0 0 3v1a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-1a1.5 1.5 0 0 0 0-3V6Z"/></svg>
              <%= coupon.code %> applied
            </div>
          <% } %>

          <ul class="mini-items">
            <% items.forEach(function(it) { %>
              <li>
                <div class="mini-thumb">
                  <% if (it.product.images && it.product.images[0]) { %>
                    <img src="<%= it.product.images[0].url %>" alt="<%= it.product.name %>">
                  <% } else { %>
                    <div class="mini-thumb__ph">Shiōrra</div>
                  <% } %>
                  <span class="qty-badge"><%= it.quantity %></span>
                </div>
                <div>
                  <div class="mini-name"><%= it.product.name %></div>
                  <div class="mini-meta"><%= formatINR(it.product.priceInPaise) %> each</div>
                </div>
                <div class="mini-price"><%= formatINR(it.subtotalInPaise) %></div>
              </li>
            <% }); %>
          </ul>

          <div class="summary-divider"></div>

          <div class="summary-row">
            <span>Subtotal</span>
            <strong><%= formatINR(totals.subtotalInPaise) %></strong>
          </div>
          <% if (totals.discountInPaise > 0) { %>
            <div class="summary-row summary-row--discount">
              <span>Discount<% if (coupon) { %> · <%= coupon.code %><% } %></span>
              <strong>− <%= formatINR(totals.discountInPaise) %></strong>
            </div>
          <% } %>
          <div class="summary-row">
            <span>Shipping</span>
            <strong><%= totals.shippingInPaise === 0 ? 'Free' : formatINR(totals.shippingInPaise) %></strong>
          </div>
          <div class="summary-row">
            <span>Tax</span>
            <span class="muted">Included</span>
          </div>
          <div class="summary-row summary-row--total">
            <span>Total</span>
            <strong><%= formatINR(totals.totalInPaise) %></strong>
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>

<% if (razorpayEnabled) { %>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<% } %>
<script>
(function() {
    const form = document.getElementById('checkoutForm');
    const btn  = document.getElementById('payBtn');
    const msg  = document.getElementById('checkoutMsg');
    const razorpayEnabled = <%- razorpayEnabled ? 'true' : 'false' %>;

    // Mobile summary toggle
    document.querySelectorAll('[data-summary-toggle]').forEach(function (t) {
      var id = t.getAttribute('aria-controls');
      var body = id ? document.getElementById(id) : null;
      if (!body) return;
      var apply = function () {
        if (window.matchMedia('(max-width: 960px)').matches) {
          var expanded = t.getAttribute('aria-expanded') === 'true';
          body.hidden = !expanded;
        } else {
          body.hidden = false;
        }
      };
      t.addEventListener('click', function () {
        var expanded = t.getAttribute('aria-expanded') === 'true';
        t.setAttribute('aria-expanded', String(!expanded));
        apply();
      });
      window.addEventListener('resize', apply);
      apply();
    });

    form.addEventListener('submit', async (e) => {
        const method = (form.querySelector('input[name="payMethod"]:checked') || {}).value || 'cod';

        // COD = let the form submit natively
        if (method === 'cod') return;

        // Razorpay path
        e.preventDefault();
        if (!razorpayEnabled) {
            msg.textContent = 'Online payment is not configured. Please pick Cash on Delivery.';
            return;
        }
        btn.disabled = true;
        msg.textContent = '';
        const fd = new FormData(form);
        const payload = { address: {} };
        for (const [k, v] of fd.entries()) {
            const m = k.match(/^address\[(\w+)\]$/);
            if (m) payload.address[m[1]] = v;
        }
        try {
            const r = await fetch('/checkout/create-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
            const data = await r.json();
            if (!r.ok) throw new Error(data.error || 'Failed to create order');

            const options = {
                key: data.key,
                amount: data.amount,
                currency: data.currency,
                name: data.name,
                description: data.description,
                order_id: data.orderId,
                prefill: data.prefill,
                theme: { color: '#23867F' },
                handler: async function (resp) {
                    msg.textContent = 'Verifying payment…';
                    const v = await fetch('/checkout/verify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(resp),
                    });
                    const vd = await v.json();
                    if (v.ok && vd.redirect) window.location.href = vd.redirect;
                    else { msg.textContent = vd.error || 'Payment verification failed'; btn.disabled = false; }
                },
                modal: {
                    ondismiss: function () {
                        msg.textContent = 'Payment cancelled. You can try again.';
                        btn.disabled = false;
                    }
                }
            };
            const rzp = new Razorpay(options);
            rzp.open();
        } catch (err) {
            msg.textContent = err.message;
            btn.disabled = false;
        }
    });
})();
</script>
