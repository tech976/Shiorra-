<section class="page-hero">
    <div class="container">
        <span class="eyebrow">Checkout</span>
        <h1>Place your order</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="checkout">
            <form id="checkoutForm" class="checkout__form" action="/checkout/cod" method="post">
                <h3>Shipping address</h3>
                <div class="form-grid">
                    <label>Full name<input name="address[fullName]" required value="<%= currentUser.name || '' %>"></label>
                    <label>Phone<input name="address[phone]" required value="<%= currentUser.phone || '' %>"></label>
                    <label class="form-grid__full">Address line 1<input name="address[line1]" required></label>
                    <label class="form-grid__full">Address line 2 (optional)<input name="address[line2]"></label>
                    <label>City<input name="address[city]" required></label>
                    <label>State<input name="address[state]" required></label>
                    <label>Postcode<input name="address[postcode]" required></label>
                    <label>Country<input name="address[country]" value="India" required></label>
                </div>

                <h3>Payment</h3>
                <div class="checkout__pay-options">
                    <% if (razorpayEnabled) { %>
                        <label class="checkout__pay-option">
                            <input type="radio" name="payMethod" value="razorpay" checked>
                            <span class="checkout__pay-title">Online (Razorpay)</span>
                            <span class="checkout__pay-sub">UPI · Cards · Wallets · Netbanking</span>
                        </label>
                    <% } else { %>
                        <p class="form-hint">
                            Online payment via Razorpay is not configured. Set
                            <code>RAZORPAY_KEY_ID</code> + <code>RAZORPAY_KEY_SECRET</code>
                            in <code>app/.env</code> and restart to enable it. Cash on Delivery is
                            available right now.
                        </p>
                    <% } %>
                    <label class="checkout__pay-option">
                        <input type="radio" name="payMethod" value="cod" <%= !razorpayEnabled ? 'checked' : '' %>>
                        <span class="checkout__pay-title">Cash on Delivery</span>
                        <span class="checkout__pay-sub">Pay in cash when the courier arrives.</span>
                    </label>
                </div>

                <button type="submit" id="payBtn" class="btn btn--lg btn--full">Place order · <%= formatINR(totals.totalInPaise) %></button>
                <p class="checkout__note" id="checkoutMsg"></p>
            </form>

            <aside class="checkout__summary">
                <h3>Order summary</h3>
                <ul class="checkout__items">
                    <% items.forEach(function(it) { %>
                        <li>
                            <span><%= it.product.name %> × <%= it.quantity %></span>
                            <span><%= formatINR(it.subtotalInPaise) %></span>
                        </li>
                    <% }); %>
                </ul>
                <div class="cart__row"><span>Subtotal</span><span><%= formatINR(totals.subtotalInPaise) %></span></div>
                <div class="cart__row"><span>Shipping</span><span><%= totals.shippingInPaise === 0 ? 'Free' : formatINR(totals.shippingInPaise) %></span></div>
                <div class="cart__row cart__row--total"><span>Total</span><span><%= formatINR(totals.totalInPaise) %></span></div>
            </aside>
        </div>
    </div>
</section>

<% if (razorpayEnabled) { %>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<% } %>
<script>
(function() {
    const form = document.getElementById('checkoutForm');
    const btn  = document.getElementById('payBtn');
    const msg  = document.getElementById('checkoutMsg');
    const razorpayEnabled = <%- razorpayEnabled ? 'true' : 'false' %>;

    form.addEventListener('submit', async (e) => {
        const method = (form.querySelector('input[name="payMethod"]:checked') || {}).value || 'cod';

        // COD = let the form submit natively
        if (method === 'cod') return;

        // Razorpay path
        e.preventDefault();
        if (!razorpayEnabled) {
            msg.textContent = 'Online payment is not configured. Please pick Cash on Delivery.';
            return;
        }
        btn.disabled = true;
        msg.textContent = '';
        const fd = new FormData(form);
        const payload = { address: {} };
        for (const [k, v] of fd.entries()) {
            const m = k.match(/^address\[(\w+)\]$/);
            if (m) payload.address[m[1]] = v;
        }
        try {
            const r = await fetch('/checkout/create-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
            const data = await r.json();
            if (!r.ok) throw new Error(data.error || 'Failed to create order');

            const options = {
                key: data.key,
                amount: data.amount,
                currency: data.currency,
                name: data.name,
                description: data.description,
                order_id: data.orderId,
                prefill: data.prefill,
                theme: { color: '#23867F' },
                handler: async function (resp) {
                    msg.textContent = 'Verifying payment…';
                    const v = await fetch('/checkout/verify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(resp),
                    });
                    const vd = await v.json();
                    if (v.ok && vd.redirect) window.location.href = vd.redirect;
                    else { msg.textContent = vd.error || 'Payment verification failed'; btn.disabled = false; }
                },
                modal: {
                    ondismiss: function () {
                        msg.textContent = 'Payment cancelled. You can try again.';
                        btn.disabled = false;
                    }
                }
            };
            const rzp = new Razorpay(options);
            rzp.open();
        } catch (err) {
            msg.textContent = err.message;
            btn.disabled = false;
        }
    });
})();
</script>
