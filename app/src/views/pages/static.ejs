<style>
    .static-page {
        background: #fff;
        padding: clamp(48px, 8vw, 96px) 0 clamp(64px, 10vw, 120px);
        min-height: 60vh;
    }
    .static-page .container { max-width: 720px; }
    .static-page__eyebrow {
        display: inline-block;
        font-size: 11px; font-weight: 700;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: #6B6B6B;
        margin-bottom: 16px;
    }
    .static-page h1 {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        font-size: clamp(34px, 5vw, 52px);
        font-weight: 700;
        line-height: 1.1;
        color: #1A1A1A;
        margin: 0 0 12px;
        letter-spacing: -0.02em;
    }
    .static-page__sub {
        font-size: 16px;
        color: #6B6B6B;
        margin: 0 0 40px;
    }
    .static-page__body {
        font-size: 16px;
        line-height: 1.75;
        color: #2A2A2A;
    }
    .static-page__body p { margin: 0 0 18px; }
    .static-page__body h2 {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        font-size: clamp(20px, 2.6vw, 26px);
        font-weight: 700;
        line-height: 1.2;
        color: #1A1A1A;
        margin: 32px 0 14px;
        letter-spacing: -0.015em;
    }
    .static-page__body a {
        color: #23867F;
        text-decoration: none;
        border-bottom: 1px solid currentColor;
        transition: color 160ms ease;
    }
    .static-page__body a:hover { color: #1B6E68; }
    .static-page__body .btn {
        border-bottom: 0;
        margin-top: 14px;
    }
    @media (max-width: 640px) {
        .static-page .container { padding-left: 20px; padding-right: 20px; }
    }
</style>

<section class="static-page">
    <div class="container">
        <span class="static-page__eyebrow"><%= sub %></span>
        <h1><%= heading %></h1>
        <div class="static-page__body"><%- body %></div>
    </div>
</section>
