    <script src="/js/main.js"></script>
    <script>
        (() => {
            const scroller = document.getElementById('videoScroller');
            const prev = document.getElementById('videoPrev');
            const next = document.getElementById('videoNext');
            if (!scroller) return;
            const step = () => {
                const card = scroller.querySelector('.video-card'); if (!card) return scroller.clientWidth * 0.8;
                const gap = parseFloat(getComputedStyle(scroller).columnGap) || 22;
                return card.getBoundingClientRect().width + gap;
            };
            prev && prev.addEventListener('click', () => scroller.scrollBy({ left: -step(), behavior: 'smooth' }));
            next && next.addEventListener('click', () => scroller.scrollBy({ left:  step(), behavior: 'smooth' }));
        })();
        (() => {
            const bar = document.getElementById('scrollProgress'); if (!bar) return;
            const update = () => { const m = document.documentElement.scrollHeight - window.innerHeight; bar.style.width = (m > 0 ? (window.scrollY / m) * 100 : 0) + '%'; };
            window.addEventListener('scroll', update, { passive: true }); window.addEventListener('resize', update); update();
        })();
        (() => {
            const heads = document.querySelectorAll('[data-split]'); if (!heads.length) return;
            const splitNode = (node) => {
                const out = document.createDocumentFragment();
                node.childNodes.forEach(child => {
                    if (child.nodeType === Node.TEXT_NODE) {
                        child.textContent.split(/(\s+)/).forEach(part => { if (!part) return; if (/^\s+$/.test(part)) out.appendChild(document.createTextNode(' ')); else { const w = document.createElement('span'); w.className = 'word'; w.textContent = part; out.appendChild(w); } });
                    } else if (child.nodeType === Node.ELEMENT_NODE) {
                        if (child.tagName === 'BR') out.appendChild(child.cloneNode(true));
                        else { const w = document.createElement('span'); w.className = 'word'; w.appendChild(child.cloneNode(true)); out.appendChild(w); out.appendChild(document.createTextNode(' ')); }
                    }
                });
                node.innerHTML = ''; node.appendChild(out);
            };
            heads.forEach(h => { splitNode(h); h.querySelectorAll('.word').forEach((w, i) => w.style.transitionDelay = (i * 0.06) + 's'); });
            const io = new IntersectionObserver(entries => entries.forEach(en => { if (en.isIntersecting) { en.target.classList.add('is-visible'); io.unobserve(en.target); } }), { threshold: 0.25 });
            heads.forEach(h => io.observe(h));
        })();
    </script>

    <script>
        (() => {
            const btn = document.getElementById("backToTop");
            if (!btn) return;
            const onScroll = () => btn.classList.toggle("is-visible", window.scrollY > 600);
            window.addEventListener("scroll", onScroll, { passive: true });
            btn.addEventListener("click", () => {
                if (window.lenis) window.lenis.scrollTo(0, { duration: 1.2 });
                else window.scrollTo({ top: 0, behavior: "smooth" });
            });
            onScroll();
        })();
    </script></body>
