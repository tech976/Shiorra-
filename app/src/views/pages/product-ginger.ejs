<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Advanced Ginger+ · Shiōrra · Gentle Pregnancy Support</title>
<meta name="description" content="Shiōrra Advanced Ginger+ — Standardized Ginger Extract + Active Vitamin B6 (P5P) + Vitamin B1 + Magnesium Bisglycinate. Eases nausea, supports digestion, gentle on stomach. A trademark of K.C. Laboratories." />
<link rel="shortcut icon" type="image/png" href="/img/logo/logo-green.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    /* Ginger+ product accent — forest green (calm / digestive) */
    --honey:#2E8B57;
    --honey-2:#1F6B43;
    --honey-deep:#144B30;
    --honey-soft:#E0F0E5;
    --charcoal:#282828;
    --charcoal-2:#3A3A3A;
    --ink:#282828;
    --ink-soft:#3A3A3A;
    --white:#FFFFFF;
    --surface:#F7F7F8;
    --surface-2:#FBFBFC;
    --line:#E5E5E7;
    --line-soft:#F0F0F2;
    --muted:#6B6B6B;
    --muted-2:#8A8A8A;
    --green:#1E9E5C;
    --shadow-sm:0 2px 6px rgba(40,40,40,.06);
    --shadow-md:0 8px 24px rgba(40,40,40,.08);
  }
  html{scroll-behavior:smooth;overflow-x:clip}
  body{
    font-family:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
    color:var(--ink);background:#fff;line-height:1.55;font-size:15px;
    overflow-x:clip;padding-bottom:88px;
  }
  @media(max-width:720px){body{padding-bottom:84px}}
  img{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  button{font:inherit;cursor:pointer;border:0;background:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 20px}

  /* Marquee */
  .marquee{background:var(--charcoal);color:#fff;padding:10px 0;overflow:hidden;border-bottom:1px solid var(--line)}
  .marquee-track{display:flex;gap:48px;width:max-content;animation:marquee 36s linear infinite;font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}
  .marquee-item{display:inline-flex;align-items:center;gap:8px}
  .marquee-item svg{width:14px;height:14px;color:var(--honey)}
  .marquee-item .accent{color:var(--honey)}
  @keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* Microbar */
  .microbar{background:var(--surface);border-bottom:1px solid var(--line);padding:8px 0;font-size:12px;color:var(--ink-soft);font-weight:500}
  .microbar-inner{display:flex;justify-content:center;gap:32px;flex-wrap:wrap}
  .microbar-item{display:inline-flex;align-items:center;gap:6px}
  .microbar-item svg{width:14px;height:14px;color:var(--honey)}

  /* Hero */
  .product-hero{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:48px 0 64px;position:relative;overflow:hidden}
  .product-hero::before{content:'';position:absolute;top:-100px;right:-100px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(46,139,87,.18) 0%,transparent 70%);pointer-events:none}
  .product-hero-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:48px;align-items:start;position:relative}
  @media(max-width:880px){.product-hero-grid{grid-template-columns:1fr;gap:28px}}
  .gallery{position:sticky;top:88px}
  @media(max-width:880px){.gallery{position:static}}
  .gallery-main{aspect-ratio:4/5;width:100%;background:#fff;border-radius:22px;border:1px solid var(--line);display:grid;place-items:center;overflow:hidden;position:relative}
  .gallery-main img{width:100%;height:100%;object-fit:cover;object-position:center}
  .gallery-thumbs{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:10px}
  .gallery-thumb{aspect-ratio:4/5;background:#fff;border:1.5px solid var(--line);border-radius:12px;overflow:hidden;cursor:pointer;padding:0;transition:border-color .2s,transform .2s}
  .gallery-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s ease}
  .gallery-thumb:hover{border-color:var(--honey);transform:translateY(-1px)}
  .gallery-thumb.is-active{border-color:var(--honey);box-shadow:0 0 0 3px var(--honey-soft) inset}
  .float-badge{position:absolute;background:#fff;border-radius:18px;padding:10px 16px;font-size:12px;font-weight:700;box-shadow:0 8px 22px rgba(40,40,40,.10);display:inline-flex;align-items:center;gap:10px;z-index:2;color:var(--ink)}
  .float-1{top:18px;left:18px} .float-2{bottom:18px;right:18px}
  .float-1-icon{width:28px;height:28px;border-radius:50%;background:var(--honey);color:#fff;display:grid;place-items:center;font-weight:800;font-size:13px}
  .pulse-dot{width:10px;height:10px;border-radius:50%;background:var(--honey);animation:pulse 1.6s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.55}}

  /* Product info — "quiet pharmacy editorial" */
  .info{padding-top:8px}
  .pi-kicker{display:block;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--honey-deep);margin-bottom:10px}
  .pi-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:52px;font-weight:700;line-height:1.02;letter-spacing:-0.03em;color:var(--ink);margin-bottom:14px;text-wrap:balance}
  .pi-title em{font-style:normal;color:var(--honey);font-weight:700}
  @media(max-width:680px){.pi-title{font-size:38px}}
  .pi-sub{font-size:16px;color:var(--ink-soft);font-style:normal;font-weight:400;line-height:1.6;margin-bottom:20px;max-width:520px;text-align:left;hyphens:none;word-break:normal;overflow-wrap:normal}
  .pi-proof{display:flex;align-items:baseline;gap:7px;margin-bottom:10px;font-size:13px;line-height:1}
  .pi-proof__star{color:var(--honey);font-size:13px}
  .pi-proof__score{font-weight:600;color:var(--ink)}
  .pi-proof__count{font-weight:400;color:var(--muted);text-decoration:underline;text-underline-offset:3px}
  .pi-proof__count:hover{color:var(--ink)}
  .pi-claims{font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#8A8A8A;margin-bottom:28px;line-height:1.8}
  .pi-commerce{display:flex;align-items:center;justify-content:space-between;gap:16px}
  .pi-price-line{display:flex;flex-direction:column;gap:3px}
  .pi-price-now{font-family:'Helvetica Neue',Arial,sans-serif;font-size:22px;font-weight:700;letter-spacing:-0.01em;color:var(--ink);line-height:1}
  .pi-price-meta{font-size:13px;color:#8A8A8A;font-weight:400}
  .pi-price-meta s{text-decoration:line-through}
  .pi-qty{display:inline-flex;align-items:center;border:1px solid var(--line);border-radius:12px;background:#fff;overflow:hidden}
  .pi-qty button{width:38px;height:46px;font-size:18px;color:var(--ink);font-weight:700}
  .pi-qty input{width:44px;height:46px;border:0;text-align:center;font-size:15px;font-weight:700;font-family:inherit;background:transparent}
  .pi-qty input::-webkit-inner-spin-button{display:none}
  .pi-buy-row{display:flex;gap:10px;margin:0}
  .pi-add{flex:1;height:50px;display:inline-flex;align-items:center;justify-content:center;background:var(--charcoal);color:#fff;font-weight:700;font-size:14px;letter-spacing:.04em;border-radius:12px;text-transform:uppercase;transition:background .2s,transform .2s;border:0;cursor:pointer}
  .pi-add:hover{background:var(--charcoal-2);transform:translateY(-1px)}
  .pi-add-secondary{height:50px;display:inline-flex;align-items:center;justify-content:center;background:transparent;color:var(--ink);font-weight:700;font-size:14px;letter-spacing:.04em;border:1px solid var(--ink);border-radius:12px;cursor:pointer;text-transform:uppercase;transition:background .2s,color .2s}
  .pi-add-secondary:hover{background:var(--ink);color:#fff}
  .pi-footnote{margin-top:20px;padding-top:16px;border-top:1px solid var(--line-soft,#EFEFEF);font-size:12px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:#8A8A8A;line-height:1.7}
  /* Benefit bullets — soft circular check + clean type. List, not grid, so long
     copy can breathe without truncating. */
  .pi-points{margin-top:18px;display:flex;flex-direction:column;gap:10px;padding:0}
  .pi-points li{display:flex;align-items:center;gap:12px;font-size:14.5px;list-style:none;color:var(--ink);font-weight:500;line-height:1.35}
  .pi-points__check{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:var(--honey-soft);color:var(--honey-deep);flex-shrink:0}
  .pi-points__check svg{width:12px;height:12px}
  /* Benefits illustration — single composite graphic */
  .pi-benefits{margin:28px 0 0;border-radius:14px;overflow:hidden;background:#fff}
  .pi-benefits img{display:block;width:100%;height:auto}

  /* Section */
  section.s{padding:72px 0;font-size:17px;position:relative}
  @media(max-width:680px){section.s{padding:56px 0}}
  .s-eyebrow{display:inline-flex;align-items:center;background:var(--honey-soft);color:var(--honey-deep);font-size:12px;font-weight:800;padding:8px 16px;border-radius:24px;letter-spacing:.10em;text-transform:uppercase;margin-bottom:16px}
  .s-title{font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:48px;font-weight:700;line-height:1.05;letter-spacing:-0.025em;margin-bottom:16px;max-width:760px;color:var(--charcoal);text-wrap:balance}
  .s-title em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.s-title{font-size:36px}}
  .s-sub{font-size:17px;color:var(--ink-soft);max-width:640px;line-height:1.6}
  .s-head{margin-bottom:40px}
  .s-head.center{text-align:center}
  .s-head.center .s-title,.s-head.center .s-sub{margin-left:auto;margin-right:auto}

  /* Symptoms */
  .symptoms-bg{background:#fff}
  .symptoms-figure,.actives-figure,.bvitamins-figure{margin:0;border-radius:18px;overflow:hidden;background:#fff}
  .symptoms-figure img,.actives-figure img,.bvitamins-figure img{display:block;width:100%;height:auto}
  .symptoms-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media(max-width:880px){.symptoms-grid{grid-template-columns:repeat(2,1fr)}}
  .symptom-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;transition:transform .3s ease,box-shadow .3s ease;position:relative}
  .symptom-card:hover{transform:translateY(-5px);box-shadow:0 18px 40px rgba(40,40,40,.10)}
  .symptom-card .ic{width:64px;height:64px;border-radius:18px;background:#F7F7F8;color:var(--ink);display:grid;place-items:center;margin-bottom:18px}
  .symptom-card .ic svg{width:30px;height:30px;stroke-width:2.2}
  .symptom-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;font-weight:700;margin-bottom:6px;color:var(--ink)}
  .symptom-card p{font-size:14px;color:var(--muted);line-height:1.5}

  /* Power team */
  .power-bg{background:#fff}
  .power-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;align-items:stretch}
  @media(max-width:880px){.power-grid{grid-template-columns:1fr}}
  .power-card{background:#fff;border:1px solid var(--line);border-radius:24px;padding:34px;position:relative;transition:transform .3s ease,box-shadow .3s ease}
  .power-card:hover{transform:translateY(-4px);box-shadow:0 22px 48px rgba(40,40,40,.10)}
  .power-card .pc-eye{display:inline-flex;align-items:center;background:var(--honey-soft);color:var(--honey-deep);font-size:11px;font-weight:800;padding:6px 12px;border-radius:16px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px}
  .power-card .pc-icon{width:72px;height:72px;border-radius:22px;background:#F7F7F8;color:var(--ink);display:grid;place-items:center;margin-bottom:18px}
  .power-card .pc-icon svg{width:36px;height:36px;stroke-width:2.2}
  .power-card h3{font-family:'Helvetica Neue',Arial,sans-serif;font-size:26px;margin-bottom:8px;letter-spacing:-0.015em}
  .power-card .pc-lede{font-size:14.5px;color:var(--muted);margin-bottom:18px;line-height:1.55}
  .power-card ul{list-style:none;display:grid;gap:8px}
  .power-card li{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--ink-soft)}
  .power-card li svg{width:16px;height:16px;color:var(--honey)}
  .power-card .pc-tag{margin-top:16px;font-size:12px;color:var(--honey-deep);font-style:italic}

  /* B Vitamins (kept name) */
  .bvit-bg{background:#fff}
  .bvit-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:18px}
  @media(max-width:880px){.bvit-grid{grid-template-columns:repeat(2,1fr)}}
  .bvit-pill{background:var(--honey-soft);border-radius:18px;padding:18px 12px;text-align:center}
  .bvit-pill .name{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:14px;color:var(--honey-deep);letter-spacing:.04em}
  .bvit-pill .sub{font-size:11px;color:var(--muted);margin-top:2px}
  .bvit-help{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:36px;align-items:stretch}
  @media(max-width:880px){.bvit-help{grid-template-columns:repeat(2,1fr)}}
  .bvit-help-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:24px;transition:transform .25s ease,box-shadow .25s ease}
  .bvit-help-card:hover{transform:translateY(-3px);box-shadow:0 14px 32px rgba(40,40,40,.10)}
  .bvit-help-card .bv-icon{width:64px;height:64px;border-radius:18px;background:#F7F7F8;color:var(--ink);display:grid;place-items:center;margin-bottom:14px}
  .bvit-help-card .bv-icon svg{width:30px;height:30px;stroke-width:2.2}
  .bvit-help-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:15px;margin-bottom:5px;color:var(--ink)}
  .bvit-help-card p{font-size:13px;color:var(--muted);line-height:1.5}

  /* Formula list */
  .formula-bg{background:#fff}
  .formula-list{margin-top:14px;border:1px solid var(--line);border-radius:22px;overflow:hidden;background:#fff}
  .formula-row{display:grid;grid-template-columns:1.5fr 1fr 2fr;align-items:center;padding:18px 22px;border-top:1px solid var(--line-soft)}
  .formula-row:first-child{border-top:0;background:var(--surface);font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--honey-deep)}
  .fc-name{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:700;color:var(--ink);font-size:14.5px}
  .fc-name small{display:block;font-size:11.5px;color:var(--muted);font-weight:500;margin-top:2px}
  .fc-amt{font-family:'Helvetica Neue',Arial,sans-serif;font-weight:700;color:var(--honey-deep);font-size:14px}
  .fc-role{font-size:13.5px;color:var(--muted);line-height:1.5}
  @media(max-width:680px){.formula-row{grid-template-columns:1fr}.fc-amt{font-size:13px}.formula-row:first-child{display:none}}

  /* Timeline */
  .timeline-bg{background:linear-gradient(180deg,#fff,var(--surface) 100%)}
  .timeline-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:16px;align-items:stretch}
  @media(max-width:880px){.timeline-grid{grid-template-columns:1fr}}
  .tl-card{background:#fff;border:1px solid var(--line);border-radius:22px;padding:30px;position:relative;transition:transform .3s ease,box-shadow .3s ease}
  .tl-card:hover{transform:translateY(-5px);box-shadow:0 22px 48px rgba(40,40,40,.10)}
  .tl-icon{width:64px;height:64px;border-radius:20px;background:#F7F7F8;color:var(--ink);display:grid;place-items:center}
  .tl-icon svg{width:30px;height:30px;stroke-width:2.2}
  .tl-step{position:absolute;top:22px;right:22px;background:var(--charcoal);color:#fff;font-family:'Helvetica Neue';font-weight:800;font-size:11px;padding:6px 12px;border-radius:16px;letter-spacing:.06em}
  .tl-card h4{font-family:'Helvetica Neue',Arial,sans-serif;font-size:22px;color:var(--ink);margin:22px 0 14px;max-width:80%;letter-spacing:-0.015em}
  .tl-card ul{list-style:none;display:grid;gap:7px}
  .tl-card li{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--ink-soft)}
  .tl-card li svg{width:15px;height:15px;color:var(--honey)}
  .tl-stat{margin-top:36px;background:var(--charcoal);color:#fff;border-radius:20px;padding:24px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
  .tl-stat strong{font-family:'Helvetica Neue';font-weight:800;font-size:22px;letter-spacing:-0.02em}
  .tl-stat .ref{font-size:11px;opacity:.85;font-style:italic}

  /* Compare */
  .why-bg{background:#fff}
  .compare-table{margin-top:14px;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff}
  .compare-row{display:grid;grid-template-columns:1.2fr 1fr 1fr}
  .compare-row + .compare-row{border-top:1px solid var(--line-soft)}
  .compare-row.head{background:var(--surface);font-family:'Helvetica Neue',Arial,sans-serif;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--ink)}
  .compare-row.head .cc{padding:14px 18px}
  .compare-row.head .cc:first-child{visibility:hidden}
  .compare-row.head .cc:nth-child(2){color:var(--honey-deep);background:var(--honey-soft)}
  .cc{padding:14px 18px;font-size:14px;line-height:1.45}
  .cc.lbl{font-weight:700;color:var(--ink)}
  .cc.them{color:var(--muted)}
  .cc.us{background:var(--honey-soft);color:var(--ink);font-weight:600}
  @media(max-width:680px){
    .compare-row{grid-template-columns:1fr 1fr}
    .compare-row.head .cc:first-child{display:none}
    .cc.lbl{grid-column:1/-1;background:var(--line-soft);font-size:13px}
  }

  /* Root cards */
  .root-bg{background:linear-gradient(180deg,var(--surface),#fff 100%)}
  .root-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:14px;align-items:stretch}
  @media(max-width:980px){.root-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:580px){.root-grid{grid-template-columns:1fr}}
  .root-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:28px;position:relative;transition:transform .3s ease,box-shadow .3s ease}
  .root-card:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(40,40,40,.10)}
  .root-card .rc-eye{display:inline-flex;align-items:center;background:var(--honey-soft);font-family:'Helvetica Neue';font-weight:800;font-size:11px;color:var(--honey-deep);letter-spacing:.08em;text-transform:uppercase;margin-bottom:12px;padding:5px 11px;border-radius:14px}
  .root-card h5{font-family:'Helvetica Neue',Arial,sans-serif;font-size:17px;color:var(--ink);margin-bottom:8px}
  .root-card p{font-size:13.5px;color:var(--muted);line-height:1.55;margin-bottom:16px}
  .root-card .solve{display:flex;gap:10px;align-items:flex-start;background:var(--honey-soft);color:var(--honey-deep);padding:12px 14px;border-radius:14px;font-size:13px;font-weight:600;line-height:1.4}
  .root-card .solve svg{width:18px;height:18px;flex-shrink:0;margin-top:1px;stroke-width:2.4}

  /* Reminder + final CTA */
  .reminder{background:var(--charcoal);color:#fff;padding:64px 0}
  .reminder .wrap{text-align:center}
  .reminder .eye{display:inline-block;background:rgba(255,255,255,.08);color:#fff;font-size:11px;font-weight:800;padding:6px 14px;border-radius:20px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px}
  .reminder h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:42px;font-weight:700;line-height:1.15;color:#fff;max-width:22ch;margin:0 auto 16px;letter-spacing:-0.02em}
  .reminder h2 em{font-style:italic;color:var(--honey);font-weight:500}
  .reminder p{font-size:16px;color:#bbb;max-width:560px;margin:0 auto 24px}
  .reminder .rem-row{display:inline-flex;flex-wrap:wrap;gap:8px;margin-top:8px;justify-content:center}
  .reminder .rem-chip{background:rgba(255,255,255,.07);color:#fff;font-size:12px;font-weight:600;padding:7px 14px;border-radius:20px}
  @media(max-width:680px){.reminder h2{font-size:32px}}

  .final{background:linear-gradient(180deg,var(--honey-soft) 0%,#fff 100%);padding:80px 0;text-align:center;position:relative}
  .final h2{font-family:'Helvetica Neue',Arial,sans-serif;font-size:44px;font-weight:700;line-height:1.15;max-width:22ch;margin:0 auto 14px}
  .final h2 em{font-style:italic;color:var(--honey);font-weight:500}
  @media(max-width:680px){.final h2{font-size:32px}}
  .final p{font-size:16px;color:var(--muted);max-width:540px;margin:0 auto 24px}
