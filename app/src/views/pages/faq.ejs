<script>
(function(){
  const y = document.getElementById('year');
  if (y) y.textContent = new Date().getFullYear();

  // FAQ search — show/hide items matching the query
  const input = document.getElementById('fqSearch');
  if (!input) return;
  const items = Array.from(document.querySelectorAll('.fq-item'));
  const chapters = Array.from(document.querySelectorAll('.fq-chap'));

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    items.forEach((it) => {
      const text = it.textContent.toLowerCase();
      it.style.display = !q || text.includes(q) ? '' : 'none';
    });
    // Hide chapters whose every item is hidden
    chapters.forEach((ch) => {
      const visible = ch.querySelectorAll('.fq-item:not([style*="display: none"])').length;
      ch.style.display = visible ? '' : 'none';
    });
  });

  // Active-chip highlight when scrolling
  const chips = Array.from(document.querySelectorAll('.fq-cat-chip'));
  const ids = chips.map(c => c.getAttribute('href').slice(1));
  const onScroll = () => {
    let cur = ids[0];
    for (const id of ids) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top - 120 <= 0) cur = id;
    }
    chips.forEach(c => c.classList.toggle('active', c.getAttribute('href') === '#' + cur));
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
