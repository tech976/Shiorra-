<style>
    /* ─────────── Order success (premium thank-you) ─────────── */
    .os-wrap {
        max-width: 640px; margin: 0 auto;
        display: flex; flex-direction: column; align-items: center;
        gap: 28px; padding: 8px 0 16px;
    }

    /* Hero checkmark */
    .os-mark {
        position: relative;
        width: 84px; height: 84px;
        border-radius: 50%;
        background: #FFFFFF;
        display: inline-flex; align-items: center; justify-content: center;
        box-shadow: 0 0 0 1px #D1E6D9 inset;
    }
    .os-mark::before {
        content: ""; position: absolute; inset: -10px;
        border-radius: 50%; border: 1px solid #E0EDE5;
    }
    .os-mark::after {
        content: ""; position: absolute; inset: -22px;
        border-radius: 50%; border: 1px solid #EEF6F1;
    }
    .os-mark svg { width: 36px; height: 36px; color: #2C6A4F; }

    .os-headline {
        text-align: center;
    }
    .os-headline h1 {
        margin: 0 0 10px 0; font-size: 32px; font-weight: 600;
        letter-spacing: -0.02em; line-height: 1.18;
        color: var(--c-text-1, #15171A);
    }
    .os-headline p {
        margin: 0; font-size: 15px; color: var(--c-text-2, #6A6F75);
        line-height: 1.55;
    }
    .os-headline strong { color: var(--c-text-1, #15171A); font-weight: 600; }

    .os-ordnum {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 13px; letter-spacing: 0.04em;
        background: #F4F5F6; border: 1px solid #ECECEC;
        padding: 6px 12px; border-radius: 8px;
        color: var(--c-text-1, #15171A); display: inline-block;
    }

    /* Section card (shared look with order-detail) */
    .os-card {
        width: 100%;
        background: #FFFFFF; border: 1px solid #ECECEC;
        border-radius: 14px; padding: 24px 26px;
    }
    .os-card__title {
        margin: 0 0 16px 0; font-size: 13px; font-weight: 600;
        letter-spacing: 0.04em; text-transform: uppercase;
        color: var(--c-text-2, #6A6F75);
    }

    /* Items list (compact) */
    .os-items { list-style: none; padding: 0; margin: 0; }
    .os-item {
        display: flex; justify-content: space-between; align-items: baseline;
        padding: 10px 0; border-bottom: 1px solid #ECECEC;
        font-size: 14px; color: var(--c-text-1, #15171A);
        gap: 12px;
    }
    .os-item:last-child { border-bottom: none; }
    .os-item__name { color: var(--c-text-1, #15171A); }
    .os-item__qty { color: var(--c-text-2, #6A6F75); font-size: 12px; margin-left: 4px; }
    .os-item__amt { font-weight: 500; }
    .os-total {
        display: flex; justify-content: space-between; align-items: baseline;
        margin-top: 14px; padding-top: 14px; border-top: 1px solid #ECECEC;
        font-size: 16px; font-weight: 600; letter-spacing: -0.01em;
        color: var(--c-text-1, #15171A);
    }

    /* What's next 3-step */
    .os-next {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 14px; width: 100%;
    }
    @media (max-width: 640px) { .os-next { grid-template-columns: 1fr; } }
    .os-step {
        background: #FFFFFF; border: 1px solid #ECECEC;
        border-radius: 12px; padding: 18px 16px;
        display: flex; flex-direction: column; gap: 10px;
        text-align: left;
    }
    .os-step__icon {
        width: 36px; height: 36px; border-radius: 10px;
        background: #F4F8F7; color: #23867F;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .os-step__lbl {
        margin: 0; font-size: 14px; font-weight: 600; letter-spacing: -0.005em;
        color: var(--c-text-1, #15171A);
    }
    .os-step__sub {
        margin: 0; font-size: 12px; color: var(--c-text-2, #6A6F75); line-height: 1.5;
    }
    .os-step--active .os-step__icon { background: #23867F; color: #FFFFFF; }
    .os-step--active { border-color: #D1E6D9; }

    /* Address card */
    .os-address {
        font-style: normal; font-size: 14px; line-height: 1.65;
        color: var(--c-text-1, #15171A);
    }
    .os-address strong { font-weight: 600; }

    /* Actions */
    .os-actions {
        display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
        margin-top: 4px;
    }
    .os-actions .btn { min-width: 180px; text-align: center; }

    .os-fineprint {
        font-size: 12px; color: var(--c-text-2, #6A6F75); text-align: center;
        max-width: 480px; line-height: 1.55;
    }
    .os-fineprint a { color: #23867F; text-decoration: none; }
    .os-fineprint a:hover { text-decoration: underline; }
</style>

<section class="section" style="padding-top:64px;">
    <div class="container">
        <div class="os-wrap">

            <!-- Checkmark hero -->
            <span class="os-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12.5 10 17 19 7"/>
                </svg>
            </span>

            <div class="os-headline">
                <h1>Thank you for your order</h1>
                <p>A confirmation has been sent to <strong><%= currentUser.email %></strong>.<br>We'll email you again the moment it ships.</p>
            </div>

            <span class="os-ordnum">Order #<%= order.orderNumber %></span>

            <!-- Order summary -->
            <section class="os-card">
                <h2 class="os-card__title">Your order</h2>
                <ul class="os-items">
                    <% order.items.forEach(function(it) { %>
                        <li class="os-item">
                            <span>
                                <span class="os-item__name"><%= it.name %></span>
                                <span class="os-item__qty">× <%= it.quantity %></span>
                            </span>
                            <span class="os-item__amt"><%= formatINR(it.totalInPaise) %></span>
                        </li>
                    <% }); %>
                </ul>
                <div class="os-total">
                    <span>Total paid</span>
                    <span><%= formatINR(order.totalInPaise) %></span>
                </div>
            </section>

            <!-- What's next -->
            <div class="os-next" aria-label="What happens next">
                <div class="os-step os-step--active">
                    <span class="os-step__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 7l8-4 8 4-8 4-8-4Z"/>
                            <path d="M4 7v10l8 4 8-4V7"/>
                            <path d="M12 11v10"/>
                        </svg>
                    </span>
                    <p class="os-step__lbl">We're packing</p>
                    <p class="os-step__sub">Your order is being prepared with care at our studio.</p>
                </div>
                <div class="os-step">
                    <span class="os-step__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 7h11v9H3z"/>
                            <path d="M14 10h4l3 3v3h-7"/>
                            <circle cx="7" cy="18" r="2"/>
                            <circle cx="17" cy="18" r="2"/>
                        </svg>
                    </span>
                    <p class="os-step__lbl">On the way</p>
                    <p class="os-step__sub">A tracking link will arrive in your inbox once we hand it to our courier.</p>
                </div>
                <div class="os-step">
                    <span class="os-step__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 11l8-7 8 7"/>
                            <path d="M6 10v10h12V10"/>
                            <path d="M10 20v-6h4v6"/>
                        </svg>
                    </span>
                    <p class="os-step__lbl">Arriving</p>
                    <p class="os-step__sub">Most orders reach you within 3–5 business days.</p>
                </div>
            </div>

            <!-- Shipping address -->
            <% if (order.shippingAddress) { %>
                <section class="os-card">
                    <h2 class="os-card__title">Shipping to</h2>
                    <address class="os-address">
                        <strong><%= order.shippingAddress.fullName %></strong><br>
                        <%= order.shippingAddress.line1 %><br>
                        <% if (order.shippingAddress.line2) { %><%= order.shippingAddress.line2 %><br><% } %>
                        <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.postcode %><br>
                        <%= order.shippingAddress.country %><br>
                        <span style="color:var(--c-text-2,#6A6F75);"><%= order.shippingAddress.phone %></span>
                    </address>
                </section>
            <% } %>

            <!-- Actions -->
            <div class="os-actions">
                <a href="/account/orders/<%= order.orderNumber %>" class="btn">Track this order</a>
                <a href="/shop" class="btn btn--ghost">Continue shopping</a>
            </div>

            <p class="os-fineprint">
                Questions about your order? <a href="/contact">Get in touch</a> — we usually reply the same day.
            </p>
        </div>
    </div>
</section>
