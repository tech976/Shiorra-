<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Invoice · <%= order.orderNumber %> · Shiōrra</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
    font: 14px/1.55 'Inter', system-ui, -apple-system, Helvetica, Arial, sans-serif;
    color: #1A1F2B;
    background: #F4F5F7;
    padding: 40px 20px 56px;
    -webkit-font-smoothing: antialiased;
}
.invoice {
    max-width: 800px;
    margin: 0 auto;
    background: #fff;
    padding: 60px 64px 52px;
    box-shadow: 0 12px 40px rgba(15,23,42,0.06);
    border-radius: 8px;
    border: 1px solid #ECECEC;
}
.invoice__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid #1A1F2B;
}
.invoice__brand {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.025em;
    color: #1A1F2B;
}
.invoice__brand small {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 700;
    color: #6B7280;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 6px;
}
.invoice__meta { text-align: right; font-size: 12px; color: #6B7280; line-height: 1.7; }
.invoice__meta strong {
    display: block;
    color: #1A1F2B;
    font-size: 18px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
    font-weight: 700;
}
.invoice__meta-row {
    display: flex;
    justify-content: flex-end;
    align-items: baseline;
    gap: 12px;
    line-height: 1.7;
}
.invoice__meta-row span:first-child {
    color: #8A8A8A;
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    min-width: 46px;
    text-align: right;
}
.invoice__meta-row span:last-child {
    color: #1A1F2B;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    min-width: 92px;
    text-align: right;
}
.invoice__status-pill {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: #E0F5EA;
    color: #1E9E5C;
}
.invoice__addr {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    margin-bottom: 36px;
}
.invoice__addr h4 {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8A8A8A;
    margin-bottom: 10px;
}
.invoice__addr address {
    font-style: normal;
    line-height: 1.6;
    color: #4A5160;
}
.invoice__addr address strong { color: #1A1F2B; font-weight: 600; }
.invoice table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 28px;
}
.invoice th {
    text-align: left;
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6B7280;
    padding: 12px;
    border-bottom: 1px solid #ECECEC;
    background: #FAFAFB;
}
.invoice th.r, .invoice td.r {
    text-align: right;
    font-variant-numeric: tabular-nums;
}
.invoice td {
    padding: 14px 12px;
    border-bottom: 1px solid #F4F4F5;
    vertical-align: top;
    color: #1A1F2B;
}
.invoice td strong { font-weight: 600; }
.invoice__totals {
    margin-left: auto;
    width: 320px;
    margin-bottom: 32px;
}
.invoice__totals .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 0;
    font-size: 13px;
    color: #6B7280;
    line-height: 1.3;
}
.invoice__totals .row span:last-child {
    font-variant-numeric: tabular-nums;
    color: #1A1F2B;
    font-weight: 500;
}
.invoice__totals .row--final {
    margin-top: 8px;
    padding-top: 14px;
    border-top: 2px solid #1A1F2B;
    font-weight: 700;
    color: #1A1F2B;
    font-size: 17px;
}
.invoice__totals .row--final span:last-child {
    font-weight: 800;
    font-size: 18px;
}
.invoice__foot {
    clear: both;
    padding-top: 28px;
    margin-top: 8px;
    border-top: 1px solid #ECECEC;
    font-size: 12px;
    color: #8A8A8A;
    text-align: center;
    line-height: 1.75;
    letter-spacing: 0.005em;
}
.invoice__foot strong { color: #1A1F2B; font-weight: 600; }
.invoice__paid-stamp {
    display: inline-block;
    margin-top: 18px;
    padding: 6px 16px;
    border: 2px solid #1E9E5C;
    color: #1E9E5C;
    border-radius: 6px;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
}
.printbar {
    max-width: 800px;
    margin: 0 auto 18px;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}
.printbar button, .printbar a {
    border: 1px solid #ECECEC;
    background: #fff;
    color: #1A1F2B;
    padding: 10px 18px;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.printbar button {
    background: #1A1F2B;
    color: #fff;
    border-color: #1A1F2B;
}
.printbar button:hover { background: #23867F; border-color: #23867F; }
.printbar a:hover { background: #FAFAFB; }

@media print {
    body { background: #fff; padding: 0; }
    .printbar { display: none; }
    .invoice { box-shadow: none; max-width: none; border: 0; padding: 28px; border-radius: 0; }
}
@media (max-width: 640px) {
    body { padding: 16px; }
    .invoice { padding: 32px 24px; }
    .invoice__top { flex-direction: column; gap: 16px; }
    .invoice__meta { text-align: left; }
    .invoice__meta-row { justify-content: flex-start; }
    .invoice__addr { grid-template-columns: 1fr; gap: 20px; }
    .invoice__totals { width: 100%; }
}
</style>
</head>
<body>

<div class="printbar">
    <a href="/admin/orders/<%= order.id %>">← Back</a>
    <button onclick="window.print()">Print / save PDF</button>
</div>

<div class="invoice">
    <div class="invoice__top">
        <div class="invoice__brand">
            Shiōrra
            <small>A trademark of K.C. Laboratories</small>
        </div>
        <div class="invoice__meta">
            <strong>Invoice</strong>
            <div class="invoice__meta-row"><span>No.</span><span><%= order.orderNumber %></span></div>
            <div class="invoice__meta-row"><span>Date</span><span><%= order.createdAt.toISOString().slice(0,10) %></span></div>
            <div class="invoice__meta-row"><span>Status</span><span><%= order.status %></span></div>
            <% if (order.paymentStatus === 'PAID' || order.paymentStatus === 'CAPTURED') { %>
                <div style="margin-top:8px"><span class="invoice__status-pill">Paid</span></div>
            <% } %>
        </div>
    </div>

    <div class="invoice__addr">
        <div>
            <h4>From</h4>
            <address>
                <strong>Shiōrra · K.C. Laboratories</strong><br>
                Mumbai, India<br>
                hello@shiorra.com<br>
                FSSAI &amp; GMP certified
            </address>
        </div>
        <div>
            <h4>Bill to</h4>
            <address>
                <% const billEmail = (order.user && order.user.email) || order.guestEmail || '—'; %>
                <% if (order.shippingAddress) { %>
                    <strong><%= order.shippingAddress.fullName %></strong><br>
                    <%= order.shippingAddress.line1 %><br>
                    <% if (order.shippingAddress.line2) { %><%= order.shippingAddress.line2 %><br><% } %>
                    <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.postcode %><br>
                    <%= order.shippingAddress.country %><br>
                    <%= order.shippingAddress.phone %><br>
                    <%= billEmail %>
                <% } else { %>
                    <strong><%= order.user ? (order.user.name || order.user.email) : 'Guest' %></strong><br>
                    <%= billEmail %>
                <% } %>
            </address>
        </div>
    </div>

    <table>
        <thead><tr><th>Item</th><th class="r">Qty</th><th class="r">Unit</th><th class="r">Total</th></tr></thead>
        <tbody>
        <% order.items.forEach(function(it) { %>
            <tr>
                <td><strong><%= it.name %></strong></td>
                <td class="r"><%= it.quantity %></td>
                <td class="r"><%= formatINR(it.priceInPaise) %></td>
                <td class="r"><%= formatINR(it.totalInPaise) %></td>
            </tr>
        <% }); %>
        </tbody>
    </table>

    <div class="invoice__totals">
        <div class="row"><span>Subtotal</span><span><%= formatINR(order.subtotalInPaise) %></span></div>
        <div class="row"><span>Shipping</span><span><%= order.shippingInPaise === 0 ? 'Free' : formatINR(order.shippingInPaise) %></span></div>
        <% if (order.discountInPaise > 0) { %>
            <div class="row"><span>Discount<% if (order.couponCode) { %> (<%= order.couponCode %>)<% } %></span><span>-<%= formatINR(order.discountInPaise) %></span></div>
        <% } %>
        <div class="row row--final"><span>Total</span><span><%= formatINR(order.totalInPaise) %></span></div>
    </div>

    <div class="invoice__foot">
        Thank you for choosing Shiōrra. Questions? <strong>hello@shiorra.com</strong><br>
        This is a system-generated invoice and does not require a signature.
    </div>
</div>

</body>
</html>
