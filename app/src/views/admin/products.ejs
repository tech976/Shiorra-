<%- include('./_styles') %>
<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">

        <div class="adm-hero">
            <div class="adm-crumbs">
                <a href="/admin">Admin</a>
                <span class="sep">/</span>
                <strong>Products</strong>
            </div>
            <div class="adm-hero__row">
                <div>
                    <h1>Products</h1>
                    <div class="adm-hero__sub"><%= products.length %> product<%= products.length === 1 ? '' : 's' %> in catalogue</div>
                </div>
                <div class="adm-hero__actions">
                    <a href="/admin/products/new" class="btn btn--sm adm-btn-accent">+ New product</a>
                </div>
            </div>
        </div>

        <form method="get" action="/admin/products" class="admin__search">
            <input type="text" name="q" value="<%= q || '' %>" placeholder="Search by name or slug…">
            <button class="btn btn--sm">Search</button>
            <% if (q) { %><a href="/admin/products" class="btn btn--sm btn--ghost">Clear</a><% } %>
        </form>

        <% if (!products.length) { %>
            <div class="adm-empty">
                <div class="adm-empty__art">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m7.5 4.27 9 5.15"/><path d="M21 8.5v7a2 2 0 0 1-1 1.73l-7 4a2 2 0 0 1-2 0l-7-4A2 2 0 0 1 3 15.5v-7a2 2 0 0 1 1-1.73l7-4a2 2 0 0 1 2 0l7 4A2 2 0 0 1 21 8.5z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                </div>
                <p>No products yet.</p>
                <a href="/admin/products/new" class="btn btn--sm">Create the first one</a>
            </div>
        <% } else { %>
            <div class="adm-table-wrap">
            <div class="adm-table-scroll">
            <table class="data-table">
                <thead><tr><th></th><th>Name</th><th>Slug</th><th class="adm-num">Price</th><th>Stock</th><th>Status</th><th></th></tr></thead>
                <tbody>
                <% products.forEach(function(p) { %>
                    <tr>
                        <td class="data-table__thumb">
                            <% if (p.images && p.images[0]) { %>
                                <img src="<%= p.images[0].url %>" alt="" style="border:1px solid var(--adm-line)">
                            <% } else { %>
                                <div style="width:48px;height:48px;border-radius:6px;background:var(--adm-line-2);border:1px solid var(--adm-line)"></div>
                            <% } %>
                        </td>
                        <td>
                            <a href="/admin/products/<%= p.id %>/edit"><strong><%= p.name %></strong></a>
                            <% if (p.featured) { %> <span class="badge badge--paid">★ Featured</span><% } %>
                        </td>
                        <td><code><%= p.slug %></code></td>
                        <td class="adm-num adm-money">
                            <%= formatINR(p.priceInPaise) %>
                            <% if (p.mrpInPaise) { %><br><small style="color:var(--adm-ink-3);text-decoration:line-through;font-weight:500"><%= formatINR(p.mrpInPaise) %></small><% } %>
                        </td>
                        <td>
                            <form action="/admin/products/<%= p.id %>/stock" method="post" class="quick-stock">
                                <input type="number" name="stock" value="<%= p.stock %>" min="0" step="1" style="border:1px solid var(--adm-line);border-radius:6px;padding:6px 8px">
                                <button class="btn btn--sm">Set</button>
                            </form>
                        </td>
                        <td>
                            <form action="/admin/products/<%= p.id %>/toggle-active" method="post" style="display:inline">
                                <button class="badge badge--<%= p.active ? 'paid' : 'cancelled' %>" style="border:0;cursor:pointer;">
                                    <%= p.active ? 'Active' : 'Hidden' %>
                                </button>
                            </form>
                        </td>
                        <td class="data-table__actions">
                            <a href="/product/<%= p.slug %>" class="btn btn--sm btn--ghost" target="_blank">View</a>
                            <a href="/admin/products/<%= p.id %>/edit" class="btn btn--sm">Edit</a>
                            <form action="/admin/products/<%= p.id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete <%= p.name %>?')" style="display:inline">
                                <button class="btn btn--sm btn--danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            </div>
            </div>
        <% } %>
    </div>
</div>
