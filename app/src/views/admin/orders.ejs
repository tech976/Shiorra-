<%- include('./_styles') %>
<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">

        <div class="adm-hero">
            <div class="adm-crumbs">
                <a href="/admin">Admin</a>
                <span class="sep">/</span>
                <strong>Orders</strong>
            </div>
            <div class="adm-hero__row">
                <div>
                    <h1>Orders</h1>
                    <div class="adm-hero__sub">
                        <%= orders.length %> matching · <%= matchPaidCount %> paid · <strong style="color:var(--adm-ink)"><%= formatINR(matchPaidRevInPaise) %></strong> revenue
                    </div>
                </div>
                <div class="adm-hero__actions">
                    <a href="/admin/orders.csv?<%= new URLSearchParams({ q, status: activeStatus, from, to }).toString() %>" class="btn btn--sm btn--ghost">Export CSV</a>
                </div>
            </div>
        </div>

        <form method="get" action="/admin/orders" class="admin__search admin__search--multi">
            <input type="text" name="q" value="<%= q %>" placeholder="Order number, customer name or email…">
            <select name="status">
                <option value="">All statuses</option>
                <% statuses.forEach(function(s) { %>
                    <option value="<%= s %>" <%= activeStatus === s ? 'selected' : '' %>><%= s %></option>
                <% }); %>
            </select>
            <label class="datelbl">From<input type="date" name="from" value="<%= from %>"></label>
            <label class="datelbl">To<input type="date" name="to" value="<%= to %>"></label>
            <button class="btn btn--sm">Filter</button>
            <% if (q || activeStatus || from || to) { %><a href="/admin/orders" class="btn btn--sm btn--ghost">Clear</a><% } %>
        </form>

        <% if (!orders.length) { %>
            <div class="adm-empty">
                <div class="adm-empty__art">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                </div>
                <p>No orders match your filter.</p>
                <% if (q || activeStatus || from || to) { %><a href="/admin/orders" class="btn btn--sm">Clear filters</a><% } %>
            </div>
        <% } else { %>
            <form action="/admin/orders/bulk" method="post" id="bulkForm">
                <div class="bulk-bar" id="bulkBar" hidden>
                    <span id="bulkCount">0 selected</span>
                    <select name="action" required>
                        <option value="">Bulk action…</option>
                        <option value="status:PROCESSING">Mark as Processing</option>
                        <option value="status:SHIPPED">Mark as Shipped</option>
                        <option value="status:DELIVERED">Mark as Delivered</option>
                        <option value="status:CANCELLED">Mark as Cancelled</option>
                    </select>
                    <button class="btn btn--sm" type="submit">Apply</button>
                </div>

                <div class="adm-table-wrap">
                <div class="adm-table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:34px"><input type="checkbox" id="bulkAll"></th>
                            <th>Order</th>
                            <th>Customer</th>
                            <th class="adm-num">Items</th>
                            <th class="adm-num">Total</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    <% orders.forEach(function(o) { %>
                        <tr>
                            <td><input type="checkbox" name="ids" value="<%= o.id %>" class="bulk-row"></td>
                            <td>
                                <a href="/admin/orders/<%= o.id %>"><strong><%= o.orderNumber %></strong></a>
                                <% if (o.couponCode) { %><br><small style="color:var(--adm-ink-3)">🎟 <%= o.couponCode %></small><% } %>
                            </td>
                            <td>
                                <a href="/admin/users/<%= o.userId %>"><%= o.user.name || o.user.email %></a><br>
                                <small style="color:var(--adm-ink-3)"><%= o.user.email %></small>
                            </td>
                            <td class="adm-num"><%= o.items.length %></td>
                            <td class="adm-num adm-money">
                                <%= formatINR(o.totalInPaise) %>
                                <% if (o.discountInPaise > 0) { %><br><small style="color:var(--c-success);font-weight:500">-<%= formatINR(o.discountInPaise) %></small><% } %>
                            </td>
                            <td><span class="badge badge--<%= o.status.toLowerCase() %>"><%= o.status %></span></td>
                            <td><span class="badge badge--<%= o.paymentStatus.toLowerCase() %>"><%= o.paymentStatus %></span></td>
                            <td style="color:var(--adm-ink-3);font-size:0.84rem;font-variant-numeric:tabular-nums"><%= o.createdAt.toISOString().slice(0,10) %></td>
                            <td>
                                <div style="display:flex;gap:6px">
                                    <a href="/admin/orders/<%= o.id %>" class="btn btn--sm">Open</a>
                                    <a href="/admin/orders/<%= o.id %>/invoice" target="_blank" class="btn btn--sm btn--ghost">Invoice</a>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                    </tbody>
                </table>
                </div>
                </div>
            </form>
        <% } %>
    </div>
</div>

<script>
(function() {
    const all = document.getElementById('bulkAll');
    const rows = document.querySelectorAll('.bulk-row');
    const bar = document.getElementById('bulkBar');
    const count = document.getElementById('bulkCount');
    if (!all) return;

    const refresh = () => {
        const sel = Array.from(rows).filter((r) => r.checked).length;
        bar.hidden = sel === 0;
        count.textContent = `${sel} selected`;
    };
    all.addEventListener('change', () => {
        rows.forEach((r) => (r.checked = all.checked));
        refresh();
    });
    rows.forEach((r) => r.addEventListener('change', refresh));
})();
</script>
