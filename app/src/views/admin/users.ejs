<%- include('./_styles') %>
<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">

        <div class="adm-hero">
            <div class="adm-crumbs">
                <a href="/admin">Admin</a>
                <span class="sep">/</span>
                <strong>Customers</strong>
            </div>
            <div class="adm-hero__row">
                <div>
                    <h1>Customers</h1>
                    <div class="adm-hero__sub"><%= users.length %> customer<%= users.length === 1 ? '' : 's' %> total</div>
                </div>
            </div>
        </div>

        <form method="get" action="/admin/users" class="admin__search">
            <input type="text" name="q" value="<%= q || '' %>" placeholder="Search by name, email or phone…">
            <button class="btn btn--sm">Search</button>
            <% if (q) { %><a href="/admin/users" class="btn btn--sm btn--ghost">Clear</a><% } %>
        </form>

        <% if (!users.length) { %>
            <div class="adm-empty">
                <div class="adm-empty__art">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                </div>
                <h4>No customers match your search</h4>
                <p>Try a broader query — name, email or phone all work.</p>
            </div>
        <% } else { %>
            <div class="adm-table-wrap">
            <div class="adm-table-scroll">
            <table class="data-table">
                <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th class="adm-num">Orders</th><th>Joined</th><th></th></tr></thead>
                <tbody>
                <% users.forEach(function(u) { %>
                    <tr>
                        <td><a href="/admin/users/<%= u.id %>"><strong><%= u.name || '—' %></strong></a></td>
                        <td class="adm-cell-mute"><%= u.email %></td>
                        <td class="adm-cell-mute adm-cell-tabular"><%= u.phone || '—' %></td>
                        <td><span class="badge badge--<%= u.role.toLowerCase() %>"><%= u.role %></span></td>
                        <td class="adm-num"><%= u._count.orders %></td>
                        <td class="adm-cell-date"><%= u.createdAt.toISOString().slice(0,10) %></td>
                        <td class="data-table__actions">
                            <a href="/admin/users/<%= u.id %>" class="btn btn--sm">Open</a>
                            <% if (u.id !== currentUser.id) { %>
                                <form action="/admin/users/<%= u.id %>/toggle-role" method="post" onsubmit="return confirm('Toggle role for <%= u.email %>?')" class="adm-inline-toggle">
                                    <button class="btn btn--sm btn--ghost" type="submit">Make <%= u.role === 'ADMIN' ? 'User' : 'Admin' %></button>
                                </form>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            </div>
            </div>
        <% } %>
    </div>
</div>
