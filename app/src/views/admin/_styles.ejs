<%
// Shared admin polish styles — Shopify Admin × Stripe Dashboard × Linear.
// Included from every admin EJS. Builds on top of /css/app.css without overriding it;
// new classes are namespaced `.adm-*` so existing .admin / .data-table / .kpi etc.
// continue to render as before.
%>
<style>
/* ============================================================
   ADMIN POLISH LAYER · namespaced .adm-* tokens
   ------------------------------------------------------------ */
:root {
    --adm-sage: #23867F;
    --adm-sage-deep: #1B6A65;
    --adm-sage-soft: #E8F2F0;
    --adm-ink: #1A1F2B;
    --adm-ink-2: #4A5160;
    --adm-ink-3: #6B7280;
    --adm-line: #ECECEC;
    --adm-line-2: #F4F4F5;
    --adm-bg: #FAFAFA;
    --adm-radius: 16px;
    --adm-radius-sm: 10px;
    --adm-shadow-card: 0 1px 2px rgba(40,40,40,.04);
    --adm-shadow-card-hover: 0 4px 14px rgba(40,40,40,.08);
    --adm-shadow-pop: 0 10px 30px rgba(15,23,42,.06);
    --adm-row-pad-y: 14px;
    --adm-row-pad-x: 16px;
}

/* ---------- Layout shell ---------- */
.admin { background: var(--adm-bg); min-height: 100vh; }
.admin__main { background: var(--adm-bg); padding: 28px clamp(20px, 3vw, 40px) 64px !important; }

/* ---------- Sidebar polish (Stripe / Shopify) ---------- */
.admin__nav {
    background: linear-gradient(180deg, #15191F 0%, #0F1318 100%);
    padding: 24px 14px 28px !important;
    width: 232px;
    border-right: 1px solid #000;
}
.admin__nav h4 {
    display: none; /* replaced by .adm-nav-brand */
}
.adm-nav-brand {
    display: flex; align-items: center; gap: 10px;
    padding: 4px 10px 22px;
    color: #fff;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-weight: 800;
    letter-spacing: -0.01em;
    font-size: 1.05rem;
}
.adm-nav-brand small {
    display: block;
    font-size: 9.5px;
    font-weight: 700;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 3px;
}
.adm-nav-brand .adm-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--adm-sage);
    box-shadow: 0 0 0 4px rgba(35,134,127,0.18);
}
.adm-nav-section {
    color: rgba(255,255,255,0.36);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 18px 12px 8px;
}
.admin__nav a {
    display: flex !important;
    align-items: center;
    gap: 11px;
    height: 40px;
    padding: 0 12px !important;
    margin: 1px 0;
    border-radius: 8px;
    font-size: 0.86rem !important;
    color: rgba(255,255,255,0.72) !important;
    font-weight: 500;
    position: relative;
    transition: background 0.15s, color 0.15s;
}
.admin__nav a:hover {
    background: rgba(255,255,255,0.05) !important;
    color: #fff !important;
}
.admin__nav a.active {
    background: rgba(35,134,127,0.16) !important;
    color: #fff !important;
    font-weight: 600;
}
.admin__nav a.active::before {
    content: "";
    position: absolute;
    left: -14px;
    top: 8px; bottom: 8px;
    width: 3px;
    background: var(--adm-sage);
    border-radius: 0 3px 3px 0;
}
.admin__nav a .adm-ico {
    width: 18px; height: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.55);
    flex-shrink: 0;
}
.admin__nav a .adm-ico svg {
    width: 18px; height: 18px; stroke-width: 1.7;
}
.admin__nav a.active .adm-ico,
.admin__nav a:hover .adm-ico { color: #fff; }
.admin__nav hr {
    border-top-color: rgba(255,255,255,0.06) !important;
    margin: 18px 0 !important;
}
.admin__nav-back {
    color: rgba(255,255,255,0.4) !important;
    font-size: 0.78rem !important;
}
.admin__nav-back .adm-ico svg { width: 14px; height: 14px; }

/* ---------- Page hero (breadcrumb + h1 + actions) — Stripe/Shopify pattern ---------- */
.adm-hero {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--adm-line);
}
.adm-crumbs {
    display: flex; align-items: center; gap: 6px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--adm-ink-3);
    margin-bottom: 12px;
    font-weight: 700;
}
.adm-crumbs a {
    color: var(--adm-ink-3);
    text-decoration: none;
}
.adm-crumbs a:hover { color: var(--adm-sage); }
.adm-crumbs span.sep { color: #CBD5E1; font-weight: 400; }
.adm-crumbs strong {
    color: var(--adm-ink);
    font-weight: 700;
}
.adm-hero__row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
}
.adm-hero h1 {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 2.2vw, 1.875rem); /* 28-30px */
    letter-spacing: -0.02em;
    color: var(--adm-ink);
    margin: 0;
    line-height: 1.15;
}
.adm-hero__sub {
    margin-top: 6px;
    color: var(--adm-ink-3);
    font-size: 0.875rem; /* 14px */
    line-height: 1.5;
}
.adm-hero__actions {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
}

/* Override the inherited .admin__head so it looks clean if used legacy */
.admin__head { margin-bottom: 0 !important; }

/* ---------- Cards ---------- */
.adm-card {
    background: #fff;
    border: 1px solid var(--adm-line);
    border-radius: var(--adm-radius);
    box-shadow: var(--adm-shadow-card);
    padding: 22px;
    transition: box-shadow 0.18s, transform 0.18s, border-color 0.18s;
}
.adm-card__head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 14px;
    gap: 16px;
    min-height: 22px;
}
.adm-card__head h3 {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin: 0;
    color: var(--adm-ink);
    line-height: 1.2;
}
.adm-card__head small {
    font-size: 0.74rem;
    color: var(--adm-ink-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
    line-height: 1.2;
}
.adm-card + .adm-card { margin-top: 20px; }

/* admin__panel polish to match adm-card */
.admin__panel {
    border: 1px solid var(--adm-line) !important;
    background: #fff !important;
    box-shadow: var(--adm-shadow-card);
    border-radius: var(--adm-radius) !important;
    padding: 22px !important;
    transition: box-shadow 0.18s, border-color 0.18s;
}
.admin__panel h3 {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: -0.005em;
}
/* hover lift on clickable cards (kpi etc.) */
.kpi { cursor: default; }
.adm-card:hover { box-shadow: var(--adm-shadow-card-hover); border-color: #DDE1E7; }

/* ---------- KPI polish · identical height, padding, hierarchy ---------- */
.kpis { gap: 16px !important; margin-bottom: 24px; align-items: stretch; }
.kpi {
    border: 1px solid var(--adm-line) !important;
    border-radius: var(--adm-radius) !important;
    padding: 18px 20px !important;
    background: #fff !important;
    box-shadow: var(--adm-shadow-card);
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
    min-height: 108px;
    display: flex !important;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0 !important;
}
.kpi:hover {
    transform: translateY(-1px);
    border-color: #D9DDE3 !important;
    box-shadow: var(--adm-shadow-card-hover);
}
.kpi__label {
    font-size: 11px !important;
    color: var(--adm-ink-3) !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    display: block;
}
.kpi__num {
    font-variant-numeric: tabular-nums;
    color: var(--adm-ink) !important;
    font-size: 1.625rem !important; /* 26px */
    margin: 8px 0 6px !important;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.015em;
    display: block;
}
.kpi__delta {
    font-size: 0.78rem !important;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    line-height: 1.3;
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 4px;
}
.kpi__delta.is-up    { color: #1E9E5C; }
.kpi__delta.is-down  { color: #DC3F5A; }
.kpi__delta.is-muted { color: var(--adm-ink-3); }
.kpi--accent {
    background: linear-gradient(180deg, #F2FAF8 0%, #E8F2F0 100%) !important;
    border-color: #D7E8E5 !important;
}
.kpi--accent .kpi__label,
.kpi--accent .kpi__num { color: var(--adm-sage-deep) !important; }
.kpi--warn {
    background: linear-gradient(180deg, #FFF8E8 0%, #FFEFCB 100%) !important;
    border-color: #F4DDA8 !important;
}
.kpi--warn .kpi__label,
.kpi--warn .kpi__num { color: #8A5A00 !important; }
/* Variant for date / non-currency values that shouldn't blow up the type scale */
.kpi__num--date { font-size: 1.125rem !important; font-weight: 700; }

/* ---------- Buttons (sage accent primary) ---------- */
.admin__main .btn:not(.btn--ghost):not(.btn--danger):not(.btn--link) {
    background: var(--adm-ink);
    border-color: var(--adm-ink);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    letter-spacing: 0.01em;
}
.admin__main .btn:not(.btn--ghost):not(.btn--danger):not(.btn--link):hover {
    background: var(--adm-sage-deep);
    border-color: var(--adm-sage-deep);
}
.admin__main .btn--ghost {
    background: #fff;
    color: var(--adm-ink-2);
    border: 1px solid var(--adm-line);
    border-radius: 8px;
    font-weight: 600;
}
.admin__main .btn--ghost:hover {
    background: var(--adm-line-2);
    color: var(--adm-ink);
    border-color: #D9DDE3;
}
.adm-btn-accent {
    background: var(--adm-sage) !important;
    border-color: var(--adm-sage) !important;
    color: #fff !important;
}
.adm-btn-accent:hover {
    background: var(--adm-sage-deep) !important;
    border-color: var(--adm-sage-deep) !important;
}

/* ---------- Tables · standardised row padding 14px, header #FAFAFA, hairline ---------- */
.adm-table-wrap {
    background: #fff;
    border: 1px solid var(--adm-line);
    border-radius: var(--adm-radius);
    box-shadow: var(--adm-shadow-card);
    overflow: hidden;
}
.adm-table-scroll { overflow-x: auto; }
.data-table {
    background: #fff !important;
    border-radius: 0 !important;
    border-collapse: collapse;
    width: 100%;
}
.data-table thead tr {
    background: #FAFAFA;
    border-bottom: 1px solid var(--adm-line);
}
.data-table th {
    background: #FAFAFA !important;
    padding: 11px var(--adm-row-pad-x) !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 0.1em !important;
    color: var(--adm-ink-3) !important;
    border-bottom: 1px solid var(--adm-line) !important;
    text-align: left;
    line-height: 1.3;
}
.data-table th.adm-num { text-align: right; }
.data-table td {
    padding: var(--adm-row-pad-y) var(--adm-row-pad-x) !important;
    border-top: 1px solid var(--adm-line-2) !important;
    color: var(--adm-ink) !important;
    font-size: 0.88rem;
    vertical-align: middle;
    line-height: 1.45;
}
.data-table tbody tr {
    transition: background 0.12s;
}
.data-table tbody tr:hover {
    background: #FAFAFB;
}
.data-table a {
    color: var(--adm-ink);
    text-decoration: none;
    font-weight: 600;
}
.data-table a:hover { color: var(--adm-sage); }
.data-table td code {
    background: var(--adm-line-2);
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 0.8rem;
    color: var(--adm-ink-2);
    font-variant-numeric: tabular-nums;
}
/* Dashboard "cozy" override — keep dense but still aligned */
.data-table--cozy th { padding: 10px 14px !important; font-size: 10.5px !important; }
.data-table--cozy td { padding: 12px 14px !important; font-size: 0.86rem; }

.adm-num {
    font-variant-numeric: tabular-nums;
    text-align: right;
    white-space: nowrap;
}
.adm-money {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--adm-ink);
}
/* numeric drift safety net — any td.adm-num descendant inherits tabular */
.data-table td.adm-num small,
.data-table td.adm-money small { font-variant-numeric: tabular-nums; }

/* ---------- Search + filter bar · uniform 40px control height ---------- */
.admin__search {
    background: #fff;
    border: 1px solid var(--adm-line);
    border-radius: 10px;
    padding: 10px;
    box-shadow: var(--adm-shadow-card);
    margin-bottom: 18px !important;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
}
.admin__search input,
.admin__search select {
    border: 1px solid var(--adm-line) !important;
    border-radius: 8px !important;
    padding: 0 12px !important;
    height: 40px;
    font-size: 0.9rem;
    background: #fff;
    color: var(--adm-ink);
    transition: border-color 0.15s, box-shadow 0.15s;
}
.admin__search input { flex: 1 1 220px; min-width: 200px; }
.admin__search input:focus,
.admin__search select:focus {
    outline: none;
    border-color: var(--adm-sage) !important;
    box-shadow: 0 0 0 3px rgba(35,134,127,0.12);
}
.admin__search .btn { height: 40px; }
.datelbl {
    font-size: 10px !important;
    color: var(--adm-ink-3) !important;
    letter-spacing: 0.1em;
    font-weight: 700;
    text-transform: uppercase;
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
}
.datelbl input { height: 40px; }

/* ---------- Status pills · single unified spec ---------- */
.badge,
.status-pill {
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    padding: 4px 10px !important;
    border-radius: 999px !important;
    text-transform: uppercase;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    gap: 6px;
    line-height: 1;
    min-height: 22px;
    white-space: nowrap;
    vertical-align: middle;
}
/* Tabular badges (with leading dot) — kept consistent across orders, users, coupons */
.badge--dot::before,
.status-pill--dot::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
}

/* ---------- Forms (premium) · 50px inputs, 14px font, sage focus ring ---------- */
.form-grid--admin {
    background: #fff;
    border: 1px solid var(--adm-line);
    border-radius: var(--adm-radius);
    padding: 28px;
    box-shadow: var(--adm-shadow-card);
    padding-bottom: 28px;
}
.form-grid--admin label {
    color: var(--adm-ink-3) !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}
.form-grid--admin label.form-grid__inline {
    text-transform: none;
    letter-spacing: normal;
    color: var(--adm-ink) !important;
    font-size: 0.9rem !important;
    font-weight: 500 !important;
}
.form-grid--admin input,
.form-grid--admin textarea,
.form-grid--admin select {
    font-size: 0.875rem !important; /* 14px */
    color: var(--adm-ink) !important;
    border: 1px solid var(--adm-line) !important;
    border-radius: 8px !important;
    padding: 0 14px !important;
    height: 44px;
    background: #fff !important;
    transition: border-color 0.15s, box-shadow 0.15s;
    font-weight: 500;
    text-transform: none;
    letter-spacing: normal;
    width: 100%;
}
.form-grid--admin textarea {
    padding: 12px 14px !important;
    height: auto;
    min-height: 88px;
    line-height: 1.55;
}
.form-grid--admin input[type=checkbox] {
    height: auto;
    width: auto;
}
.form-grid--admin input:focus,
.form-grid--admin textarea:focus,
.form-grid--admin select:focus {
    outline: none !important;
    border-color: var(--adm-sage) !important;
    box-shadow: 0 0 0 3px rgba(35,134,127,0.12) !important;
}
@media (max-width: 640px) {
    /* prevent iOS auto-zoom on input focus */
    .form-grid--admin input,
    .form-grid--admin textarea,
    .form-grid--admin select { font-size: 16px !important; height: 50px; }
    .form-grid--admin textarea { height: auto; }
}
.form-grid--admin fieldset {
    border: 1px solid var(--adm-line) !important;
    background: var(--adm-line-2);
    border-radius: 10px !important;
    padding: 18px !important;
}
.form-grid--admin legend {
    color: var(--adm-ink) !important;
    background: #fff;
    border: 1px solid var(--adm-line);
    border-radius: 6px;
    padding: 4px 10px !important;
    font-size: 0.78rem !important;
}
.form-hint {
    color: var(--adm-ink-3) !important;
    font-size: 0.78rem !important;
    font-weight: 400 !important;
    letter-spacing: normal !important;
    text-transform: none !important;
    display: block;
    margin-top: 6px;
}
.adm-input-code {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700 !important;
}

/* Drag-drop file upload */
.adm-dropzone {
    display: block;
    border: 1.5px dashed #D3D8DF;
    border-radius: 12px;
    padding: 36px 24px;
    background: #FCFCFD;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
}
.adm-dropzone:hover {
    border-color: var(--adm-sage);
    background: #F4FAF8;
}
.adm-dropzone__icon { color: #B4BAC4; margin-bottom: 8px; line-height: 0; }
.adm-dropzone__title { color: var(--adm-ink); font-size: 0.92rem; font-weight: 600; text-transform: none; letter-spacing: normal; }
.adm-dropzone__hint  { color: var(--adm-ink-3); font-size: 0.78rem; text-transform: none; letter-spacing: normal; font-weight: 400; margin-top: 4px; }

/* Save bar (sticky footer for forms) · prevent overlap via wrapper padding */
.adm-save-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    margin-top: 20px;
    background: #fff;
    border: 1px solid var(--adm-line);
    border-radius: 10px;
    box-shadow: 0 -2px 12px rgba(15,23,42,.05);
    position: sticky;
    bottom: 16px;
    z-index: 5;
}
.adm-save-bar .btn { height: 40px; }
.adm-save-bar__hint {
    margin-right: auto;
    color: var(--adm-ink-3);
    font-size: 0.82rem;
    align-self: center;
}
/* leave room below sticky save-bar so it never overlaps content */
form.form-grid--admin { padding-bottom: 28px; }
.admin__main:has(.adm-save-bar) { padding-bottom: 96px !important; }

/* ---------- Alerts ---------- */
.alert {
    background: #FFF6F8 !important;
    border-left: 3px solid #DC3F5A !important;
    color: #B83353 !important;
    border-radius: 8px !important;
    padding: 14px 18px !important;
}

/* ---------- Activity / list polish ---------- */
.activity li {
    padding: 12px 14px !important;
    background: var(--adm-line-2) !important;
    border-radius: 10px;
    border: 1px solid var(--adm-line);
}
.lowstock-list li {
    background: #FFF8E8 !important;
    border: 1px solid #F4DDA8;
}

/* ---------- KVP polish ---------- */
.kvp dt {
    font-size: 10.5px !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--adm-ink-3) !important;
    font-weight: 700;
}
.kvp dd { color: var(--adm-ink) !important; font-weight: 500; }

/* ---------- Misc helpers ---------- */
.adm-row-gap { display: flex; flex-direction: column; gap: 20px; }
.adm-section-gap { margin-top: 20px; }
.adm-link-accent { color: var(--adm-sage); text-decoration: none; font-weight: 600; }
.adm-link-accent:hover { color: var(--adm-sage-deep); }
.adm-link-muted  { color: inherit; text-decoration: underline; text-underline-offset: 2px; text-decoration-color: rgba(35,134,127,0.4); }
.adm-link-muted:hover { color: var(--adm-sage-deep); }
/* Cell helpers used across data tables */
.adm-cell-sub   { color: var(--adm-ink-3); font-size: 0.78rem; }
.adm-cell-date    { color: var(--adm-ink-3); font-size: 0.84rem; font-variant-numeric: tabular-nums; white-space: nowrap; }
.adm-cell-mute    { color: var(--adm-ink-2); }
.adm-cell-tabular { font-variant-numeric: tabular-nums; }
.adm-muted-line   { color: var(--adm-ink-3); font-size: 0.9rem; margin: 8px 0; }
.adm-cell-discount { color: #1E9E5C; font-weight: 600; font-variant-numeric: tabular-nums; }

/* hero sub variants */
.adm-hero__sub--inline { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.adm-hero__sep { color: #CBD5E1; font-weight: 400; }

/* Order detail · totals block */
.adm-totals {
    margin-top: 18px;
    padding: 16px 18px;
    background: var(--adm-line-2);
    border: 1px solid var(--adm-line);
    border-radius: 10px;
}

/* Order detail · customer block */
.adm-customer-block { line-height: 1.7; margin: 0; }
.adm-customer-block strong { color: var(--adm-ink); font-size: 0.96rem; font-weight: 600; }
