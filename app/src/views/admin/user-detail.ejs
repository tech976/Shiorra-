<%- include('./_styles') %>
<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">

        <div class="adm-hero">
            <div class="adm-crumbs">
                <a href="/admin">Admin</a>
                <span class="sep">/</span>
                <a href="/admin/users">Customers</a>
                <span class="sep">/</span>
                <strong><%= u.name || u.email %></strong>
            </div>
            <div class="adm-hero__row">
                <div>
                    <h1><%= u.name || u.email %></h1>
                    <div class="adm-hero__sub adm-hero__sub--inline">
                        <span><%= u.email %></span>
                        <span class="adm-hero__sep">·</span>
                        <span class="badge badge--<%= u.role.toLowerCase() %>"><%= u.role %></span>
                        <span class="adm-hero__sep">·</span>
                        <span>Joined <%= u.createdAt.toISOString().slice(0,10) %></span>
                    </div>
                </div>
                <div class="adm-hero__actions">
                    <a href="/admin/users" class="btn btn--ghost btn--sm">← All customers</a>
                </div>
            </div>
        </div>

        <div class="kpis kpis--small">
            <div class="kpi">
                <span class="kpi__label">Lifetime spend</span>
                <span class="kpi__num"><%= formatINR(lifetimeInPaise) %></span>
                <span class="kpi__delta is-muted"><%= paidOrders %> paid orders</span>
            </div>
            <div class="kpi">
                <span class="kpi__label">Average order value</span>
                <span class="kpi__num"><%= formatINR(aovInPaise) %></span>
                <span class="kpi__delta is-muted">Across paid orders</span>
            </div>
            <div class="kpi">
                <span class="kpi__label">Total orders</span>
                <span class="kpi__num"><%= u.orders.length %></span>
                <span class="kpi__delta is-muted">All statuses</span>
            </div>
            <div class="kpi">
                <span class="kpi__label">Last order</span>
                <span class="kpi__num kpi__num--date"><%= lastOrderAt ? lastOrderAt.toISOString().slice(0,10) : '—' %></span>
                <span class="kpi__delta is-muted">Most recent paid</span>
            </div>
        </div>

        <div class="admin__panels" style="margin-top:8px">
            <section class="admin__panel">
                <div class="adm-card__head">
                    <h3>Identity</h3>
                    <% if (u.id !== currentUser.id) { %>
                        <form action="/admin/users/<%= u.id %>/toggle-role" method="post" onsubmit="return confirm('Toggle role for <%= u.email %>?');" style="margin:0">
                            <input type="hidden" name="returnTo" value="/admin/users/<%= u.id %>">
                            <button class="btn btn--sm btn--ghost">Make <%= u.role === 'ADMIN' ? 'User' : 'Admin' %></button>
                        </form>
                    <% } %>
                </div>
                <dl class="kvp">
                    <dt>Email</dt><dd><%= u.email %></dd>
                    <dt>Name</dt><dd><%= u.name || '—' %></dd>
                    <dt>Phone</dt><dd><%= u.phone || '—' %></dd>
                    <dt>Role</dt><dd><span class="badge badge--<%= u.role.toLowerCase() %>"><%= u.role %></span></dd>
                    <dt>Joined</dt><dd><%= u.createdAt.toISOString().slice(0,10) %></dd>
                </dl>

                <hr class="adm-divider">

                <div class="adm-card__head">
                    <h3>Tags &amp; notes</h3>
                    <small>Internal only</small>
                </div>
                <form action="/admin/users/<%= u.id %>" method="post" class="form-grid form-grid--admin" style="padding:18px">
                    <label class="form-grid__full">Tags (comma-separated)
                        <input name="tags" value="<%= (u.tags || []).join(', ') %>" placeholder="vip, repeat, beta-tester">
                    </label>
                    <label class="form-grid__full">Internal notes
                        <textarea name="adminNotes" rows="4" placeholder="e.g. asked about postpartum kits; reach out about bundle offer"><%= u.adminNotes || '' %></textarea>
                    </label>
                    <div class="form-grid__full" style="text-align:right"><button class="btn btn--sm">Save</button></div>
                </form>
            </section>

            <section class="admin__panel">
                <div class="adm-card__head">
                    <h3>Saved addresses</h3>
                    <small><%= u.addresses.length %> on file</small>
                </div>
                <% if (!u.addresses.length) { %>
                    <p class="adm-muted-line">No saved addresses.</p>
                <% } else { %>
                    <ul class="address-list">
                        <% u.addresses.forEach(function(a) { %>
                            <li>
                                <% if (a.isDefault) { %><span class="badge badge--paid">Default</span><% } %>
                                <strong class="address-list__name"><%= a.fullName %></strong>
                                <span class="address-list__body">
                                    <%= a.line1 %><br>
                                    <% if (a.line2) { %><%= a.line2 %><br><% } %>
                                    <%= a.city %>, <%= a.state %> <%= a.postcode %><br>
                                    <%= a.country %><br>
                                    <%= a.phone %>
                                </span>
                            </li>
                        <% }); %>
                    </ul>
                <% } %>
            </section>
        </div>

        <section class="admin__panel" style="margin-top:24px">
            <div class="adm-card__head">
                <h3>Order history</h3>
                <small><%= u.orders.length %> total</small>
            </div>
            <% if (!u.orders.length) { %>
                <p class="adm-muted-line">This customer hasn't placed an order yet.</p>
            <% } else { %>
                <div class="adm-table-scroll">
                <table class="data-table">
                    <thead><tr><th>Order</th><th>Date</th><th class="adm-num">Items</th><th class="adm-num">Total</th><th>Status</th><th>Payment</th><th></th></tr></thead>
                    <tbody>
                    <% u.orders.forEach(function(o) { %>
                        <tr>
                            <td><a href="/admin/orders/<%= o.id %>"><strong><%= o.orderNumber %></strong></a></td>
                            <td class="adm-cell-date"><%= o.createdAt.toISOString().slice(0,10) %></td>
                            <td class="adm-num"><%= o.items.length %></td>
                            <td class="adm-num adm-money"><%= formatINR(o.totalInPaise) %></td>
                            <td><span class="badge badge--<%= o.status.toLowerCase() %>"><%= o.status %></span></td>
                            <td><span class="badge badge--<%= o.paymentStatus.toLowerCase() %>"><%= o.paymentStatus %></span></td>
                            <td class="data-table__actions"><a href="/admin/orders/<%= o.id %>" class="btn btn--sm">Open</a></td>
                        </tr>
                    <% }); %>
                    </tbody>
                </table>
                </div>
            <% } %>
        </section>
    </div>
</div>
