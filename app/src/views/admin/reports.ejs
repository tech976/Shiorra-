<%- include('./_styles') %>
<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">

        <div class="adm-hero">
            <div class="adm-crumbs">
                <a href="/admin">Admin</a>
                <span class="sep">/</span>
                <strong>Reports</strong>
            </div>
            <div class="adm-hero__row">
                <div>
                    <h1>Reports</h1>
                    <div class="adm-hero__sub">Revenue, shipping, discounts and product performance over the selected window.</div>
                </div>
                <div class="adm-hero__actions">
                    <div class="adm-segment" role="tablist" aria-label="Window">
                        <% [7, 14, 30, 60, 90, 180, 365].forEach(function(d) { %>
                            <a href="/admin/reports?days=<%= d %>" class="<%= d === days ? 'is-active' : '' %>"><%= d %>d</a>
                        <% }); %>
                    </div>
                    <a href="/admin/reports.csv?days=<%= days %>" class="btn btn--sm btn--ghost">Export CSV</a>
                </div>
            </div>
        </div>

        <div class="kpis kpis--small">
            <div class="kpi kpi--accent">
                <span class="kpi__label">Paid revenue · <%= days %>d</span>
                <span class="kpi__num"><%= formatINR(paidRevInPaise) %></span>
                <span class="kpi__delta is-muted"><%= paidOrderCount %> paid orders</span>
            </div>
            <div class="kpi">
                <span class="kpi__label">Shipping collected</span>
                <span class="kpi__num"><%= formatINR(shippingInPaise) %></span>
                <span class="kpi__delta is-muted">From paid orders</span>
            </div>
            <div class="kpi">
                <span class="kpi__label">Discounts given</span>
                <span class="kpi__num"><%= formatINR(discountInPaise) %></span>
                <span class="kpi__delta is-muted">Via coupons</span>
            </div>
            <div class="kpi">
                <span class="kpi__label">Net product revenue</span>
                <span class="kpi__num"><%= formatINR(paidRevInPaise - shippingInPaise) %></span>
                <span class="kpi__delta is-muted">Total minus shipping</span>
            </div>
        </div>

        <section class="admin__panel adm-section-gap">
            <div class="adm-card__head">
                <h3>Revenue &amp; orders</h3>
                <small>Last <%= days %> days</small>
            </div>
            <div class="chart-wrap"><canvas id="revChart" height="120"></canvas></div>
        </section>

        <section class="admin__panel adm-section-gap">
            <div class="adm-card__head">
                <h3>By product</h3>
                <small>Last <%= days %> days · ranked by revenue</small>
            </div>
            <% if (!byProduct.length) { %>
                <p class="adm-muted-line">No sales in the window.</p>
            <% } else { %>
                <div class="adm-table-scroll">
                <table class="data-table data-table--cozy">
                    <thead><tr><th>Product</th><th class="adm-num">Units</th><th class="adm-num">Revenue</th><th>Share</th></tr></thead>
                    <tbody>
                    <% const totalRev = byProduct.reduce((n, p) => n + p.revenueInPaise, 0); %>
                    <% byProduct.forEach(function(p) { %>
                        <% const pct = totalRev ? Math.round((p.revenueInPaise / totalRev) * 100) : 0; %>
                        <tr>
                            <td><strong><%= p.name %></strong></td>
                            <td class="adm-num"><%= p.units %></td>
                            <td class="adm-num adm-money"><%= formatINR(p.revenueInPaise) %></td>
                            <td>
                                <div class="adm-share">
                                    <div class="share-bar"><span style="width:<%= pct %>%"></span></div>
                                    <small class="adm-share__pct"><%= pct %>%</small>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                    </tbody>
                </table>
                </div>
            <% } %>
        </section>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function() {
    const SERIES = <%- JSON.stringify(series) %>;
    const ctx = document.getElementById('revChart');
    if (!ctx || !SERIES.length) return;
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: SERIES.map((s) => s.day.slice(5)),
            datasets: [
                {
                    type: 'bar',
                    label: 'Revenue (₹)',
                    data: SERIES.map((s) => s.revenueInPaise / 100),
                    backgroundColor: 'rgba(35,134,127,0.78)',
                    hoverBackgroundColor: 'rgba(27,106,101,1)',
                    borderRadius: 6,
                    yAxisID: 'y',
                },
                {
                    type: 'line',
                    label: 'Orders',
                    data: SERIES.map((s) => s.orders),
                    borderColor: '#1A1F2B',
                    backgroundColor: 'rgba(26,31,43,0.08)',
                    borderWidth: 2,
                    tension: 0.35,
                    pointRadius: 2.5,
                    pointBackgroundColor: '#1A1F2B',
                    yAxisID: 'y1',
                },
            ],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 10, color: '#6B7280', font: { size: 11 } } },
                tooltip: { backgroundColor: '#1A1F2B', padding: 10, cornerRadius: 6 },
            },
            scales: {
                y: { position: 'left', beginAtZero: true, ticks: { callback: (v) => '₹' + (v / 1000).toFixed(0) + 'k', color: '#6B7280', font: { size: 10 } }, grid: { color: 'rgba(15,23,42,0.05)' }, border: { display: false } },
                y1: { position: 'right', beginAtZero: true, ticks: { precision: 0, color: '#6B7280', font: { size: 10 } }, grid: { drawOnChartArea: false }, border: { display: false } },
                x: { grid: { display: false }, ticks: { color: '#6B7280', font: { size: 10 } }, border: { display: false } },
            },
        },
    });
})();
</script>
