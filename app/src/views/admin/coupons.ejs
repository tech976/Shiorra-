<%- include('./_styles') %>
<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">

        <div class="adm-hero">
            <div class="adm-crumbs">
                <a href="/admin">Admin</a>
                <span class="sep">/</span>
                <strong>Coupons</strong>
            </div>
            <div class="adm-hero__row">
                <div>
                    <h1>Coupons</h1>
                    <div class="adm-hero__sub"><%= coupons.length %> discount code<%= coupons.length === 1 ? '' : 's' %> configured</div>
                </div>
                <div class="adm-hero__actions">
                    <a href="/admin/coupons/new" class="btn btn--sm adm-btn-accent">+ New coupon</a>
                </div>
            </div>
        </div>

        <% if (!coupons.length) { %>
            <div class="adm-empty">
                <div class="adm-empty__art">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 12a2 2 0 0 1 0 4v2a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-2a2 2 0 0 0 0-4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg>
                </div>
                <p>No coupons yet. Create one to give customers a discount at checkout.</p>
                <a href="/admin/coupons/new" class="btn btn--sm">Create your first coupon</a>
            </div>
        <% } else { %>
            <div class="adm-table-wrap">
            <div class="adm-table-scroll">
            <table class="data-table">
                <thead><tr><th>Code</th><th>Discount</th><th class="adm-num">Min subtotal</th><th class="adm-num">Used</th><th>Status</th><th>Expires</th><th></th></tr></thead>
                <tbody>
                <% coupons.forEach(function(c) { %>
                    <tr>
                        <td><code class="coupon-code">🎟 <%= c.code %></code></td>
                        <td>
                            <% if (c.type === 'FIXED') { %>
                                <strong class="adm-money"><%= formatINR(c.value) %> off</strong>
                            <% } else { %>
                                <strong><%= c.value %>% off</strong>
                            <% } %>
                        </td>
                        <td class="adm-num"><%= c.minSubtotal > 0 ? formatINR(c.minSubtotal) : '—' %></td>
                        <td class="adm-num"><%= c.usedCount %><% if (c.usageLimit) { %> <span style="color:var(--adm-ink-3)">/ <%= c.usageLimit %></span><% } %></td>
                        <td>
                            <% const isExpired = c.expiresAt && new Date(c.expiresAt) < new Date(); %>
                            <% if (!c.active) { %>
                                <span class="badge badge--cancelled">Disabled</span>
                            <% } else if (isExpired) { %>
                                <span class="badge badge--cancelled">Expired</span>
                            <% } else { %>
                                <span class="badge badge--paid">Active</span>
                            <% } %>
                        </td>
                        <td style="color:var(--adm-ink-3);font-variant-numeric:tabular-nums;font-size:0.84rem"><%= c.expiresAt ? c.expiresAt.toISOString().slice(0,10) : '—' %></td>
                        <td class="data-table__actions">
                            <a href="/admin/coupons/<%= c.id %>/edit" class="btn btn--sm">Edit</a>
                            <form action="/admin/coupons/<%= c.id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete coupon <%= c.code %>?');" style="display:inline">
                                <button class="btn btn--sm btn--danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            </div>
            </div>
        <% } %>
    </div>
</div>
