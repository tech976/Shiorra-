<div class="admin">
    <%- include('./_nav') %>
    <div class="admin__main">
        <div class="admin__head">
            <h1><%= coupon ? 'Edit coupon' : 'New coupon' %></h1>
            <a href="/admin/coupons" class="btn btn--ghost btn--sm">← All coupons</a>
        </div>

        <% if (errors) { %>
            <div class="alert alert--error">
                <strong>Please fix:</strong>
                <ul>
                    <% errors.forEach(function(e) { %><li><%= e.path.join('.') %>: <%= e.message %></li><% }); %>
                </ul>
            </div>
        <% } %>

        <form action="<%= coupon ? '/admin/coupons/' + coupon.id : '/admin/coupons' %>" method="post" class="form-grid form-grid--admin">
            <label>Code<input name="code" required value="<%= values.code || '' %>" placeholder="WELCOME10" style="text-transform:uppercase"></label>
            <label>Type
                <select name="type">
                    <option value="PERCENT" <%= values.type === 'PERCENT' ? 'selected' : '' %>>Percent off</option>
                    <option value="FIXED" <%= values.type === 'FIXED' ? 'selected' : '' %>>Fixed amount off</option>
                </select>
            </label>
            <label>Value<input name="value" required value="<%= values.value || '' %>" placeholder="10 for 10% or 100 for ₹100">
                <small class="form-hint">Percent: 1-100 · Fixed: rupees off</small>
            </label>
            <label>Minimum subtotal (₹, optional)<input name="minSubtotal" value="<%= values.minSubtotal || '' %>" placeholder="0 for no minimum"></label>
            <label>Usage limit (optional)<input name="usageLimit" value="<%= values.usageLimit || '' %>" placeholder="Leave blank for unlimited"></label>
            <label>Expires on (optional)<input type="date" name="expiresAt" value="<%= values.expiresAt || '' %>"></label>
            <label class="form-grid__inline">
                <input type="checkbox" name="active" value="true" <%= values.active !== false ? 'checked' : '' %>>
                Active
            </label>
            <label class="form-grid__full">Internal notes (optional)
                <textarea name="notes" rows="2" placeholder="e.g. launched in newsletter Q3"><%= values.notes || '' %></textarea>
            </label>
            <div class="form-grid__full">
                <button class="btn"><%= coupon ? 'Save changes' : 'Create coupon' %></button>
            </div>
        </form>
    </div>
</div>
