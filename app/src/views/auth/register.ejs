<style>
  /* ============================================================
     Register — premium card layout (Apple / Stripe quality)
     Scoped to .auth-page so it cannot leak into app.css
     ============================================================ */
  .auth-page {
    background: #FAFAFA;
    padding: 64px 20px 96px;
    min-height: calc(100vh - 160px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .auth-page .auth-card {
    position: relative;
    width: 100%;
    max-width: 448px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 44px 40px 36px;
    box-shadow:
      0 1px 2px rgba(15,23,42,0.04),
      0 12px 32px -8px rgba(15,23,42,0.08),
      0 32px 64px -16px rgba(15,23,42,0.10);
  }
  .auth-page .auth-card::before {
    content: "";
    position: absolute;
    inset: -80px auto auto -60px;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, rgba(35,134,127,0.18) 0%, rgba(35,134,127,0) 70%);
    filter: blur(8px);
    z-index: -1;
    pointer-events: none;
  }
  .auth-page .auth-card__logo {
    display: flex;
    justify-content: center;
    margin-bottom: 28px;
  }
  .auth-page .auth-card__logo img {
    height: 28px;
    width: auto;
    display: block;
  }
  .auth-page h1 {
    font-family: 'Inter', sans-serif;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #0F172A;
    text-align: center;
    margin: 0 0 8px;
    line-height: 1.2;
  }
  .auth-page .auth-card__sub {
    text-align: center;
    color: #64748B;
    font-size: 14.5px;
    line-height: 1.5;
    margin: 0 0 28px;
  }
  .auth-page .auth__form {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin: 0 0 24px;
  }
  .auth-page .auth__form label {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: #475569;
  }
  .auth-page .auth__form .label-optional {
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
    color: #94A3B8;
    font-size: 11px;
    margin-left: 6px;
  }
  .auth-page .auth__form input {
    height: 50px;
    padding: 0 16px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #0F172A;
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
    -webkit-appearance: none;
    appearance: none;
  }
  .auth-page .auth__form input::placeholder { color: #94A3B8; }
  .auth-page .auth__form input:hover { border-color: #CBD5E1; }
  .auth-page .auth__form input:focus {
    outline: none;
    border-color: #23867F;
    box-shadow: 0 0 0 4px rgba(35,134,127,0.10);
    background: #fff;
  }
  .auth-page .auth__form .auth__hint {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #94A3B8;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
    margin: -4px 0 0 2px;
    line-height: 1.45;
  }
  .auth-page .auth__form button[type="submit"] {
    width: 100%;
    height: 52px;
    margin-top: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: #fff;
    background: #0F172A;
    border: 0;
    border-radius: 12px;
    cursor: pointer;
    transition: background .15s ease, transform .12s ease, box-shadow .15s ease;
  }
  .auth-page .auth__form button[type="submit"]:hover {
    background: #1E293B;
    transform: translateY(-1px);
    box-shadow: 0 6px 16px -4px rgba(15,23,42,0.30);
  }
  .auth-page .auth__form button[type="submit"]:active { transform: translateY(0); }
  .auth-page .auth__legal {
    text-align: center;
    font-size: 12px;
    color: #94A3B8;
    line-height: 1.5;
    margin: 0 0 16px;
  }
  .auth-page .auth__legal a {
    color: #64748B;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .auth-page .auth__alt {
    text-align: center;
    margin: 0;
    padding-top: 4px;
    font-size: 14px;
    color: #64748B;
  }
  .auth-page .auth__alt a {
    color: #23867F;
    font-weight: 500;
    text-decoration: none;
    padding: 6px 2px;
  }
  .auth-page .auth__alt a:hover { text-decoration: underline; }

  body:has(.auth-page) .site-footer { margin-top: 0; }

  @media (max-width: 640px) {
    .auth-page { padding: 36px 16px 56px; min-height: auto; }
    .auth-page .auth-card { padding: 36px 24px 28px; border-radius: 16px; }
    .auth-page .auth-card::before { display: none; }
    .auth-page h1 { font-size: 24px; }
    .auth-page .auth-card__sub { margin-bottom: 24px; font-size: 14px; }
    .auth-page .auth__form { gap: 16px; }
    .auth-page .auth__form input { height: 52px; font-size: 16px; }
    .auth-page .auth__form button[type="submit"] { height: 54px; font-size: 16px; }
  }
</style>
<section class="auth auth-page">
    <div class="auth-card">
        <div class="auth-card__logo">
            <img src="/img/logo/logo-green.png" alt="Shiorra">
        </div>
        <h1>Create your account</h1>
        <p class="auth-card__sub">Join Shiōrra — wellness, gently formulated.</p>
        <form action="/register" method="post" class="auth__form" novalidate>
            <label>
                Full name
                <input type="text" name="name" required value="<%= values.name || '' %>" autocomplete="name" placeholder="Your full name">
            </label>
            <label>
                Email
                <input type="email" name="email" required value="<%= values.email || '' %>" autocomplete="email" inputmode="email" placeholder="you@example.com">
            </label>
            <label>
                Phone <span class="label-optional">(optional)</span>
                <input type="tel" name="phone" value="<%= values.phone || '' %>" autocomplete="tel" inputmode="tel" placeholder="+91 98765 43210">
            </label>
            <label>
                Password
                <input type="password" name="password" required minlength="8" autocomplete="new-password" placeholder="At least 8 characters">
                <span class="auth__hint">Use 8 or more characters with a mix of letters and numbers.</span>
            </label>
            <button type="submit">Create account</button>
        </form>
        <p class="auth__legal">
            By creating an account you agree to our <a href="/terms">Terms</a> &amp; <a href="/privacy">Privacy Policy</a>.
        </p>
        <p class="auth__alt">Already have an account? <a href="/login">Log in</a></p>
    </div>
</section>
